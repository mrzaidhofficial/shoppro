<%- include('partials/header') %>

<section class="cart-section">
  <div class="container">
    <h1 style="font-family: var(--font-heading); font-size: 2rem; margin-bottom: 32px;">Shopping Cart</h1>

    <% if (cartItems && cartItems.length > 0) { %>
      <div class="cart-layout">
        <div class="cart-items-list">
          <% cartItems.forEach(function(item) { %>
            <div class="cart-item-row">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="cart-item-image" onerror="this.src='https://picsum.photos/100/100'">
              <div class="cart-item-info">
                <div class="cart-item-name"><%= item.name %></div>
                <div class="cart-item-price">$<%= item.price.toFixed(2) %> each</div>
                <div class="cart-item-actions">
                  <form action="/cart/update/<%= item.productId %>" method="POST" class="cart-qty-form" style="display:inline;">
                    <div class="cart-item-quantity">
                      <button type="button" class="cart-qty-btn cart-qty-minus" data-action="minus">−</button>
                      <input type="number" name="quantity" value="<%= item.quantity %>" min="1" class="cart-qty-input" readonly>
                      <button type="button" class="cart-qty-btn cart-qty-plus" data-action="plus">+</button>
                    </div>
                  </form>
                  <form action="/cart/remove/<%= item.productId %>" method="POST" style="display:inline;">
                    <button type="submit" class="cart-item-remove" title="Remove"><i class="fas fa-trash-alt"></i></button>
                  </form>
                </div>
              </div>
              <div class="cart-item-subtotal">$<%= (item.price * item.quantity).toFixed(2) %></div>
            </div>
          <% }) %>
        </div>

        <div class="cart-summary">
          <h3 class="cart-summary-title">Order Summary</h3>
          <div class="cart-summary-rows">
            <div class="cart-summary-row"><span>Subtotal</span><span>$<%= subtotal %></span></div>
            <div class="cart-summary-row"><span>Shipping</span><span><%= parseFloat(shipping) === 0 ? 'FREE' : '$' + shipping %></span></div>
            <div class="cart-summary-row"><span>Tax (8%)</span><span>$<%= tax %></span></div>
            <% if (typeof couponDiscount !== 'undefined' && parseFloat(couponDiscount) > 0) { %>
              <div class="cart-summary-row" style="color:var(--success);"><span>Coupon Discount</span><span>-$<%= couponDiscount %></span></div>
            <% } %>
            <div class="cart-summary-row total"><span>Total</span><span>$<%= total %></span></div>
          </div>
          
          <!-- Coupon Code -->
          <% if (!appliedCoupon) { %>
            <form action="/cart/apply-coupon" method="POST" style="display:flex;gap:8px;margin-bottom:16px;">
              <input type="text" name="couponCode" placeholder="Coupon code" style="flex:1;padding:10px 14px;border:2px solid var(--gray-200);border-radius:var(--radius-full);font-size:0.85rem;font-family:var(--font-primary);outline:none;" required>
              <button type="submit" style="padding:10px 18px;background:var(--accent);color:var(--gray-900);border:none;border-radius:var(--radius-full);font-weight:600;font-size:0.85rem;cursor:pointer;font-family:var(--font-primary);white-space:nowrap;">Apply</button>
            </form>
          <% } else { %>
            <div style="display:flex;align-items:center;justify-content:space-between;background:var(--success-bg);padding:10px 16px;border-radius:var(--radius-lg);margin-bottom:16px;">
              <span style="color:var(--success);font-weight:600;font-size:0.85rem;"><i class="fas fa-tag"></i> <%= appliedCoupon.code %></span>
              <a href="/cart/remove-coupon" style="color:var(--error);font-size:0.85rem;font-weight:600;text-decoration:none;">Remove</a>
            </div>
          <% } %>
          
          <div class="cart-summary-actions">
            <a href="/cart/checkout" class="btn btn-primary btn-lg btn-block"><i class="fas fa-lock"></i> Proceed to Checkout</a>
            <a href="/products" class="btn btn-outline btn-block">Continue Shopping</a>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="empty-cart">
        <div class="empty-cart-icon"><i class="fas fa-shopping-cart"></i></div>
        <h3 class="empty-cart-title">Your cart is empty</h3>
        <p class="empty-cart-text">Looks like you haven't added anything yet.</p>
        <a href="/products" class="btn btn-primary btn-lg">Start Shopping</a>
      </div>
    <% } %>
  </div>
</section>

<script>
(function() {
  'use strict';
  document.addEventListener('DOMContentLoaded', function() {
    var qtyForms = document.querySelectorAll('.cart-qty-form');
    qtyForms.forEach(function(form) {
      var input = form.querySelector('.cart-qty-input');
      var minusBtn = form.querySelector('.cart-qty-minus');
      var plusBtn = form.querySelector('.cart-qty-plus');
      if (!input || !minusBtn || !plusBtn) return;
      var newMinus = minusBtn.cloneNode(true);
      var newPlus = plusBtn.cloneNode(true);
      minusBtn.parentNode.replaceChild(newMinus, minusBtn);
      plusBtn.parentNode.replaceChild(newPlus, plusBtn);
      minusBtn = form.querySelector('.cart-qty-minus');
      plusBtn = form.querySelector('.cart-qty-plus');
      minusBtn.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); var currentVal = parseInt(input.value, 10); if (isNaN(currentVal)) currentVal = 1; if (currentVal > 1) { input.value = currentVal - 1; form.submit(); } });
      plusBtn.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); var currentVal = parseInt(input.value, 10); if (isNaN(currentVal)) currentVal = 0; input.value = currentVal + 1; form.submit(); });
    });
  });
})();
</script>

<%- include('partials/footer') %>