<%- include('partials/header') %>

<section class="auth-section">
  <div class="auth-card">
    <h1 class="auth-title">Reset Password</h1>
    <p class="auth-subtitle">Enter your new password</p>

    <form action="/auth/reset-password/<%= token %>" method="POST">
      <div class="form-group">
        <label class="form-label">New Password</label>
        <input type="password" name="password" class="form-input" placeholder="At least 6 characters" minlength="6" required autofocus>
      </div>

      <div class="form-group">
        <label class="form-label">Confirm New Password</label>
        <input type="password" name="password2" class="form-input" placeholder="Re-enter your new password" minlength="6" required>
      </div>

      <button type="submit" class="auth-submit-btn auth-submit-signin">
        <i class="fas fa-lock"></i> Reset Password
      </button>
    </form>

    <p class="auth-footer">
      <a href="/auth/signin">Back to Sign In</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>