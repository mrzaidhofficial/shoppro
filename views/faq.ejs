<%- include('partials/header') %>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
    padding: 70px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  [data-theme="dark"] .page-hero { background: linear-gradient(135deg, #020617 0%, #0F172A 100%); }
  .page-hero-icon {
    width: 70px; height: 70px; border-radius: 20px;
    background: rgba(124,58,237,0.15);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: #7C3AED;
    margin-bottom: 18px; position: relative; z-index: 1;
  }
  .page-hero-title {
    font-family: var(--font-display); font-size: clamp(1.6rem, 5vw, 2.2rem);
    font-weight: 700; color: #FFFFFF; position: relative; z-index: 1;
  }
  
  .page-content { padding: 56px 0; background: var(--bg-body); }
  .content-wrapper { max-width: 800px; margin: 0 auto; }
  
  .faq-category { margin-bottom: 28px; }
  .faq-category-title {
    font-family: var(--font-display); font-size: clamp(1.1rem, 3vw, 1.3rem);
    font-weight: 700; color: var(--text-primary);
    margin-bottom: 16px; display: flex; align-items: center; gap: 10px;
  }
  .faq-category-title i { color: var(--primary); font-size: 1.1rem; }
  
  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    margin-bottom: 10px;
    overflow: hidden;
    transition: all 0.2s ease;
  }
  .faq-item:hover { box-shadow: var(--shadow-sm); }
  .faq-question {
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.92rem;
    transition: color 0.2s ease;
    gap: 12px;
  }
  .faq-question:hover { color: var(--primary); }
  .faq-question i {
    font-size: 0.8rem;
    color: var(--text-muted);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .faq-item.open .faq-question i {
    transform: rotate(180deg);
    color: var(--primary);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 22px 18px;
    color: var(--text-body);
    font-size: 0.88rem;
    line-height: 1.7;
  }
  
  @media (max-width: 600px) {
    .page-hero { padding: 48px 0; }
    .page-hero-icon { width: 50px; height: 50px; font-size: 1.3rem; margin-bottom: 14px; }
    .page-content { padding: 36px 0; }
    .faq-question { padding: 14px 16px; font-size: 0.85rem; }
    .faq-answer p { padding: 0 16px 14px; font-size: 0.82rem; }
    .faq-category { margin-bottom: 20px; }
  }
</style>

<div class="page-hero">
  <div class="page-hero-icon"><i class="fas fa-question-circle"></i></div>
  <h1 class="page-hero-title">Frequently Asked Questions</h1>
</div>

<div class="page-content">
  <div class="container">
    <div class="content-wrapper">
      
      <!-- Orders -->
      <div class="faq-category">
        <h3 class="faq-category-title"><i class="fas fa-shopping-bag"></i> Orders</h3>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>How do I place an order?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Simply browse our products, add items to your cart, and proceed to checkout. You'll need to create an account or sign in, enter your shipping address, and complete payment via PayPal or credit card.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>Can I modify or cancel my order?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Orders can be modified or cancelled within 1 hour of placing them. After that, the order enters processing and cannot be changed. Please contact us immediately if you need to make changes.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>How do I track my order?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Once your order ships, you'll receive a tracking number via email. You can track your order anytime on our <a href="/track" style="color:var(--primary);font-weight:600;">Track Order</a> page by entering your tracking number and email address.</p>
          </div>
        </div>
      </div>
      
      <!-- Shipping -->
      <div class="faq-category">
        <h3 class="faq-category-title"><i class="fas fa-truck"></i> Shipping</h3>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>How long does shipping take?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Standard shipping typically takes 7-21 business days depending on your location. Processing takes 1-3 business days before shipping. See our <a href="/shipping-policy" style="color:var(--primary);font-weight:600;">Shipping Policy</a> for details.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>Do you offer free shipping?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Yes! We offer free shipping on orders that meet our minimum threshold. Check the shipping information at checkout or our <a href="/shipping-policy" style="color:var(--primary);font-weight:600;">Shipping Policy</a> page for current offers.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>Do you ship internationally?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Yes! We ship to over 50 countries worldwide. Shipping costs and delivery times vary by location and are calculated at checkout.</p>
          </div>
        </div>
      </div>
      
      <!-- Returns -->
      <div class="faq-category">
        <h3 class="faq-category-title"><i class="fas fa-undo-alt"></i> Returns & Refunds</h3>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>What is your return policy?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>We offer a 30-day return policy. Items must be unused and in original packaging. See our <a href="/returns" style="color:var(--primary);font-weight:600;">Returns & Exchanges</a> page for full details.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>How long do refunds take?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Once we receive and inspect your return, refunds are processed within 5-10 business days to your original payment method.</p>
          </div>
        </div>
      </div>
      
      <!-- Payment -->
      <div class="faq-category">
        <h3 class="faq-category-title"><i class="fas fa-credit-card"></i> Payment</h3>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>What payment methods do you accept?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>We accept PayPal and all major credit/debit cards processed through PayPal. Your payment information is always secure and encrypted.</p>
          </div>
        </div>
        
        <div class="faq-item">
          <div class="faq-question" onclick="toggleFaq(this)">
            <span>Is my payment information secure?</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="faq-answer">
            <p>Absolutely. All payments are processed through PayPal's secure payment gateway with industry-standard encryption. We never store your credit card details on our servers.</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
function toggleFaq(el) {
  var item = el.parentElement;
  var wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
  if (!wasOpen) { item.classList.add('open'); }
}
</script>

<%- include('partials/footer') %>