<%- include('../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); margin-bottom: 4px; }
  .admin-sidebar-header span { font-size: 0.78rem; color: var(--gray-500); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  .admin-page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
  .admin-page-title { font-family: var(--font-display); font-size: 1.8rem; color: var(--gray-900); }
  .btn-admin-primary { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--primary-gradient); color: var(--white) !important; border: none; border-radius: var(--radius-full); font-size: 0.88rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: var(--transition); box-shadow: 0 4px 16px rgba(0,102,255,0.3); }
  .btn-admin-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,102,255,0.4); }
  .table-wrapper { background: var(--white); border: var(--border); border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-xs); }
  .admin-table { width: 100%; border-collapse: collapse; }
  .admin-table th { text-align: left; padding: 14px 18px; background: var(--gray-50); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--gray-500); border-bottom: var(--border); }
  .admin-table td { padding: 14px 18px; font-size: 0.87rem; color: var(--gray-700); border-bottom: 1px solid var(--gray-100); }
  .admin-table tr:last-child td { border-bottom: none; }
  .badge-active { background: var(--success-bg); color: var(--success); padding: 3px 12px; border-radius: var(--radius-full); font-size: 0.72rem; font-weight: 600; }
  .badge-inactive { background: var(--error-bg); color: var(--error); padding: 3px 12px; border-radius: var(--radius-full); font-size: 0.72rem; font-weight: 600; }
  .btn-sm { padding: 6px 14px; font-size: 0.75rem; border-radius: var(--radius-full); font-weight: 600; cursor: pointer; border: none; font-family: var(--font-primary); }
  .btn-danger { background: var(--error); color: white; }
  .btn-warning { background: #F59E0B; color: white; }
  .btn-success { background: var(--success); color: white; }
  @media (max-width: 900px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; } .admin-sidebar-header { display: none; } .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; } .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); } }
</style>

<div class="container">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header"><h3>Admin Panel</h3><span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span></div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item active"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    <div class="admin-content">
      <div class="admin-page-header">
        <h1 class="admin-page-title">Coupons</h1>
        <a href="/admin/coupons/add" class="btn-admin-primary"><i class="fas fa-plus"></i> Add Coupon</a>
      </div>
      <% if (coupons && coupons.length > 0) { %>
        <div class="table-wrapper" style="overflow-x:auto;">
          <table class="admin-table">
            <thead><tr><th>Code</th><th>Discount</th><th>Min Purchase</th><th>Usage</th><th>Expiry</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              <% coupons.forEach(function(c) { %>
                <tr>
                  <td style="font-weight:700;"><%= c.code %></td>
                  <td><%= c.discountType === 'percentage' ? c.discountValue + '%' : '$' + c.discountValue.toFixed(2) %></td>
                  <td><%= c.minPurchase > 0 ? '$' + c.minPurchase.toFixed(2) : 'None' %></td>
                  <td><%= c.usedCount %>/<%= c.usageLimit || '∞' %></td>
                  <td><%= c.expiryDate ? c.expiryDate.toLocaleDateString() : 'No expiry' %></td>
                  <td><span class="<%= c.isActive ? 'badge-active' : 'badge-inactive' %>"><%= c.isActive ? 'Active' : 'Inactive' %></span></td>
                  <td style="display:flex;gap:6px;">
                    <form action="/admin/coupons/toggle/<%= c._id %>" method="POST"><button type="submit" class="btn-sm <%= c.isActive ? 'btn-warning' : 'btn-success' %>"><%= c.isActive ? 'Deactivate' : 'Activate' %></button></form>
                    <form action="/admin/coupons/delete/<%= c._id %>" method="POST" onsubmit="return confirm('Delete this coupon?')"><button type="submit" class="btn-sm btn-danger">Delete</button></form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:60px;background:var(--white);border:var(--border);border-radius:var(--radius-xl);"><i class="fas fa-tags" style="font-size:3rem;color:var(--gray-300);margin-bottom:12px;display:block;"></i><p>No coupons created yet.</p></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>