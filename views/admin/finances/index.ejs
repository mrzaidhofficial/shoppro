<%- include('../../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); margin-bottom: 4px; }
  .admin-sidebar-header span { font-size: 0.78rem; color: var(--gray-500); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  
  .page-top { margin-bottom: 24px; }
  .page-title { font-family: var(--font-display); font-size: 1.7rem; color: var(--text-primary); }
  .page-subtitle { font-size: 0.85rem; color: var(--text-muted); margin-top: 2px; }
  
  .summary-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 24px; }
  .summary-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); padding: 18px 20px; box-shadow: var(--shadow-xs); transition: var(--transition); }
  .summary-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .summary-icon { width: 36px; height: 36px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; margin-bottom: 10px; }
  .summary-icon.blue { background: #EFF6FF; color: #3B82F6; }
  .summary-icon.red { background: #FEF2F2; color: #EF4444; }
  .summary-icon.orange { background: #FFF7ED; color: #F97316; }
  .summary-icon.purple { background: #F5F3FF; color: #7C3AED; }
  .summary-icon.green { background: #ECFDF5; color: #059669; }
  [data-theme="dark"] .summary-icon.blue { background: rgba(59,130,246,0.2); color: #60A5FA; }
  [data-theme="dark"] .summary-icon.red { background: rgba(239,68,68,0.2); color: #F87171; }
  [data-theme="dark"] .summary-icon.orange { background: rgba(249,115,22,0.2); color: #FB923C; }
  [data-theme="dark"] .summary-icon.purple { background: rgba(124,58,237,0.2); color: #A78BFA; }
  [data-theme="dark"] .summary-icon.green { background: rgba(5,150,105,0.2); color: #34D399; }
  .summary-value { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 2px; }
  .summary-label { font-size: 0.68rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.6px; font-weight: 600; }
  
  .summary-card.revenue .summary-value { color: #2563EB; }
  .summary-card.costs .summary-value { color: #DC2626; }
  .summary-card.shipping .summary-value { color: #EA580C; }
  .summary-card.coupons .summary-value { color: #7C3AED; }
  .summary-card.profit .summary-value { color: #059669; }
  [data-theme="dark"] .summary-card.revenue .summary-value { color: #60A5FA; }
  [data-theme="dark"] .summary-card.costs .summary-value { color: #F87171; }
  [data-theme="dark"] .summary-card.shipping .summary-value { color: #FB923C; }
  [data-theme="dark"] .summary-card.coupons .summary-value { color: #A78BFA; }
  [data-theme="dark"] .summary-card.profit .summary-value { color: #4ADE80; }
  
  .filter-bar { display: flex; gap: 10px; margin-bottom: 20px; align-items: center; flex-wrap: wrap; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 12px 16px; }
  .filter-input, .filter-select { padding: 9px 14px; border: 2px solid var(--border-color); border-radius: var(--radius); font-size: 0.82rem; font-family: var(--font-primary); background: var(--bg-input); color: var(--text-body); outline: none; }
  .filter-input:focus, .filter-select:focus { border-color: var(--primary); background: var(--bg-card); }
  .filter-btn { padding: 9px 18px; background: var(--primary); color: #FFFFFF; border: none; border-radius: var(--radius); font-size: 0.82rem; font-weight: 600; cursor: pointer; font-family: var(--font-primary); }
  .filter-clear { padding: 9px 16px; border: 2px solid var(--border-color); border-radius: var(--radius); font-size: 0.78rem; font-weight: 600; color: var(--text-secondary); text-decoration: none; }
  .filter-clear:hover { background: var(--bg-hover); }
  
  .table-wrap { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-xs); }
  .finance-table { width: 100%; border-collapse: collapse; }
  .finance-table th { 
    text-align: left; padding: 12px 10px; background: var(--bg-card-alt); 
    font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.7px; 
    color: var(--text-muted); border-bottom: 2px solid var(--border-color); white-space: nowrap; 
  }
  .finance-table td { 
    padding: 12px 10px; font-size: 0.81rem; color: var(--text-body); 
    border-bottom: 1px solid var(--border-color); vertical-align: middle; background: var(--bg-card);
  }
  .finance-table tr:last-child td { border-bottom: none; }
  .finance-table tr:hover td { background: var(--bg-hover) !important; }
  
  .order-link { color: var(--primary); font-weight: 600; text-decoration: none; font-family: var(--font-display); font-size: 0.82rem; }
  .order-link:hover { text-decoration: underline; }
  .cust-name { font-weight: 500; color: var(--text-primary); font-size: 0.82rem; }
  .cust-email { font-size: 0.68rem; color: var(--text-muted); }
  .prod-name { font-weight: 500; color: var(--text-primary); }
  
  .amount { font-weight: 600; font-family: var(--font-display); }
  .amount.revenue-color { color: #2563EB; }
  .amount.cost-color { color: #DC2626; }
  .amount.shipping-color { color: #EA580C; }
  .amount.coupon-color { color: #7C3AED; }
  .amount.profit-color { color: #059669; }
  .amount.neutral { color: var(--text-primary); }
  [data-theme="dark"] .amount.revenue-color { color: #60A5FA; }
  [data-theme="dark"] .amount.cost-color { color: #F87171; }
  [data-theme="dark"] .amount.shipping-color { color: #FB923C; }
  [data-theme="dark"] .amount.coupon-color { color: #A78BFA; }
  [data-theme="dark"] .amount.profit-color { color: #4ADE80; }
  [data-theme="dark"] .amount.neutral { color: #F1F5F9; }
  
  .badge { display: inline-block; padding: 3px 9px; border-radius: var(--radius-full); font-size: 0.64rem; font-weight: 600; text-transform: capitalize; }
  .badge-processing { background: #FEF3C7; color: #D97706; }
  .badge-shipped { background: #DBEAFE; color: #2563EB; }
  .badge-delivered { background: #ECFDF5; color: #059669; }
  .badge-cancelled { background: #FEF2F2; color: #EF4444; }
  [data-theme="dark"] .badge-processing { background: rgba(251,191,36,0.2); color: #FBBF24; }
  [data-theme="dark"] .badge-shipped { background: rgba(59,130,246,0.2); color: #60A5FA; }
  [data-theme="dark"] .badge-delivered { background: rgba(52,211,153,0.2); color: #34D399; }
  [data-theme="dark"] .badge-cancelled { background: rgba(248,113,113,0.2); color: #F87171; }
  
  .pagination { display: flex; justify-content: center; gap: 5px; margin-top: 20px; }
  .page-link { padding: 7px 12px; border: 2px solid var(--border-color); border-radius: var(--radius-full); font-weight: 600; color: var(--text-secondary); text-decoration: none; font-size: 0.8rem; background: var(--bg-card); }
  .page-link:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
  .page-link.active { background: var(--primary-gradient); color: #FFFFFF; border-color: var(--primary); }
  
  .empty { text-align: center; padding: 60px 20px; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); }
  .empty i { font-size: 3rem; color: var(--text-muted); margin-bottom: 12px; display: block; }
  .empty p { color: var(--text-muted); }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
    .summary-grid { grid-template-columns: repeat(3, 1fr); }
    .filter-bar { flex-direction: column; }
  }
  @media (max-width: 500px) {
    .summary-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/admin/shipping/settings" class="admin-nav-item"><i class="fas fa-truck"></i> Shipping</a>
      <a href="/admin/finances" class="admin-nav-item active"><i class="fas fa-chart-pie"></i> Finances</a>
      <a href="/admin/bank-details" class="admin-nav-item"><i class="fas fa-university"></i> Bank Details</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <div class="page-top">
        <h1 class="page-title">Finances</h1>
        <p class="page-subtitle">Complete financial breakdown of all orders</p>
      </div>
      
      <div class="summary-grid">
        <div class="summary-card revenue">
          <div class="summary-icon blue"><i class="fas fa-shopping-cart"></i></div>
          <div class="summary-value">LKR <%= totalRevenue.toFixed(2) %></div>
          <div class="summary-label">Total Revenue</div>
        </div>
        <div class="summary-card costs">
          <div class="summary-icon red"><i class="fas fa-receipt"></i></div>
          <div class="summary-value">−LKR <%= totalProductCost.toFixed(2) %></div>
          <div class="summary-label">Product Costs</div>
        </div>
        <div class="summary-card shipping">
          <div class="summary-icon orange"><i class="fas fa-truck"></i></div>
          <div class="summary-value">−LKR <%= totalShippingCost.toFixed(2) %></div>
          <div class="summary-label">Shipping Costs</div>
        </div>
        <div class="summary-card coupons">
          <div class="summary-icon purple"><i class="fas fa-tag"></i></div>
          <div class="summary-value">−LKR <%= totalCoupons.toFixed(2) %></div>
          <div class="summary-label">Coupons</div>
        </div>
        <div class="summary-card profit">
          <div class="summary-icon green"><i class="fas fa-chart-line"></i></div>
          <div class="summary-value">LKR <%= totalNetProfit.toFixed(2) %></div>
          <div class="summary-label">Net Profit</div>
        </div>
      </div>
      
      <form class="filter-bar" method="GET" action="/admin/finances">
        <select name="status" class="filter-select">
          <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All Status</option>
          <option value="processing" <%= currentStatus === 'processing' ? 'selected' : '' %>>Processing</option>
          <option value="shipped" <%= currentStatus === 'shipped' ? 'selected' : '' %>>Shipped</option>
          <option value="delivered" <%= currentStatus === 'delivered' ? 'selected' : '' %>>Delivered</option>
          <option value="cancelled" <%= currentStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
        <input type="date" name="dateFrom" class="filter-input" value="<%= currentDateFrom %>" placeholder="From date">
        <input type="date" name="dateTo" class="filter-input" value="<%= currentDateTo %>" placeholder="To date">
        <button type="submit" class="filter-btn"><i class="fas fa-filter"></i> Filter</button>
        <% if (currentStatus !== 'all' || currentDateFrom || currentDateTo) { %>
          <a href="/admin/finances" class="filter-clear">Clear</a>
        <% } %>
      </form>
      
      <% if (orders && orders.length > 0) { %>
        <div class="table-wrap" style="overflow-x:auto;">
          <table class="finance-table">
            <thead>
              <tr>
                <th>Order #</th><th>Date</th><th>Customer</th><th>Product</th><th>Qty</th><th>Price</th><th>Cost</th><th>Shipping</th><th>Coupon</th><th>Revenue</th><th>Profit</th><th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(function(order) { %>
                <% if (order.items && order.items.length > 0) { %>
                  <% order.items.forEach(function(item, idx) { 
                    var itemRevenue = order.total || 0;
                    var itemShipping = order.shippingCost || 0;
                    var itemCoupon = order.couponDiscount || 0;
                    var itemProfit = (itemRevenue - ((item.cost || 0) * item.quantity) - (idx === 0 ? itemShipping : 0));
                  %>
                    <tr>
                      <td><a href="/admin/shipping/orders/<%= order._id %>" class="order-link"><%= order.orderNumber %></a></td>
                      <td style="font-size:0.76rem;white-space:nowrap;"><%= order.createdAt.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></td>
                      <td>
                        <div class="cust-name"><%= order.user ? order.user.firstName + ' ' + order.user.lastName : 'N/A' %></div>
                        <div class="cust-email"><%= order.user ? order.user.email : '' %></div>
                      </td>
                      <td><span class="prod-name"><%= item.name %></span></td>
                      <td><%= item.quantity %></td>
                      <td class="amount neutral">LKR <%= item.price.toFixed(2) %></td>
                      <td class="amount cost-color">LKR <%= ((item.cost || 0) * item.quantity).toFixed(2) %></td>
                      <td class="amount shipping-color"><%= idx === 0 ? 'LKR ' + itemShipping.toFixed(2) : '—' %></td>
                      <td class="amount coupon-color"><%= idx === 0 && itemCoupon > 0 ? '−$' + itemCoupon.toFixed(2) : 'LKR 0.00' %></td>
                      <td class="amount revenue-color"><%= idx === 0 ? 'LKR ' + itemRevenue.toFixed(2) : '—' %></td>
                      <td class="amount <%= itemProfit >= 0 ? 'profit-color' : 'cost-color' %>">
                        <%= idx === 0 ? 'LKR ' + itemProfit.toFixed(2) : 'LKR ' + ((item.price - (item.cost || 0)) * item.quantity).toFixed(2) %>
                      </td>
                      <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
                    </tr>
                  <% }) %>
                <% } %>
              <% }) %>
            </tbody>
          </table>
        </div>
        
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% for (var p = 1; p <= totalPages; p++) { %>
              <a href="/admin/finances?page=<%= p %><%= currentStatus !== 'all' ? '&status=' + currentStatus : '' %><%= currentDateFrom ? '&dateFrom=' + currentDateFrom : '' %><%= currentDateTo ? '&dateTo=' + currentDateTo : '' %>" class="page-link <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
            <% } %>
          </div>
        <% } %>
      <% } else { %>
        <div class="empty">
          <i class="fas fa-receipt"></i>
          <p>No orders found matching your filters.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>