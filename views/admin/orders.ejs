<%- include('../partials/header') %>

<style>
  .admin-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 32px;
    padding: 40px 0;
    min-height: 70vh;
  }
  .admin-sidebar {
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
    padding: 24px 0;
    height: fit-content;
    position: sticky;
    top: 100px;
    box-shadow: var(--shadow-xs);
  }
  .admin-sidebar-header {
    padding: 0 24px 20px;
    border-bottom: var(--border);
    margin-bottom: 12px;
  }
  .admin-sidebar-header h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--gray-900);
    margin-bottom: 4px;
  }
  .admin-sidebar-header span {
    font-size: 0.78rem;
    color: var(--gray-500);
  }
  .admin-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 24px;
    color: var(--gray-600);
    font-weight: 500;
    font-size: 0.9rem;
    transition: var(--transition-fast);
    border-left: 3px solid transparent;
    text-decoration: none;
  }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  .admin-page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .admin-page-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--gray-900);
  }
  .table-wrapper {
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xs);
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
  }
  .admin-table th {
    text-align: left;
    padding: 14px 18px;
    background: var(--gray-50);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gray-500);
    border-bottom: var(--border);
    white-space: nowrap;
  }
  .admin-table td {
    padding: 14px 18px;
    font-size: 0.87rem;
    color: var(--gray-700);
    border-bottom: 1px solid var(--gray-100);
    vertical-align: middle;
  }
  .admin-table tr:last-child td { border-bottom: none; }
  .admin-table tr:hover td { background: var(--gray-50); }
  .order-number-link { font-weight: 600; color: var(--primary); text-decoration: none; }
  .order-number-link:hover { text-decoration: underline; }
  .badge-status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  .badge-processing { background: #FEF3C7; color: #D97706; }
  .badge-shipped { background: #DBEAFE; color: #2563EB; }
  .badge-delivered { background: var(--success-bg); color: var(--success); }
  .badge-cancelled { background: var(--error-bg); color: var(--error); }
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
  }
  .empty-state i { font-size: 4rem; color: var(--gray-200); margin-bottom: 16px; display: block; }
  .empty-state p { color: var(--gray-500); }
  
  /* Bulk Actions Bar */
  .bulk-actions-bar {
    background: var(--primary-light);
    border: 1px solid var(--primary);
    border-radius: var(--radius-lg);
    padding: 14px 20px;
    margin-bottom: 20px;
    display: none;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    animation: slideDown 0.3s ease;
  }
  .bulk-actions-bar.active { display: flex; }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .bulk-count {
    font-weight: 600;
    color: var(--primary);
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .bulk-status-select {
    padding: 9px 14px;
    border: 2px solid var(--primary);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-family: var(--font-primary);
    background: var(--white);
    color: var(--gray-700);
    outline: none;
    cursor: pointer;
  }
  .btn-bulk-update {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 20px;
    background: var(--primary-gradient);
    color: var(--white);
    border: none;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-bulk-update:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,102,255,0.3);
  }
  .btn-bulk-clear {
    padding: 9px 20px;
    background: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-bulk-clear:hover {
    background: var(--white);
  }
  
  /* Checkbox styling */
  .order-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--primary);
    cursor: pointer;
  }
  .select-all-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--primary);
    cursor: pointer;
  }
  
  /* Individual status form */
  .status-update-form {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .status-select-sm {
    padding: 6px 10px;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-full);
    font-size: 0.78rem;
    font-family: var(--font-primary);
    background: var(--white);
    color: var(--gray-700);
    outline: none;
    cursor: pointer;
  }
  .btn-status-update {
    padding: 6px 14px;
    background: var(--primary);
    color: var(--white);
    border: none;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: var(--transition-fast);
    white-space: nowrap;
  }
  .btn-status-update:hover {
    background: var(--primary-dark);
  }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item active"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <div class="admin-page-header">
        <h1 class="admin-page-title">Orders</h1>
      </div>
      
      <% if (orders && orders.length > 0) { %>
        
        <!-- Bulk Actions Bar -->
        <div class="bulk-actions-bar" id="bulkActionsBar">
          <span class="bulk-count" id="bulkCount">0 order(s) selected</span>
          <select class="bulk-status-select" id="bulkStatus">
            <option value="">Change status to...</option>
            <option value="processing">Processing</option>
            <option value="shipped">Shipped</option>
            <option value="delivered">Delivered</option>
            <option value="cancelled">Cancelled</option>
          </select>
          <button type="button" class="btn-bulk-update" onclick="submitBulkUpdate()">
            <i class="fas fa-check"></i> Apply
          </button>
          <button type="button" class="btn-bulk-clear" onclick="clearSelection()">Clear Selection</button>
        </div>
        
        <form id="bulkUpdateForm" action="/admin/orders/bulk-update" method="POST" style="display:none;">
          <input type="hidden" name="status" id="bulkStatusInput">
          <div id="bulkOrderIdsContainer"></div>
        </form>
        
        <div class="table-wrapper" style="overflow-x:auto;">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width:40px;">
                  <input type="checkbox" class="select-all-checkbox" id="selectAll" onclick="toggleSelectAll(this)">
                </th>
                <th>Order #</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Date</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(function(order) { %>
                <tr>
                  <td>
                    <input type="checkbox" class="order-checkbox" value="<%= order._id %>" onchange="updateBulkBar()">
                  </td>
                  <td>
                    <a href="/cart/order-confirmation/<%= order._id %>" class="order-number-link">
                      <%= order.orderNumber %>
                    </a>
                  </td>
                  <td>
                    <div style="font-weight:500;"><%= order.user ? order.user.firstName + ' ' + order.user.lastName : 'N/A' %></div>
                    <div style="font-size:0.75rem;color:var(--gray-400);"><%= order.user ? order.user.email : '' %></div>
                  </td>
                  <td><%= order.items ? order.items.length : 0 %> item(s)</td>
                  <td style="font-weight:600;">$<%= order.total.toFixed(2) %></td>
                  <td style="font-size:0.82rem;white-space:nowrap;">
                    <%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                  </td>
                  <td>
                    <span class="badge-status badge-<%= order.status %>"><%= order.status %></span>
                  </td>
                  <td>
                    <form action="/admin/orders/update-status/<%= order._id %>" method="POST" class="status-update-form">
                      <select name="status" class="status-select-sm">
                        <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Processing</option>
                        <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                        <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                      </select>
                      <button type="submit" class="btn-status-update">Update</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <p>No orders have been placed yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
function toggleSelectAll(selectAllCheckbox) {
  var checkboxes = document.querySelectorAll('.order-checkbox');
  checkboxes.forEach(function(cb) {
    cb.checked = selectAllCheckbox.checked;
  });
  updateBulkBar();
}

function updateBulkBar() {
  var checkedBoxes = document.querySelectorAll('.order-checkbox:checked');
  var bulkBar = document.getElementById('bulkActionsBar');
  var bulkCount = document.getElementById('bulkCount');
  var selectAll = document.getElementById('selectAll');
  var allBoxes = document.querySelectorAll('.order-checkbox');
  
  var count = checkedBoxes.length;
  
  if (count > 0) {
    bulkBar.classList.add('active');
    bulkCount.textContent = count + ' order(s) selected';
    selectAll.checked = (count === allBoxes.length);
  } else {
    bulkBar.classList.remove('active');
    selectAll.checked = false;
  }
}

function submitBulkUpdate() {
  var status = document.getElementById('bulkStatus').value;
  if (!status) {
    alert('Please select a status');
    return;
  }
  
  var checkedBoxes = document.querySelectorAll('.order-checkbox:checked');
  if (checkedBoxes.length === 0) {
    alert('Please select at least one order');
    return;
  }
  
  if (!confirm('Update ' + checkedBoxes.length + ' order(s) to "' + status + '"?')) {
    return;
  }
  
  document.getElementById('bulkStatusInput').value = status;
  var container = document.getElementById('bulkOrderIdsContainer');
  container.innerHTML = '';
  
  checkedBoxes.forEach(function(cb) {
    var input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'orderIds';
    input.value = cb.value;
    container.appendChild(input);
  });
  
  document.getElementById('bulkUpdateForm').submit();
}

function clearSelection() {
  document.querySelectorAll('.order-checkbox').forEach(function(cb) {
    cb.checked = false;
  });
  document.getElementById('selectAll').checked = false;
  updateBulkBar();
}
</script>

<%- include('../partials/footer') %>