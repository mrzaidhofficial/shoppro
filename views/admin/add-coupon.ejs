<%- include('../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-content { min-width: 0; }
  .admin-page-title { font-family: var(--font-display); font-size: 1.8rem; color: var(--gray-900); margin-bottom: 28px; }
  .form-card { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 36px; box-shadow: var(--shadow-xs); max-width: 600px; }
  .form-group { margin-bottom: 22px; }
  .form-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 7px; }
  .form-input, .form-select { width: 100%; padding: 14px 18px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.92rem; font-family: var(--font-primary); color: var(--gray-700); background: var(--gray-50); outline: none; transition: var(--transition-fast); }
  .form-input:focus, .form-select:focus { border-color: var(--primary); background: var(--white); box-shadow: 0 0 0 4px rgba(0,102,255,0.06); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .btn-submit { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: var(--primary-gradient); color: var(--white); border: none; border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: var(--transition); box-shadow: 0 4px 16px rgba(0,102,255,0.3); }
  .btn-cancel { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--white); color: var(--gray-600); border: 2px solid var(--gray-200); border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; cursor: pointer; text-decoration: none; }
  @media (max-width: 900px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; } .admin-sidebar-header { display: none; } .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; } .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); } }
</style>

<div class="container">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header"><h3>Admin Panel</h3><span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span></div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item active"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/" class="admin-nav-item"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    <div class="admin-content">
      <h1 class="admin-page-title">Add Coupon</h1>
      <div class="form-card">
        <form action="/admin/coupons/add" method="POST">
          <div class="form-group"><label class="form-label">Coupon Code *</label><input type="text" name="code" class="form-input" required placeholder="e.g. SAVE10" maxlength="20"></div>
          <div class="form-group"><label class="form-label">Description</label><input type="text" name="description" class="form-input" placeholder="e.g. 10% off your first order"></div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Discount Type *</label><select name="discountType" class="form-select" required><option value="percentage">Percentage (%)</option><option value="fixed">Fixed Amount ($)</option></select></div>
            <div class="form-group"><label class="form-label">Discount Value *</label><input type="number" name="discountValue" class="form-input" required placeholder="10" min="0" step="0.01"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Min Purchase ($)</label><input type="number" name="minPurchase" class="form-input" placeholder="0" min="0" step="0.01" value="0"></div>
            <div class="form-group"><label class="form-label">Max Discount ($)</label><input type="number" name="maxDiscount" class="form-input" placeholder="No limit" min="0" step="0.01"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Usage Limit</label><input type="number" name="usageLimit" class="form-input" placeholder="Unlimited" min="1"></div>
            <div class="form-group"><label class="form-label">Expiry Date</label><input type="date" name="expiryDate" class="form-input"></div>
          </div>
          <div style="display:flex;gap:12px;margin-top:10px;">
            <button type="submit" class="btn-submit"><i class="fas fa-plus"></i> Create Coupon</button>
            <a href="/admin/coupons" class="btn-cancel">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>