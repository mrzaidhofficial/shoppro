<%- include('../../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); margin-bottom: 4px; }
  .admin-sidebar-header span { font-size: 0.78rem; color: var(--gray-500); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  
  .page-header { margin-bottom: 28px; }
  .page-title { font-family: var(--font-display); font-size: 1.7rem; color: var(--gray-900); margin-bottom: 4px; }
  .page-subtitle { font-size: 0.85rem; color: var(--gray-500); }
  
  .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .settings-card { background: var(--white); border: var(--border); border-radius: var(--radius-xl); box-shadow: var(--shadow-xs); overflow: hidden; }
  .settings-card.full-width { grid-column: 1 / -1; }
  
  .card-head { padding: 18px 22px; border-bottom: var(--border); display: flex; align-items: center; gap: 10px; background: var(--gray-50); }
  .card-head-icon { width: 36px; height: 36px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 0.95rem; }
  .card-head-icon.blue { background: var(--primary-light); color: var(--primary); }
  .card-head-icon.amber { background: #FEF3C7; color: #D97706; }
  .card-head-icon.green { background: var(--success-bg); color: var(--success); }
  .card-head-icon.indigo { background: #DBEAFE; color: #2563EB; }
  .card-head-text { flex: 1; }
  .card-head-title { font-weight: 700; color: var(--gray-900); font-size: 0.9rem; }
  .card-head-sub { font-size: 0.7rem; color: var(--gray-500); }
  
  .card-body { padding: 20px 22px; }
  .card-body.compact { padding: 16px 22px; }
  
  .mode-selector { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 14px; }
  .mode-option { border: 2px solid var(--gray-200); border-radius: var(--radius-lg); padding: 14px 10px; cursor: pointer; text-align: center; transition: all 0.2s ease; }
  .mode-option:hover { border-color: var(--primary); }
  .mode-option.active { border-color: var(--primary); background: var(--primary-light); }
  .mode-option input { display: none; }
  .mode-icon { font-size: 1.3rem; margin-bottom: 6px; display: block; }
  .mode-icon.flat { color: #D97706; }
  .mode-icon.free { color: var(--success); }
  .mode-icon.off { color: var(--gray-400); }
  .mode-option.active .mode-icon.off { color: var(--gray-600); }
  .mode-name { font-weight: 600; font-size: 0.8rem; color: var(--gray-900); }
  .mode-desc { font-size: 0.65rem; color: var(--gray-500); margin-top: 2px; line-height: 1.3; }
  
  .toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; }
  .toggle-info { flex: 1; }
  .toggle-info-label { font-weight: 600; color: var(--gray-800); font-size: 0.84rem; }
  .toggle-info-desc { font-size: 0.7rem; color: var(--gray-500); margin-top: 1px; }
  
  .toggle-switch { display: inline-flex; align-items: center; cursor: pointer; flex-shrink: 0; }
  .toggle-switch input { display: none; }
  .toggle-slider { width: 44px; height: 24px; background: var(--gray-300); border-radius: 12px; position: relative; transition: background 0.2s ease; }
  .toggle-slider::before { content: ''; position: absolute; width: 18px; height: 18px; background: white; border-radius: 50%; top: 3px; left: 3px; transition: transform 0.2s ease; box-shadow: 0 1px 2px rgba(0,0,0,0.15); }
  .toggle-switch input:checked + .toggle-slider { background: var(--primary); }
  .toggle-switch input:checked + .toggle-slider::before { transform: translateX(20px); }
  
  .preview-strip { background: linear-gradient(135deg, #F0F9FF 0%, #E0F2FE 100%); border: 1px solid #BAE6FD; border-radius: var(--radius-lg); padding: 12px 16px; text-align: center; }
  .preview-strip-label { font-size: 0.65rem; color: #0369A1; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; margin-bottom: 4px; }
  .preview-strip-value { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: #0C4A6E; }
  .preview-strip-sub { font-size: 0.7rem; color: #0369A1; margin-top: 2px; }
  
  .rate-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .rate-box { background: var(--gray-50); border: var(--border); border-radius: var(--radius-lg); padding: 14px 16px; }
  .rate-box-label { font-size: 0.7rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 4px; }
  .rate-box-desc { font-size: 0.66rem; color: var(--gray-400); margin-bottom: 10px; line-height: 1.3; }
  .rate-box-input { position: relative; }
  .rate-box-input .prefix { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--gray-400); font-size: 0.85rem; pointer-events: none; }
  .rate-box-input input { width: 100%; padding: 10px 14px 10px 30px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.9rem; font-weight: 600; font-family: var(--font-primary); color: var(--gray-800); background: var(--white); outline: none; transition: border-color 0.2s; }
  .rate-box-input input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(0,102,255,0.08); }
  
  .calc-strip { background: linear-gradient(135deg, #EFF6FF, #DBEAFE); border-radius: var(--radius-lg); padding: 14px 18px; display: flex; align-items: center; gap: 14px; margin-top: 12px; }
  .calc-icon { width: 38px; height: 38px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; flex-shrink: 0; }
  .calc-info { flex: 1; }
  .calc-label { font-size: 0.7rem; color: #1E40AF; font-weight: 600; }
  .calc-value { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: #1E3A8A; }
  .calc-breakdown { font-size: 0.68rem; color: #3B82F6; margin-top: 2px; }
  
  .threshold-row { display: flex; align-items: center; gap: 14px; }
  .threshold-input { position: relative; flex: 1; }
  .threshold-input .prefix { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--gray-400); font-size: 0.9rem; pointer-events: none; }
  .threshold-input input { width: 100%; padding: 12px 18px 12px 36px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.95rem; font-weight: 600; font-family: var(--font-primary); color: var(--gray-800); background: var(--white); outline: none; }
  .threshold-input input:focus { border-color: var(--primary); }
  .threshold-note { background: var(--gray-50); border-radius: var(--radius-lg); padding: 12px 16px; font-size: 0.76rem; color: var(--gray-600); display: flex; align-items: center; gap: 8px; margin-top: 12px; }
  .threshold-note i { color: var(--primary); }
  
  .form-group { margin-bottom: 16px; }
  .form-group:last-child { margin-bottom: 0; }
  .form-label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px; }
  .form-label sub { font-weight: 400; color: var(--gray-400); margin-left: 4px; }
  .form-input { width: 100%; padding: 12px 16px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.88rem; font-family: var(--font-primary); color: var(--gray-700); background: var(--gray-50); outline: none; transition: border-color 0.2s; }
  .form-input:focus { border-color: var(--primary); background: var(--white); box-shadow: 0 0 0 3px rgba(0,102,255,0.08); }
  
  .form-actions { display: flex; align-items: center; gap: 14px; margin-top: 24px; padding-top: 20px; border-top: var(--border); }
  .btn-save { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: var(--primary-gradient); color: white; border: none; border-radius: var(--radius-full); font-size: 0.88rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; transition: all 0.2s ease; box-shadow: 0 4px 14px rgba(0,102,255,0.25); }
  .btn-save:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,102,255,0.35); }
  .save-hint { font-size: 0.78rem; color: var(--gray-500); }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
    .settings-grid { grid-template-columns: 1fr; }
    .mode-selector { grid-template-columns: 1fr; }
    .rate-grid { grid-template-columns: 1fr; }
    .threshold-row { flex-direction: column; align-items: stretch; }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/admin/shipping/settings" class="admin-nav-item active"><i class="fas fa-truck"></i> Shipping</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <div class="page-header">
        <h1 class="page-title">Shipping Settings</h1>
        <p class="page-subtitle">Configure how shipping costs are calculated and displayed to customers</p>
      </div>
      
      <form action="/admin/shipping/settings" method="POST">
        <div class="settings-grid">
          
          <!-- Card 1: Shipping Mode -->
          <div class="settings-card">
            <div class="card-head">
              <div class="card-head-icon blue"><i class="fas fa-shipping-fast"></i></div>
              <div class="card-head-text">
                <div class="card-head-title">Shipping Mode</div>
                <div class="card-head-sub">How shipping charges are calculated</div>
              </div>
              <label class="toggle-switch">
                <input type="checkbox" name="shippingEnabled" id="shippingEnabled" <%= settings.shippingEnabled ? 'checked' : '' %> onchange="updatePreview()">
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="card-body compact">
              <div class="mode-selector">
                <label class="mode-option <%= settings.shippingType === 'flat_rate' ? 'active' : '' %>" onclick="selectMode('flat_rate', this)">
                  <input type="radio" name="shippingType" value="flat_rate" <%= settings.shippingType === 'flat_rate' ? 'checked' : '' %>>
                  <span class="mode-icon flat"><i class="fas fa-calculator"></i></span>
                  <span class="mode-name">Flat Rate</span>
                  <span class="mode-desc">Fixed rate per item/order</span>
                </label>
                <label class="mode-option <%= settings.shippingType === 'free' ? 'active' : '' %>" onclick="selectMode('free', this)">
                  <input type="radio" name="shippingType" value="free" <%= settings.shippingType === 'free' ? 'checked' : '' %>>
                  <span class="mode-icon free"><i class="fas fa-gift"></i></span>
                  <span class="mode-name">Always Free</span>
                  <span class="mode-desc">No shipping charges</span>
                </label>
                <label class="mode-option <%= settings.shippingType === 'disabled' ? 'active' : '' %>" onclick="selectMode('disabled', this)">
                  <input type="radio" name="shippingType" value="disabled" <%= settings.shippingType === 'disabled' ? 'checked' : '' %>>
                  <span class="mode-icon off"><i class="fas fa-ban"></i></span>
                  <span class="mode-name">Disable</span>
                  <span class="mode-desc">Remove shipping section</span>
                </label>
              </div>
              
              <div class="preview-strip" id="previewStrip">
                <div class="preview-strip-label">Customer Sees</div>
                <div class="preview-strip-value" id="previewValue">
                  <% if (!settings.shippingEnabled || settings.shippingType === 'disabled') { %>No shipping charges<% } else if (settings.shippingType === 'free') { %>FREE Shipping<% } else { %>$<%= settings.flatRatePerOrder.toFixed(2) %> + $<%= settings.flatRatePerItem.toFixed(2) %>/item<% } %>
                </div>
                <div class="preview-strip-sub" id="previewSub">
                  <% if (settings.shippingEnabled && settings.freeShippingEnabled && settings.shippingType === 'flat_rate' && settings.freeShippingMinAmount > 0) { %>Free over $<%= settings.freeShippingMinAmount.toFixed(2) %><% } else { %>&nbsp;<% } %>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Card 2: Free Shipping Threshold -->
          <div class="settings-card">
            <div class="card-head">
              <div class="card-head-icon green"><i class="fas fa-gift"></i></div>
              <div class="card-head-text">
                <div class="card-head-title">Free Shipping Threshold</div>
                <div class="card-head-sub">Auto-apply free shipping above cart total</div>
              </div>
              <label class="toggle-switch">
                <input type="checkbox" name="freeShippingEnabled" id="freeShippingEnabled" <%= settings.freeShippingEnabled ? 'checked' : '' %> onchange="updatePreview()">
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="card-body compact">
              <div class="threshold-row">
                <div class="threshold-input">
                  <span class="prefix">$</span>
                  <input type="number" name="freeShippingMinAmount" id="freeShippingMinAmount" value="<%= settings.freeShippingMinAmount %>" min="0" step="0.01" onchange="updatePreview()">
                </div>
              </div>
              <div class="threshold-note">
                <i class="fas fa-info-circle"></i>
                <span>Orders with subtotal ≥ <strong>$<span id="thresholdVal"><%= settings.freeShippingMinAmount.toFixed(2) %></span></strong> automatically get free shipping, overriding all other rates.</span>
              </div>
            </div>
          </div>
          
          <!-- Card 3: Rate Configuration - Full Width -->
          <div class="settings-card full-width" id="rateCard">
            <div class="card-head">
              <div class="card-head-icon amber"><i class="fas fa-sliders-h"></i></div>
              <div class="card-head-text">
                <div class="card-head-title">Rate Configuration</div>
                <div class="card-head-sub">Set your flat rate amounts</div>
              </div>
            </div>
            <div class="card-body">
              <div class="rate-grid">
                <div class="rate-box">
                  <div class="rate-box-label"><i class="fas fa-box"></i> Per Order Base</div>
                  <div class="rate-box-desc">Fixed amount added once to every order</div>
                  <div class="rate-box-input">
                    <span class="prefix">$</span>
                    <input type="number" name="flatRatePerOrder" value="<%= settings.flatRatePerOrder %>" min="0" step="0.01" onchange="updatePreview()">
                  </div>
                </div>
                <div class="rate-box">
                  <div class="rate-box-label"><i class="fas fa-cubes"></i> Per Item</div>
                  <div class="rate-box-desc">Charged for each item in the cart</div>
                  <div class="rate-box-input">
                    <span class="prefix">$</span>
                    <input type="number" name="flatRatePerItem" value="<%= settings.flatRatePerItem %>" min="0" step="0.01" onchange="updatePreview()">
                  </div>
                </div>
                <div class="rate-box">
                  <div class="rate-box-label"><i class="fas fa-hand-holding"></i> Handling Fee</div>
                  <div class="rate-box-desc">Additional processing charge</div>
                  <div class="rate-box-input">
                    <span class="prefix">$</span>
                    <input type="number" name="handlingFee" value="<%= settings.handlingFee %>" min="0" step="0.01" onchange="updatePreview()">
                  </div>
                </div>
              </div>
              <div class="calc-strip">
                <div class="calc-icon"><i class="fas fa-equals"></i></div>
                <div class="calc-info">
                  <div class="calc-label">Example: 3 items in cart</div>
                  <div class="calc-value" id="calcTotal">$<%= (settings.flatRatePerOrder + (settings.flatRatePerItem * 3) + settings.handlingFee).toFixed(2) %></div>
                  <div class="calc-breakdown" id="calcBreakdown">Base $<%= settings.flatRatePerOrder.toFixed(2) %> + (3 × $<%= settings.flatRatePerItem.toFixed(2) %>) + $<%= settings.handlingFee.toFixed(2) %> handling</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Card 4: Display Settings -->
          <div class="settings-card full-width">
            <div class="card-head">
              <div class="card-head-icon indigo"><i class="fas fa-eye"></i></div>
              <div class="card-head-text">
                <div class="card-head-title">Display Settings</div>
                <div class="card-head-sub">What customers see during checkout</div>
              </div>
            </div>
            <div class="card-body">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                  <label class="form-label">Estimated Delivery Time <sub>shown on cart & checkout</sub></label>
                  <input type="text" name="estimatedDelivery" class="form-input" value="<%= settings.estimatedDelivery %>" placeholder="e.g. 7-21 business days">
                </div>
                <div class="form-group">
                  <label class="form-label">Supplier Reference Note <sub>internal only, not visible to customers</sub></label>
                  <input type="text" name="supplierInfo" class="form-input" value="<%= settings.supplierInfo || '' %>" placeholder="e.g. Dropshipping via AliExpress Supplier #42">
                </div>
              </div>
            </div>
          </div>
          
        </div>
        
        <div class="form-actions">
          <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save Settings</button>
          <span class="save-hint">Changes apply immediately across the storefront.</span>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function selectMode(type, el) {
  document.querySelectorAll('.mode-option').forEach(function(o) { o.classList.remove('active'); });
  el.classList.add('active');
  el.querySelector('input').checked = true;
  var rateCard = document.getElementById('rateCard');
  if (type === 'free' || type === 'disabled') {
    rateCard.style.opacity = '0.4';
    rateCard.style.pointerEvents = 'none';
  } else {
    rateCard.style.opacity = '1';
    rateCard.style.pointerEvents = 'auto';
  }
  updatePreview();
}

function updatePreview() {
  var enabled = document.getElementById('shippingEnabled').checked;
  var type = document.querySelector('input[name="shippingType"]:checked').value;
  var perOrder = parseFloat(document.querySelector('input[name="flatRatePerOrder"]').value) || 0;
  var perItem = parseFloat(document.querySelector('input[name="flatRatePerItem"]').value) || 0;
  var handling = parseFloat(document.querySelector('input[name="handlingFee"]').value) || 0;
  var freeMin = parseFloat(document.getElementById('freeShippingMinAmount').value) || 0;
  var freeEnabled = document.getElementById('freeShippingEnabled').checked;
  
  var pv = document.getElementById('previewValue');
  var ps = document.getElementById('previewSub');
  
  if (!enabled || type === 'disabled') {
    pv.textContent = 'No shipping charges';
    ps.innerHTML = '&nbsp;';
  } else if (type === 'free') {
    pv.textContent = 'FREE Shipping';
    ps.innerHTML = '&nbsp;';
  } else {
    var parts = [];
    if (perOrder > 0) parts.push('$' + perOrder.toFixed(2) + ' base');
    if (perItem > 0) parts.push('$' + perItem.toFixed(2) + '/item');
    if (handling > 0) parts.push('$' + handling.toFixed(2) + ' handling');
    pv.textContent = parts.join(' + ') || '$0.00';
    if (freeEnabled && freeMin > 0) {
      ps.textContent = 'Free over $' + freeMin.toFixed(2);
    } else {
      ps.innerHTML = '&nbsp;';
    }
  }
  
  var total = perOrder + (perItem * 3) + handling;
  document.getElementById('calcTotal').textContent = '$' + total.toFixed(2);
  document.getElementById('calcBreakdown').textContent = 'Base $' + perOrder.toFixed(2) + ' + (3 × $' + perItem.toFixed(2) + ') + $' + handling.toFixed(2) + ' handling';
  document.getElementById('thresholdVal').textContent = freeMin.toFixed(2);
}

selectMode('<%= settings.shippingType %>', document.querySelector('.mode-option.active'));
</script>

<%- include('../../partials/footer') %>