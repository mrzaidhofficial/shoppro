<%- include('../../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); margin-bottom: 4px; }
  .admin-sidebar-header span { font-size: 0.78rem; color: var(--gray-500); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  
  .page-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
  .page-title { font-family: var(--font-display); font-size: 1.7rem; color: var(--gray-900); }
  .page-subtitle { font-size: 0.85rem; color: var(--gray-500); margin-top: 2px; }
  .page-actions { display: flex; gap: 8px; }
  .btn-action { display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px; border: 2px solid var(--gray-200); border-radius: var(--radius-full); font-size: 0.8rem; font-weight: 600; font-family: var(--font-primary); color: var(--gray-600); background: var(--white); cursor: pointer; text-decoration: none; transition: all 0.2s ease; }
  .btn-action:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
  .btn-action i { font-size: 0.85rem; }
  
  .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .settings-card { background: var(--white); border: var(--border); border-radius: var(--radius-xl); box-shadow: var(--shadow-xs); overflow: hidden; }
  .settings-card.span-2 { grid-column: 1 / -1; }
  
  .card-header { padding: 16px 20px; border-bottom: var(--border); display: flex; align-items: center; gap: 10px; }
  .card-header-icon { width: 34px; height: 34px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; flex-shrink: 0; }
  .card-header-icon.blue { background: var(--primary-light); color: var(--primary); }
  .card-header-icon.amber { background: #FEF3C7; color: #D97706; }
  .card-header-icon.green { background: var(--success-bg); color: var(--success); }
  .card-header-icon.indigo { background: #DBEAFE; color: #2563EB; }
  .card-header-text { flex: 1; min-width: 0; }
  .card-header-title { font-weight: 700; color: var(--gray-900); font-size: 0.88rem; }
  .card-header-sub { font-size: 0.7rem; color: var(--gray-500); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  
  .card-body { padding: 16px 20px; }
  
  /* Toggle Switch */
  .toggle { display: inline-flex; align-items: center; cursor: pointer; flex-shrink: 0; }
  .toggle input { display: none; }
  .toggle-track { width: 40px; height: 22px; background: var(--gray-300); border-radius: 11px; position: relative; transition: background 0.2s; }
  .toggle-track::after { content: ''; position: absolute; width: 16px; height: 16px; background: white; border-radius: 50%; top: 3px; left: 3px; transition: transform 0.2s; box-shadow: 0 1px 2px rgba(0,0,0,0.15); }
  .toggle input:checked + .toggle-track { background: var(--primary); }
  .toggle input:checked + .toggle-track::after { transform: translateX(18px); }
  
  /* Mode Selector */
  .mode-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; }
  .mode-card { border: 2px solid var(--gray-200); border-radius: var(--radius-lg); padding: 12px; cursor: pointer; transition: all 0.15s; display: flex; align-items: center; gap: 10px; }
  .mode-card:hover { border-color: var(--primary); }
  .mode-card.active { border-color: var(--primary); background: var(--primary-light); }
  .mode-card input { display: none; }
  .mode-card-icon { font-size: 1.1rem; width: 24px; text-align: center; flex-shrink: 0; }
  .mode-card-icon.flat { color: #D97706; }
  .mode-card-icon.free { color: var(--success); }
  .mode-card-icon.off { color: var(--gray-400); }
  .mode-card.active .mode-card-icon.off { color: var(--gray-600); }
  .mode-card-info { min-width: 0; }
  .mode-card-name { font-weight: 600; font-size: 0.8rem; color: var(--gray-900); line-height: 1.2; }
  .mode-card-desc { font-size: 0.66rem; color: var(--gray-500); line-height: 1.3; }
  
  /* Preview Badge */
  .preview-badge { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: var(--radius-lg); background: #F0F9FF; border: 1px solid #BAE6FD; }
  .preview-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #0284C7; flex-shrink: 0; }
  .preview-badge-text { font-size: 0.78rem; font-weight: 600; color: #0369A1; }
  .preview-badge-sub { font-size: 0.7rem; color: #0284C7; margin-left: auto; }
  
  /* Rate Boxes */
  .rate-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .rate-item { }
  .rate-label { font-size: 0.7rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 3px; display: flex; align-items: center; gap: 5px; }
  .rate-label i { font-size: 0.7rem; }
  .rate-desc { font-size: 0.64rem; color: var(--gray-400); margin-bottom: 8px; line-height: 1.3; }
  .rate-input { position: relative; }
  .rate-input .dollar { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--gray-400); font-size: 0.82rem; pointer-events: none; }
  .rate-input input { width: 100%; padding: 10px 14px 10px 30px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.88rem; font-weight: 600; font-family: var(--font-primary); color: var(--gray-800); background: var(--white); outline: none; transition: border-color 0.15s; }
  .rate-input input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(0,102,255,0.06); }
  
  /* Threshold */
  .threshold-wrap { display: flex; align-items: center; gap: 12px; }
  .threshold-input { position: relative; flex: 1; }
  .threshold-input .dollar { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--gray-400); font-size: 0.9rem; pointer-events: none; }
  .threshold-input input { width: 100%; padding: 11px 16px 11px 34px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.9rem; font-weight: 600; font-family: var(--font-primary); color: var(--gray-800); background: var(--white); outline: none; }
  .threshold-input input:focus { border-color: var(--primary); }
  .threshold-info { font-size: 0.72rem; color: var(--gray-500); margin-top: 10px; display: flex; align-items: center; gap: 6px; }
  .threshold-info i { color: var(--primary); font-size: 0.8rem; }
  
  /* Form elements */
  .form-group { margin-bottom: 14px; }
  .form-group:last-child { margin-bottom: 0; }
  .form-label { display: block; font-size: 0.76rem; font-weight: 600; color: var(--gray-700); margin-bottom: 5px; }
  .form-label .muted { font-weight: 400; color: var(--gray-400); }
  .form-input { width: 100%; padding: 11px 14px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.86rem; font-family: var(--font-primary); color: var(--gray-700); background: var(--gray-50); outline: none; transition: border-color 0.15s; }
  .form-input:focus { border-color: var(--primary); background: var(--white); box-shadow: 0 0 0 3px rgba(0,102,255,0.06); }
  
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  
  .form-footer { display: flex; align-items: center; gap: 14px; margin-top: 24px; padding-top: 18px; border-top: var(--border); }
  .btn-save { display: inline-flex; align-items: center; gap: 7px; padding: 11px 26px; background: var(--primary-gradient); color: white; border: none; border-radius: var(--radius-full); font-size: 0.86rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 12px rgba(0,102,255,0.2); }
  .btn-save:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0,102,255,0.3); }
  .save-note { font-size: 0.76rem; color: var(--gray-500); }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
    .settings-grid { grid-template-columns: 1fr; }
    .settings-card.span-2 { grid-column: 1; }
    .mode-row { grid-template-columns: 1fr; }
    .rate-row { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/admin/shipping/settings" class="admin-nav-item active"><i class="fas fa-truck"></i> Shipping</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <div class="page-top">
        <div>
          <h1 class="page-title">Shipping Settings</h1>
          <p class="page-subtitle">Configure shipping costs displayed to customers</p>
        </div>
        <div class="page-actions">
          <a href="/admin/shipping/orders" class="btn-action"><i class="fas fa-list-check"></i> Order Shipping</a>
          <a href="/admin/shipping/bulk" class="btn-action"><i class="fas fa-layer-group"></i> Bulk Update</a>
        </div>
      </div>
      
      <form action="/admin/shipping/settings" method="POST">
        <div class="settings-grid">
          
          <!-- Card: Shipping Mode -->
          <div class="settings-card">
            <div class="card-header">
              <div class="card-header-icon blue"><i class="fas fa-shipping-fast"></i></div>
              <div class="card-header-text">
                <div class="card-header-title">Shipping Mode</div>
                <div class="card-header-sub">How shipping is calculated</div>
              </div>
              <label class="toggle">
                <input type="checkbox" name="shippingEnabled" id="shippingEnabled" <%= settings.shippingEnabled ? 'checked' : '' %> onchange="refreshPreview()">
                <span class="toggle-track"></span>
              </label>
            </div>
            <div class="card-body">
              <div class="mode-row">
                <label class="mode-card <%= settings.shippingType === 'flat_rate' ? 'active' : '' %>" onclick="pickMode('flat_rate', this)">
                  <input type="radio" name="shippingType" value="flat_rate" <%= settings.shippingType === 'flat_rate' ? 'checked' : '' %>>
                  <span class="mode-card-icon flat"><i class="fas fa-calculator"></i></span>
                  <div class="mode-card-info">
                    <div class="mode-card-name">Flat Rate</div>
                    <div class="mode-card-desc">Fixed per item/order</div>
                  </div>
                </label>
                <label class="mode-card <%= settings.shippingType === 'free' ? 'active' : '' %>" onclick="pickMode('free', this)">
                  <input type="radio" name="shippingType" value="free" <%= settings.shippingType === 'free' ? 'checked' : '' %>>
                  <span class="mode-card-icon free"><i class="fas fa-gift"></i></span>
                  <div class="mode-card-info">
                    <div class="mode-card-name">Always Free</div>
                    <div class="mode-card-desc">No charges ever</div>
                  </div>
                </label>
                <label class="mode-card <%= settings.shippingType === 'disabled' ? 'active' : '' %>" onclick="pickMode('disabled', this)">
                  <input type="radio" name="shippingType" value="disabled" <%= settings.shippingType === 'disabled' ? 'checked' : '' %>>
                  <span class="mode-card-icon off"><i class="fas fa-ban"></i></span>
                  <div class="mode-card-info">
                    <div class="mode-card-name">Disable</div>
                    <div class="mode-card-desc">Remove entirely</div>
                  </div>
                </label>
              </div>
              
              <div class="preview-badge" id="previewBadge">
                <span class="preview-badge-dot"></span>
                <span class="preview-badge-text" id="previewText">
                  <% if (!settings.shippingEnabled || settings.shippingType === 'disabled') { %>Shipping: Not charged<% } else if (settings.shippingType === 'free') { %>Shipping: FREE<% } else { %>Shipping: $<%= settings.flatRatePerOrder.toFixed(2) %> + $<%= settings.flatRatePerItem.toFixed(2) %>/item<% } %>
                </span>
                <span class="preview-badge-sub" id="previewSubText">
                  <% if (settings.shippingEnabled && settings.freeShippingEnabled && settings.shippingType === 'flat_rate' && settings.freeShippingMinAmount > 0) { %>Free over $<%= settings.freeShippingMinAmount.toFixed(2) %><% } %>
                </span>
              </div>
            </div>
          </div>
          
          <!-- Card: Free Shipping Threshold -->
          <div class="settings-card">
            <div class="card-header">
              <div class="card-header-icon green"><i class="fas fa-gift"></i></div>
              <div class="card-header-text">
                <div class="card-header-title">Free Shipping Threshold</div>
                <div class="card-header-sub">Auto-apply above cart total</div>
              </div>
              <label class="toggle">
                <input type="checkbox" name="freeShippingEnabled" id="freeShippingEnabled" <%= settings.freeShippingEnabled ? 'checked' : '' %> onchange="refreshPreview()">
                <span class="toggle-track"></span>
              </label>
            </div>
            <div class="card-body">
              <div class="threshold-wrap">
                <div class="threshold-input">
                  <span class="dollar">$</span>
                  <input type="number" name="freeShippingMinAmount" id="freeShippingMinAmount" value="<%= settings.freeShippingMinAmount %>" min="0" step="0.01" onchange="refreshPreview()">
                </div>
              </div>
              <div class="threshold-info">
                <i class="fas fa-info-circle"></i>
                <span>Free shipping when cart reaches <strong>$<span id="thresholdVal"><%= settings.freeShippingMinAmount.toFixed(2) %></span></strong></span>
              </div>
            </div>
          </div>
          
          <!-- Card: Rate Configuration (Full Width) -->
          <div class="settings-card span-2" id="rateCard">
            <div class="card-header">
              <div class="card-header-icon amber"><i class="fas fa-sliders-h"></i></div>
              <div class="card-header-text">
                <div class="card-header-title">Rate Configuration</div>
                <div class="card-header-sub">Set your shipping rates</div>
              </div>
            </div>
            <div class="card-body">
              <div class="rate-row">
                <div class="rate-item">
                  <div class="rate-label"><i class="fas fa-box"></i> Per Order Base</div>
                  <div class="rate-desc">Added once per order</div>
                  <div class="rate-input">
                    <span class="dollar">$</span>
                    <input type="number" name="flatRatePerOrder" value="<%= settings.flatRatePerOrder %>" min="0" step="0.01" onchange="refreshPreview()">
                  </div>
                </div>
                <div class="rate-item">
                  <div class="rate-label"><i class="fas fa-cubes"></i> Per Item Rate</div>
                  <div class="rate-desc">× quantity in cart</div>
                  <div class="rate-input">
                    <span class="dollar">$</span>
                    <input type="number" name="flatRatePerItem" value="<%= settings.flatRatePerItem %>" min="0" step="0.01" onchange="refreshPreview()">
                  </div>
                </div>
                <div class="rate-item">
                  <div class="rate-label"><i class="fas fa-hand-holding"></i> Handling Fee</div>
                  <div class="rate-desc">Processing charge</div>
                  <div class="rate-input">
                    <span class="dollar">$</span>
                    <input type="number" name="handlingFee" value="<%= settings.handlingFee %>" min="0" step="0.01" onchange="refreshPreview()">
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Card: Display Settings -->
          <div class="settings-card span-2">
            <div class="card-header">
              <div class="card-header-icon indigo"><i class="fas fa-eye"></i></div>
              <div class="card-header-text">
                <div class="card-header-title">Display Settings</div>
                <div class="card-header-sub">Customer-facing information</div>
              </div>
            </div>
            <div class="card-body">
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Estimated Delivery Time <span class="muted">— shown on cart & checkout</span></label>
                  <input type="text" name="estimatedDelivery" class="form-input" value="<%= settings.estimatedDelivery %>" placeholder="e.g. 7-21 business days">
                </div>
                <div class="form-group">
                  <label class="form-label">Supplier Reference <span class="muted">— internal only</span></label>
                  <input type="text" name="supplierInfo" class="form-input" value="<%= settings.supplierInfo || '' %>" placeholder="e.g. AliExpress Supplier #42">
                </div>
              </div>
            </div>
          </div>
          
        </div>
        
        <div class="form-footer">
          <button type="submit" class="btn-save"><i class="fas fa-check"></i> Save Settings</button>
          <span class="save-note">Changes apply immediately across the storefront</span>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function pickMode(type, el) {
  document.querySelectorAll('.mode-card').forEach(function(c) { c.classList.remove('active'); });
  el.classList.add('active');
  el.querySelector('input').checked = true;
  var rateCard = document.getElementById('rateCard');
  rateCard.style.opacity = (type === 'free' || type === 'disabled') ? '0.4' : '1';
  rateCard.style.pointerEvents = (type === 'free' || type === 'disabled') ? 'none' : 'auto';
  refreshPreview();
}

function refreshPreview() {
  var enabled = document.getElementById('shippingEnabled').checked;
  var type = document.querySelector('input[name="shippingType"]:checked').value;
  var perOrder = parseFloat(document.querySelector('input[name="flatRatePerOrder"]').value) || 0;
  var perItem = parseFloat(document.querySelector('input[name="flatRatePerItem"]').value) || 0;
  var handling = parseFloat(document.querySelector('input[name="handlingFee"]').value) || 0;
  var freeMin = parseFloat(document.getElementById('freeShippingMinAmount').value) || 0;
  var freeEnabled = document.getElementById('freeShippingEnabled').checked;
  
  var txt = document.getElementById('previewText');
  var sub = document.getElementById('previewSubText');
  
  if (!enabled || type === 'disabled') {
    txt.textContent = 'Shipping: Not charged';
    sub.textContent = '';
  } else if (type === 'free') {
    txt.textContent = 'Shipping: FREE';
    sub.textContent = '';
  } else {
    var p = [];
    if (perOrder > 0) p.push('$' + perOrder.toFixed(2) + ' base');
    if (perItem > 0) p.push('$' + perItem.toFixed(2) + '/item');
    if (handling > 0) p.push('$' + handling.toFixed(2) + ' handling');
    txt.textContent = 'Shipping: ' + (p.join(' + ') || '$0.00');
    sub.textContent = (freeEnabled && freeMin > 0) ? 'Free over $' + freeMin.toFixed(2) : '';
  }
  
  document.getElementById('thresholdVal').textContent = freeMin.toFixed(2);
}

pickMode('<%= settings.shippingType %>', document.querySelector('.mode-card.active'));
</script>

<%- include('../../partials/footer') %>