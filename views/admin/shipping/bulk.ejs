<%- include('../../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); margin-bottom: 4px; }
  .admin-sidebar-header span { font-size: 0.78rem; color: var(--gray-500); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  .admin-page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
  .admin-page-title { font-family: var(--font-display); font-size: 1.8rem; color: var(--gray-900); }
  
  .info-box { background: var(--primary-light); border: 1px solid var(--primary); border-radius: var(--radius-lg); padding: 16px 20px; margin-bottom: 24px; }
  .info-box p { color: var(--primary); font-size: 0.88rem; margin: 0; }
  .info-box i { margin-right: 8px; }
  
  .bulk-form-card { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 28px; box-shadow: var(--shadow-xs); margin-bottom: 24px; }
  .bulk-form-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 20px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .form-group { margin-bottom: 16px; }
  .form-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px; }
  .form-input, .form-select, .form-textarea { width: 100%; padding: 12px 16px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.9rem; font-family: var(--font-primary); color: var(--gray-700); background: var(--gray-50); outline: none; transition: var(--transition-fast); }
  .form-textarea { resize: vertical; min-height: 80px; }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--primary); background: var(--white); box-shadow: 0 0 0 4px rgba(0,102,255,0.06); }
  .form-hint { font-size: 0.72rem; color: var(--gray-400); margin-top: 4px; }
  
  .btn-submit { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: var(--primary-gradient); color: var(--white); border: none; border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; transition: var(--transition); box-shadow: 0 4px 16px rgba(0,102,255,0.3); }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,102,255,0.4); }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--white); color: var(--gray-600); border: 2px solid var(--gray-200); border-radius: var(--radius-full); font-size: 0.85rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; text-decoration: none; transition: var(--transition); }
  .btn-secondary:hover { background: var(--gray-50); border-color: var(--gray-300); }
  
  .table-wrapper { background: var(--white); border: var(--border); border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-xs); margin-top: 24px; }
  .admin-table { width: 100%; border-collapse: collapse; }
  .admin-table th { text-align: left; padding: 12px 14px; background: var(--gray-50); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--gray-500); border-bottom: var(--border); }
  .admin-table td { padding: 10px 14px; font-size: 0.83rem; color: var(--gray-700); border-bottom: 1px solid var(--gray-100); }
  .admin-table tr:last-child td { border-bottom: none; }
  .admin-table tr:hover td { background: var(--gray-50); }
  
  .order-checkbox { width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer; }
  
  .badge { display: inline-block; padding: 3px 10px; border-radius: var(--radius-full); font-size: 0.68rem; font-weight: 600; }
  .badge-processing { background: #FEF3C7; color: #D97706; }
  .badge-shipped { background: #DBEAFE; color: #2563EB; }
  .badge-delivered { background: var(--success-bg); color: var(--success); }
  .badge-pending { background: var(--gray-100); color: var(--gray-600); }
  
  .form-actions { display: flex; gap: 12px; margin-top: 20px; }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/admin/shipping/settings" class="admin-nav-item"><i class="fas fa-truck"></i> Shipping</a>
      <a href="/admin/shipping/orders" class="admin-nav-item"><i class="fas fa-boxes"></i> Order Shipping</a>
      <a href="/admin/shipping/bulk" class="admin-nav-item active"><i class="fas fa-layer-group"></i> Bulk Update</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <div class="admin-page-header">
        <h1 class="admin-page-title">Bulk Shipping Update</h1>
      </div>
      
      <div class="info-box">
        <p><i class="fas fa-info-circle"></i> <strong>How it works:</strong> Select orders below, fill in the fields you want to update, and click "Apply to Selected Orders". Only filled fields will be updated.</p>
      </div>
      
      <div class="bulk-form-card">
        <h3 class="bulk-form-title">Bulk Update Values</h3>
        <form action="/admin/shipping/bulk" method="POST" id="bulkForm">
          
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Shipping Type</label>
              <select name="shippingType" class="form-select">
                <option value="">Don't Change</option>
                <option value="flat_rate">Flat Rate</option>
                <option value="free">Free Shipping</option>
                <option value="disabled">No Shipping</option>
                <option value="custom">Custom Amount</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Custom Shipping Cost (LKR)</label>
              <input type="number" name="customShippingCost" class="form-input" min="0" step="0.01" placeholder="Leave empty for no change">
            </div>
            <div class="form-group">
              <label class="form-label">Shipping Status</label>
              <select name="shippingStatus" class="form-select">
                <option value="">Don't Change</option>
                <option value="pending">Pending</option>
                <option value="processing">Processing</option>
                <option value="shipped">Shipped</option>
                <option value="delivered">Delivered</option>
                <option value="cancelled">Cancelled</option>
              </select>
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Supplier Name</label>
              <input type="text" name="supplierName" class="form-input" placeholder="Leave empty for no change">
            </div>
            <div class="form-group">
              <label class="form-label">Carrier Name</label>
              <input type="text" name="carrierName" class="form-input" placeholder="Leave empty for no change">
            </div>
            <div class="form-group">
              <label class="form-label">Tracking Number</label>
              <input type="text" name="trackingNumber" class="form-input" placeholder="Leave empty for no change">
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Tracking URL</label>
              <input type="text" name="trackingUrl" class="form-input" placeholder="Leave empty for no change">
            </div>
            <div class="form-group" style="grid-column: span 2;">
              <label class="form-label">Shipping Notes</label>
              <textarea name="shippingNotes" class="form-textarea" placeholder="Leave empty for no change"></textarea>
            </div>
          </div>
          
          <div class="form-actions">
            <button type="button" class="btn-submit" onclick="submitBulkForm()"><i class="fas fa-check-circle"></i> Apply to Selected Orders</button>
            <button type="button" class="btn-secondary" onclick="selectAllOrders()"><i class="fas fa-check-square"></i> Select All</button>
            <button type="button" class="btn-secondary" onclick="deselectAllOrders()"><i class="fas fa-square"></i> Deselect All</button>
          </div>
          
          <div id="selectedOrderIds"></div>
        </form>
      </div>
      
      <% if (orders && orders.length > 0) { %>
        <div class="table-wrapper" style="overflow-x:auto;">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width:40px;">Select</th>
                <th>Order #</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Shipping</th>
                <th>Status</th>
                <th>Ship Status</th>
                <th>Supplier</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(function(order) { 
                var shipInfo = shippingMap[order._id.toString()] || {};
              %>
                <tr>
                  <td>
                    <input type="checkbox" class="order-checkbox" name="orderIds" value="<%= order._id %>" form="bulkForm">
                  </td>
                  <td style="font-weight:600;color:var(--primary);white-space:nowrap;"><%= order.orderNumber %></td>
                  <td style="font-size:0.85rem;"><%= order.user ? order.user.firstName + ' ' + order.user.lastName : 'N/A' %></td>
                  <td style="font-weight:600;">LKR <%= order.total.toFixed(2) %></td>
                  <td><%= order.shippingCost === 0 ? 'FREE' : 'LKR ' + order.shippingCost.toFixed(2) %></td>
                  <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
                  <td><span class="badge badge-<%= shipInfo.shippingStatus || 'pending' %>"><%= shipInfo.shippingStatus || 'pending' %></span></td>
                  <td style="font-size:0.8rem;"><%= shipInfo.supplierName || '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:60px;background:var(--white);border:var(--border);border-radius:var(--radius-xl);">
          <i class="fas fa-box-open" style="font-size:3rem;color:var(--gray-300);margin-bottom:12px;display:block;"></i>
          <p style="color:var(--gray-500);">No active orders found.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
function selectAllOrders() {
  document.querySelectorAll('.order-checkbox').forEach(function(cb) { cb.checked = true; });
}
function deselectAllOrders() {
  document.querySelectorAll('.order-checkbox').forEach(function(cb) { cb.checked = false; });
}
function submitBulkForm() {
  var checked = document.querySelectorAll('.order-checkbox:checked');
  if (checked.length === 0) {
    alert('Please select at least one order.');
    return;
  }
  if (!confirm('Apply shipping updates to ' + checked.length + ' selected order(s)?')) {
    return;
  }
  document.getElementById('bulkForm').submit();
}
</script>

<%- include('../../partials/footer') %>