<%- include('../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 24px 0; height: fit-content; position: sticky; top: 100px; box-shadow: var(--shadow-xs); }
  .admin-sidebar-header { padding: 0 24px 20px; border-bottom: var(--border); margin-bottom: 12px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--gray-900); margin-bottom: 4px; }
  .admin-sidebar-header span { font-size: 0.78rem; color: var(--gray-500); }
  .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 24px; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: var(--transition-fast); border-left: 3px solid transparent; text-decoration: none; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  .admin-page-title { font-family: var(--font-display); font-size: 1.8rem; color: var(--gray-900); margin-bottom: 28px; }
  .form-card { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 36px; box-shadow: var(--shadow-xs); max-width: 700px; }
  .form-group { margin-bottom: 22px; }
  .form-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 7px; }
  .form-input, .form-select, .form-textarea { width: 100%; padding: 14px 18px; border: 2px solid var(--gray-200); border-radius: var(--radius); font-size: 0.92rem; font-family: var(--font-primary); color: var(--gray-700); background: var(--gray-50); outline: none; transition: var(--transition-fast); }
  .form-textarea { resize: vertical; min-height: 120px; }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--primary); background: var(--white); box-shadow: 0 0 0 4px rgba(0,102,255,0.06); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .form-hint { font-size: 0.75rem; color: var(--gray-400); margin-top: 5px; }
  .checkbox-group { display: flex; align-items: center; gap: 10px; margin-bottom: 22px; }
  .checkbox-group input[type="checkbox"] { width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer; }
  .checkbox-group label { font-size: 0.9rem; color: var(--gray-700); cursor: pointer; font-weight: 500; }
  .btn-submit { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: var(--primary-gradient); color: var(--white); border: none; border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; transition: var(--transition); box-shadow: 0 4px 16px rgba(0,102,255,0.3); }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,102,255,0.4); }
  .btn-cancel { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--white); color: var(--gray-600); border: 2px solid var(--gray-200); border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; text-decoration: none; transition: var(--transition); }
  .btn-cancel:hover { background: var(--gray-50); border-color: var(--gray-300); }
  .form-actions { display: flex; gap: 12px; margin-top: 10px; }
  
  /* Image Upload Styles */
  .image-upload-section { margin-bottom: 22px; }
  .image-upload-zone {
    border: 2px dashed var(--gray-300);
    border-radius: var(--radius-lg);
    padding: 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s ease;
    background: var(--gray-50);
    position: relative;
    margin-top: 14px;
  }
  .image-upload-zone:hover {
    border-color: var(--primary);
    background: var(--primary-light);
  }
  .image-upload-zone.dragover {
    border-color: var(--primary);
    background: var(--primary-light);
    box-shadow: 0 0 0 4px rgba(0,102,255,0.08);
  }
  .image-upload-zone i {
    font-size: 2.5rem;
    color: var(--gray-400);
    margin-bottom: 10px;
    display: block;
    transition: color 0.25s ease;
  }
  .image-upload-zone:hover i { color: var(--primary); }
  .image-upload-zone p {
    font-size: 0.88rem;
    color: var(--gray-500);
    margin: 0;
    font-weight: 500;
  }
  .image-upload-zone span {
    font-size: 0.75rem;
    color: var(--gray-400);
    display: block;
    margin-top: 4px;
  }
  .image-upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  
  .image-previews {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 14px;
  }
  .image-preview-item {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    border: 2px solid var(--gray-200);
    background: var(--gray-100);
  }
  .image-preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .image-preview-item .remove-image {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--error);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  .image-preview-item .remove-image:hover {
    background: #DC2626;
    transform: scale(1.1);
  }
  .image-preview-item.existing .remove-image {
    background: #F59E0B;
  }
  .image-count {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 8px;
    font-weight: 500;
  }
  .existing-images-label {
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  @media (max-width: 900px) { 
    .admin-layout { grid-template-columns: 1fr; } 
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; } 
    .admin-sidebar-header { display: none; } 
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; } 
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); } 
    .form-row { grid-template-columns: 1fr; } 
    .form-card { padding: 24px; } 
    .image-preview-item { width: 90px; height: 90px; }
  }
</style>

<div class="container">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header"><h3>Admin Panel</h3><span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span></div>
      <a href="/admin/dashboard" class="admin-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item active"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/admin/shipping/settings" class="admin-nav-item"><i class="fas fa-truck"></i> Shipping</a>
      <a href="/admin/finances" class="admin-nav-item"><i class="fas fa-chart-pie"></i> Finances</a>
      <a href="/admin/bank-details" class="admin-nav-item"><i class="fas fa-university"></i> Bank Details</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    <div class="admin-content">
      <h1 class="admin-page-title">Edit Product</h1>
      <div class="form-card">
        <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" id="editProductForm">
          
          <!-- Existing Images -->
          <div class="image-upload-section">
            <label class="form-label">Product Images</label>
            <span class="form-hint" style="margin-bottom:10px;display:block;">Manage product images. Click X to remove existing images. Upload up to 10 images total. Supported: JPG, PNG, WebP (Max 10MB each).</span>
            
            <% if (product.images && product.images.length > 0) { %>
              <div class="existing-images-label"><i class="fas fa-images"></i> Current Images</div>
              <div class="image-previews" id="existingImages">
                <% product.images.forEach(function(img, index) { %>
                  <div class="image-preview-item existing" id="existingImg<%= index %>">
                    <img src="<%= img %>" alt="Product image" onerror="this.style.display='none'">
                    <button type="button" class="remove-image" onclick="removeExistingImage(<%= index %>)" title="Remove image"><i class="fas fa-times"></i></button>
                    <input type="hidden" name="existingImages" value="<%= img %>" id="existingInput<%= index %>">
                  </div>
                <% }) %>
              </div>
            <% } %>
            
            <div class="image-upload-zone" id="uploadZone">
              <i class="fas fa-cloud-upload-alt"></i>
              <p>Click to upload new images or drag & drop here</p>
              <span>JPG, PNG, or WebP — Up to 10 images total</span>
              <input type="file" name="productImages" id="productImages" accept="image/jpeg,image/png,image/webp" multiple onchange="handleFileSelect(event)">
            </div>
            <div class="image-previews" id="newImagePreviews"></div>
            <div class="image-count" id="imageCount"><%= product.images ? product.images.length : 0 %> image(s)</div>
          </div>
          
          <div class="form-group"><label class="form-label" for="name">Product Name *</label><input type="text" class="form-input" id="name" name="name" required value="<%= product.name %>" maxlength="200"></div>
          <div class="form-group"><label class="form-label" for="shortDescription">Short Description</label><input type="text" class="form-input" id="shortDescription" name="shortDescription" value="<%= product.shortDescription || '' %>" placeholder="Brief summary shown in quick view (max 200 characters)" maxlength="200"><span class="form-hint">This appears in quick view popups and search results. Keep it brief.</span></div>
          <div class="form-group"><label class="form-label" for="description">Full Description *</label><textarea class="form-textarea" id="description" name="description" required><%= product.description %></textarea></div>
          <div class="form-row">
            <div class="form-group"><label class="form-label" for="price">Price (LKR) *</label><input type="number" class="form-input" id="price" name="price" required value="<%= product.price %>" min="0" step="0.01"></div>
            <div class="form-group"><label class="form-label" for="cost">Cost (LKR) *</label><input type="number" class="form-input" id="cost" name="cost" value="<%= product.cost || 0 %>" placeholder="0.00" min="0" step="0.01"><span class="form-hint">What you paid for this product. Profit = Price - Cost</span></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label" for="stock">Stock Quantity *</label><input type="number" class="form-input" id="stock" name="stock" required value="<%= product.stock %>" min="0"></div>
            <div class="form-group"><label class="form-label" for="category">Category *</label><select class="form-select" id="category" name="category" required><option value="">Select a category</option><% var categories = ['Electronics', 'Clothing', 'Home & Garden', 'Accessories', 'Sports', 'Books', 'Other']; categories.forEach(function(cat) { %><option value="<%= cat %>" <%= product.category === cat ? 'selected' : '' %>><%= cat %></option><% }); %></select></div>
          </div>
          <div class="checkbox-group"><input type="checkbox" id="featured" name="featured" <%= product.featured ? 'checked' : '' %>><label for="featured">Mark as Featured Product</label></div>
          <div class="checkbox-group"><input type="checkbox" id="freeShipping" name="freeShipping" <%= product.freeShipping ? 'checked' : '' %>><label for="freeShipping">Free Shipping</label></div>
          <div class="form-actions"><button type="submit" class="btn-submit"><i class="fas fa-save"></i> Save Changes</button><a href="/admin/products" class="btn-cancel">Cancel</a></div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
var newFiles = [];
var existingCount = <%= product.images ? product.images.length : 0 %>;
var removedExisting = [];

function getTotalImages() {
  return existingCount - removedExisting.length + newFiles.length;
}

function removeExistingImage(index) {
  var imgEl = document.getElementById('existingImg' + index);
  var inputEl = document.getElementById('existingInput' + index);
  if (imgEl) imgEl.style.display = 'none';
  if (inputEl) {
    inputEl.name = 'removedExistingImages';
    inputEl.value = '';
  }
  if (removedExisting.indexOf(index) === -1) {
    removedExisting.push(index);
  }
  updateImageCount();
}

function handleFileSelect(event) {
  var files = Array.from(event.target.files);
  files.forEach(function(file) {
    if (getTotalImages() >= 10) {
      alert('Maximum 10 images total allowed.');
      return;
    }
    if (!file.type.match(/^image\/(jpeg|png|webp)$/)) {
      alert('Only JPG, PNG, and WebP images are allowed.');
      return;
    }
    if (file.size > 10 * 1024 * 1024) {
      alert('File size must be less than 10MB.');
      return;
    }
    newFiles.push(file);
  });
  renderNewPreviews();
  updateFileInput();
  updateImageCount();
}

function renderNewPreviews() {
  var container = document.getElementById('newImagePreviews');
  container.innerHTML = '';
  newFiles.forEach(function(file, index) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var item = document.createElement('div');
      item.className = 'image-preview-item';
      item.innerHTML = '<img src="' + e.target.result + '" alt="Preview"><button type="button" class="remove-image" onclick="removeNewImage(' + index + ')" title="Remove image"><i class="fas fa-times"></i></button>';
      container.appendChild(item);
    };
    reader.readAsDataURL(file);
  });
}

function removeNewImage(index) {
  newFiles.splice(index, 1);
  renderNewPreviews();
  updateFileInput();
  updateImageCount();
}

function updateFileInput() {
  var dt = new DataTransfer();
  newFiles.forEach(function(file) {
    dt.items.add(file);
  });
  document.getElementById('productImages').files = dt.files;
}

function updateImageCount() {
  document.getElementById('imageCount').textContent = getTotalImages() + ' image(s)';
}

// Drag and drop
var uploadZone = document.getElementById('uploadZone');
uploadZone.addEventListener('dragover', function(e) {
  e.preventDefault();
  e.stopPropagation();
  uploadZone.classList.add('dragover');
});
uploadZone.addEventListener('dragleave', function(e) {
  e.preventDefault();
  e.stopPropagation();
  uploadZone.classList.remove('dragover');
});
uploadZone.addEventListener('drop', function(e) {
  e.preventDefault();
  e.stopPropagation();
  uploadZone.classList.remove('dragover');
  var files = Array.from(e.dataTransfer.files);
  files.forEach(function(file) {
    if (getTotalImages() >= 10) return;
    if (!file.type.match(/^image\/(jpeg|png|webp)$/)) return;
    if (file.size > 10 * 1024 * 1024) return;
    newFiles.push(file);
  });
  renderNewPreviews();
  updateFileInput();
  updateImageCount();
});
</script>

<%- include('../partials/footer') %>