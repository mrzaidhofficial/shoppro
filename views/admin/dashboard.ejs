<%- include('../partials/header') %>

<style>
  .admin-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 32px;
    padding: 40px 0;
    min-height: 70vh;
  }
  .admin-sidebar {
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
    padding: 24px 0;
    height: fit-content;
    position: sticky;
    top: 100px;
    box-shadow: var(--shadow-xs);
  }
  .admin-sidebar-header {
    padding: 0 24px 20px;
    border-bottom: var(--border);
    margin-bottom: 12px;
  }
  .admin-sidebar-header h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--gray-900);
    margin-bottom: 4px;
  }
  .admin-sidebar-header span {
    font-size: 0.78rem;
    color: var(--gray-500);
  }
  .admin-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 24px;
    color: var(--gray-600);
    font-weight: 500;
    font-size: 0.9rem;
    transition: var(--transition-fast);
    border-left: 3px solid transparent;
    text-decoration: none;
  }
  .admin-nav-item:hover {
    background: var(--primary-light);
    color: var(--primary);
  }
  .admin-nav-item.active {
    background: var(--primary-light);
    color: var(--primary);
    border-left-color: var(--primary);
    font-weight: 600;
  }
  .admin-nav-item i { width: 20px; text-align: center; }
  .admin-content { min-width: 0; }
  .admin-page-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--gray-900);
    margin-bottom: 28px;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    margin-bottom: 36px;
  }
  .stat-card {
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
    padding: 24px;
    box-shadow: var(--shadow-xs);
    transition: var(--transition);
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    font-size: 1.3rem;
  }
  .stat-icon.products { background: var(--primary-light); color: var(--primary); }
  .stat-icon.orders { background: var(--accent-light); color: var(--accent-dark); }
  .stat-icon.revenue { background: #D1FAE5; color: #059669; }
  .stat-icon.sales { background: #DBEAFE; color: #2563EB; }
  .stat-icon.customers { background: #FEF3C7; color: #D97706; }
  .stat-number {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--gray-900);
  }
  .stat-label {
    font-size: 0.82rem;
    color: var(--gray-500);
    margin-top: 4px;
  }
  .conversion-bar {
    width: 100%;
    height: 6px;
    background: var(--gray-200);
    border-radius: 3px;
    margin-top: 10px;
    overflow: hidden;
  }
  .conversion-fill {
    height: 100%;
    background: linear-gradient(90deg, #4F46E5, #818CF8);
    border-radius: 3px;
    transition: width 0.5s ease;
  }
  .analytics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 36px;
  }
  .analytics-card {
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
    padding: 24px;
    box-shadow: var(--shadow-xs);
  }
  .analytics-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--gray-900);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: var(--border);
  }
  .bar-chart { display: flex; align-items: flex-end; gap: 12px; height: 160px; padding-top: 10px; }
  .bar-item { flex: 1; text-align: center; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
  .bar { width: 100%; max-width: 50px; background: var(--primary-gradient); border-radius: var(--radius-sm) var(--radius-sm) 0 0; transition: var(--transition); min-height: 4px; }
  .bar:hover { opacity: 0.8; transform: scaleY(1.05); }
  .bar-label { font-size: 0.65rem; color: var(--gray-500); margin-top: 8px; white-space: nowrap; }
  .bar-value { font-size: 0.7rem; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
  .recent-orders-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--white);
    border: var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xs);
  }
  .recent-orders-table th {
    text-align: left;
    padding: 14px 18px;
    background: var(--gray-50);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gray-500);
    border-bottom: var(--border);
  }
  .recent-orders-table td {
    padding: 14px 18px;
    font-size: 0.88rem;
    color: var(--gray-700);
    border-bottom: 1px solid var(--gray-100);
  }
  .recent-orders-table tr:last-child td { border-bottom: none; }
  .recent-orders-table tr:hover td { background: var(--gray-50); }
  .badge-status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  .badge-processing { background: #FEF3C7; color: #D97706; }
  .badge-shipped { background: #DBEAFE; color: #2563EB; }
  .badge-delivered { background: var(--success-bg); color: var(--success); }
  .badge-cancelled { background: var(--error-bg); color: var(--error); }
  .quick-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 36px;
  }
  .quick-action-card {
    background: var(--white);
    border: 2px dashed var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 28px;
    text-align: center;
    transition: var(--transition);
    text-decoration: none;
    display: block;
  }
  .quick-action-card:hover {
    border-color: var(--primary);
    background: var(--primary-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .quick-action-card i {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 10px;
    display: block;
  }
  .quick-action-card span {
    font-weight: 600;
    color: var(--gray-700);
    font-size: 0.92rem;
  }
  .top-products-list { display: flex; flex-direction: column; gap: 12px; }
  .top-product-item { display: flex; align-items: center; gap: 14px; padding: 10px 0; border-bottom: 1px solid var(--gray-100); }
  .top-product-item:last-child { border-bottom: none; }
  .top-product-rank { width: 28px; height: 28px; border-radius: 50%; background: var(--primary-light); color: var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }
  .top-product-info { flex: 1; }
  .top-product-name { font-weight: 600; color: var(--gray-900); font-size: 0.88rem; }
  .top-product-sold { font-size: 0.75rem; color: var(--gray-500); }
  .top-product-revenue { font-weight: 700; color: var(--primary); font-size: 0.88rem; white-space: nowrap; }
  .status-summary { display: flex; gap: 12px; flex-wrap: wrap; }
  .status-pill { padding: 8px 16px; border-radius: var(--radius-full); font-size: 0.8rem; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .status-pill.processing { background: #FEF3C7; color: #D97706; }
  .status-pill.shipped { background: #DBEAFE; color: #2563EB; }
  .status-pill.delivered { background: var(--success-bg); color: var(--success); }
  .status-pill.cancelled { background: var(--error-bg); color: var(--error); }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
    .stats-grid { grid-template-columns: 1fr 1fr 1fr; }
    .analytics-grid { grid-template-columns: 1fr; }
    .quick-actions { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <span><i class="fas fa-circle" style="font-size:0.4rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong></span>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item active"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <h1 class="admin-page-title">Dashboard</h1>
      
      <div class="quick-actions">
        <a href="/admin/products/add" class="quick-action-card">
          <i class="fas fa-plus-circle"></i>
          <span>Add New Product</span>
        </a>
        <a href="/admin/orders" class="quick-action-card">
          <i class="fas fa-clipboard-list"></i>
          <span>View All Orders</span>
        </a>
        <a href="/admin/coupons/add" class="quick-action-card">
          <i class="fas fa-tags"></i>
          <span>Create Coupon</span>
        </a>
      </div>
      
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon products"><i class="fas fa-box"></i></div>
          <div class="stat-number"><%= totalProducts %></div>
          <div class="stat-label">Total Products</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orders"><i class="fas fa-receipt"></i></div>
          <div class="stat-number"><%= totalOrders %></div>
          <div class="stat-label">Total Orders</div>
        </div>
        <div class="stat-card" style="border: 2px solid #10B981; background: linear-gradient(135deg, #F0FDF4, #FFFFFF);">
          <div class="stat-icon revenue"><i class="fas fa-chart-line"></i></div>
          <div class="stat-number" style="color: #059669;">$<%= totalRevenue.toFixed(2) %></div>
          <div class="stat-label" style="color: #059669; font-weight: 600;">Total Profit</div>
        </div>
        <div class="stat-card" style="border: 2px solid #0066FF; background: linear-gradient(135deg, #EFF6FF, #FFFFFF);">
          <div class="stat-icon sales"><i class="fas fa-shopping-cart"></i></div>
          <div class="stat-number" style="color: #2563EB;">$<%= totalSales.toFixed(2) %></div>
          <div class="stat-label" style="color: #2563EB; font-weight: 600;">Total Sales</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon customers"><i class="fas fa-users"></i></div>
          <div class="stat-number"><%= typeof totalCustomers !== 'undefined' ? totalCustomers : 0 %></div>
          <div class="stat-label">Customers <span style="font-size:0.7rem;color:var(--gray-400);">(<%= typeof totalRegisteredUsers !== 'undefined' ? totalRegisteredUsers : 0 %> registered)</span></div>
        </div>
      </div>
      
      <!-- Conversion Rate Card -->
      <div class="analytics-card" style="margin-bottom:36px;">
        <h3>Conversion Rate</h3>
        <div style="display:flex;align-items:center;gap:24px;">
          <div style="text-align:center;">
            <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:700;color:#4F46E5;"><%= conversionRate %>%</div>
            <div style="font-size:0.8rem;color:var(--gray-500);margin-top:4px;">
              <%= typeof totalCustomers !== 'undefined' ? totalCustomers : 0 %> customers / <%= typeof totalRegisteredUsers !== 'undefined' ? totalRegisteredUsers : 0 %> registered
            </div>
          </div>
          <div style="flex:1;">
            <div class="conversion-bar">
              <div class="conversion-fill" style="width:<%= conversionRate %>%"></div>
            </div>
            <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:0.7rem;color:var(--gray-400);">
              <span>0%</span>
              <span>50%</span>
              <span>100%</span>
            </div>
          </div>
        </div>
        <p style="font-size:0.78rem;color:var(--gray-400);margin-top:12px;">
          <i class="fas fa-info-circle"></i> Percentage of registered users who have made at least one purchase.
        </p>
      </div>
      
      <div class="analytics-grid">
        <div class="analytics-card">
          <h3>Monthly Sales <span style="font-weight:400;font-size:0.78rem;color:var(--gray-400);">(Last 6 months)</span></h3>
          <% if (typeof monthlySales !== 'undefined' && monthlySales.length > 0) { %>
            <div class="bar-chart">
              <% var maxRevenue = 0; monthlySales.forEach(function(m) { if (m.revenue > maxRevenue) maxRevenue = m.revenue; }); %>
              <% monthlySales.forEach(function(m) { %>
                <div class="bar-item">
                  <div class="bar-value">$<%= m.revenue.toFixed(0) %></div>
                  <div class="bar" style="height:<%= maxRevenue > 0 ? (m.revenue / maxRevenue * 100) : 0 %>%"></div>
                  <div class="bar-label"><%= m._id %></div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div style="text-align:center;padding:40px;color:var(--gray-400);">No sales data yet</div>
          <% } %>
        </div>
        
        <div class="analytics-card">
          <h3>Top Selling Products</h3>
          <% if (typeof topProducts !== 'undefined' && topProducts.length > 0) { %>
            <div class="top-products-list">
              <% topProducts.forEach(function(tp, index) { %>
                <div class="top-product-item">
                  <div class="top-product-rank"><%= index + 1 %></div>
                  <div class="top-product-info">
                    <div class="top-product-name"><%= tp.name %></div>
                    <div class="top-product-sold"><%= tp.totalSold %> units sold</div>
                  </div>
                  <div class="top-product-revenue">$<%= tp.revenue.toFixed(2) %></div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div style="text-align:center;padding:40px;color:var(--gray-400);">No sales data yet</div>
          <% } %>
        </div>
      </div>
      
      <% if (typeof ordersByStatus !== 'undefined' && ordersByStatus.length > 0) { %>
        <div class="analytics-card" style="margin-bottom:36px;">
          <h3>Orders by Status</h3>
          <div class="status-summary">
            <% ordersByStatus.forEach(function(s) { %>
              <div class="status-pill <%= s._id %>">
                <strong><%= s.count %></strong> <%= s._id %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
      
      <h3 style="font-family:var(--font-display);font-size:1.2rem;color:var(--gray-900);margin-bottom:18px;">Recent Orders</h3>
      <% if (recentOrders && recentOrders.length > 0) { %>
        <div style="overflow-x:auto;">
          <table class="recent-orders-table">
            <thead>
              <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Total</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% recentOrders.forEach(function(order) { %>
                <tr>
                  <td style="font-weight:600;color:var(--primary);"><%= order.orderNumber %></td>
                  <td><%= order.user ? order.user.firstName + ' ' + order.user.lastName : 'N/A' %></td>
                  <td><%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                  <td style="font-weight:600;">$<%= order.total.toFixed(2) %></td>
                  <td><span class="badge-status badge-<%= order.status %>"><%= order.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:48px;background:var(--white);border:var(--border);border-radius:var(--radius-xl);">
          <i class="fas fa-inbox" style="font-size:3rem;color:var(--gray-300);margin-bottom:12px;display:block;"></i>
          <p style="color:var(--gray-500);">No orders yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>