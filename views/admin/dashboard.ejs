      <!-- Shipping & Coupon Stats -->
      <div class="analytics-grid" style="margin-bottom:28px;">
        <div class="analytics-card">
          <h3><i class="fas fa-shipping-fast" style="color:#2563EB;margin-right:8px;"></i> Shipping Overview</h3>
          <div style="display:flex;align-items:center;gap:20px;margin-top:16px;">
            <div style="text-align:center;">
              <div style="font-family:var(--font-display);font-size:2rem;font-weight:700;color:#2563EB;">$<%= typeof totalShippingCollected !== 'undefined' ? totalShippingCollected.toFixed(2) : '0.00' %></div>
              <div style="font-size:0.78rem;color:var(--gray-500);margin-top:4px;">Total Shipping Collected</div>
            </div>
            <div style="width:1px;height:50px;background:var(--gray-200);"></div>
            <div style="text-align:center;">
              <div style="font-family:var(--font-display);font-size:2rem;font-weight:700;color:#1E40AF;"><%= typeof paidShippingOrders !== 'undefined' ? paidShippingOrders : 0 %></div>
              <div style="font-size:0.78rem;color:var(--gray-500);margin-top:4px;">Paid Shipping Orders</div>
            </div>
          </div>
        </div>
        <div class="analytics-card">
          <h3><i class="fas fa-tags" style="color:#D97706;margin-right:8px;"></i> Coupons Overview</h3>
          <div style="display:flex;align-items:center;gap:20px;margin-top:16px;">
            <div style="text-align:center;">
              <div style="font-family:var(--font-display);font-size:2rem;font-weight:700;color:#D97706;">$<%= typeof totalCouponsGiven !== 'undefined' ? totalCouponsGiven.toFixed(2) : '0.00' %></div>
              <div style="font-size:0.78rem;color:var(--gray-500);margin-top:4px;">Total Coupons Given</div>
            </div>
            <div style="width:1px;height:50px;background:var(--gray-200);"></div>
            <div style="text-align:center;">
              <div style="font-family:var(--font-display);font-size:2rem;font-weight:700;color:#92400E;"><%= typeof couponOrderCount !== 'undefined' ? couponOrderCount : 0 %></div>
              <div style="font-size:0.78rem;color:var(--gray-500);margin-top:4px;">Orders with Coupons</div>
            </div>
          </div>
        </div>
      </div>