<%- include('../partials/header') %>

<style>
  .admin-layout { display: grid; grid-template-columns: 250px 1fr; gap: 32px; padding: 40px 0; min-height: 70vh; }
  .admin-sidebar { 
    background: var(--bg-card); 
    border: 1px solid var(--border-color); 
    border-radius: var(--radius-xl); 
    padding: 20px 0; 
    height: fit-content; 
    position: sticky; 
    top: 100px; 
    box-shadow: var(--shadow-sm); 
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .admin-sidebar:hover { box-shadow: var(--shadow-md); }
  .admin-sidebar-header { padding: 8px 20px 18px; border-bottom: 1px solid var(--border-color); margin-bottom: 8px; }
  .admin-sidebar-header h3 { font-family: var(--font-display); font-size: 1rem; color: var(--text-primary); margin-bottom: 2px; letter-spacing: -0.3px; }
  .admin-sidebar-header a { text-decoration: none; font-size: 0.72rem; color: var(--text-muted); display: flex; align-items: center; gap: 4px; margin-top: 2px; transition: color 0.2s; }
  .admin-sidebar-header a:hover { color: var(--primary); }
  .admin-nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 20px; color: var(--text-secondary); font-weight: 500; font-size: 0.85rem; transition: all 0.2s ease; border-left: 3px solid transparent; text-decoration: none; margin: 2px 8px; border-radius: 0 var(--radius) var(--radius) 0; }
  .admin-nav-item:hover { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); transform: translateX(2px); }
  .admin-nav-item.active { background: var(--primary-light); color: var(--primary); border-left-color: var(--primary); font-weight: 600; }
  .admin-nav-item i { width: 18px; text-align: center; font-size: 0.85rem; }
  .admin-content { min-width: 0; }
  .admin-page-title { font-family: var(--font-display); font-size: 1.8rem; color: var(--text-primary); margin-bottom: 28px; letter-spacing: -0.5px; }
  
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 28px; }
  .stat-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); padding: 24px; box-shadow: var(--shadow-xs); transition: all 0.3s ease; }
  .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .stat-icon { width: 48px; height: 48px; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; font-size: 1.3rem; transition: transform 0.3s ease; }
  .stat-card:hover .stat-icon { transform: scale(1.1); }
  .stat-icon.products { background: rgba(0,102,255,0.1); color: #3B82F6; }
  .stat-icon.orders { background: rgba(0,229,160,0.1); color: #059669; }
  .stat-icon.customers { background: rgba(245,158,11,0.1); color: #D97706; }
  [data-theme="dark"] .stat-icon.products { background: rgba(59,130,246,0.15); color: #60A5FA; }
  [data-theme="dark"] .stat-icon.orders { background: rgba(52,211,153,0.15); color: #34D399; }
  [data-theme="dark"] .stat-icon.customers { background: rgba(251,191,36,0.15); color: #FBBF24; }
  .stat-number { font-family: var(--font-display); font-size: 1.8rem; font-weight: 700; color: var(--text-primary); }
  .stat-label { font-size: 0.82rem; color: var(--text-muted); margin-top: 4px; }
  
  .financial-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px; }
  .financial-card { border-radius: var(--radius-xl); padding: 32px; box-shadow: var(--shadow-md); transition: all 0.3s ease; position: relative; overflow: hidden; }
  .financial-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .financial-card.sales { background: linear-gradient(135deg, #EFF6FF 0%, #FFFFFF 50%, #DBEAFE 100%); border: 2px solid #BFDBFE; }
  .financial-card.profit { background: linear-gradient(135deg, #F0FDF4 0%, #FFFFFF 50%, #D1FAE5 100%); border: 2px solid #A7F3D0; }
  [data-theme="dark"] .financial-card.sales { background: linear-gradient(135deg, #0f1d3a 0%, #152240 50%, #0f1d3a 100%); border: 2px solid #1e3a5f; }
  [data-theme="dark"] .financial-card.profit { background: linear-gradient(135deg, #0a1f1a 0%, #0f2a23 50%, #0a1f1a 100%); border: 2px solid #1a4035; }
  .financial-card .fc-icon { width: 56px; height: 56px; border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 16px; transition: transform 0.3s ease; }
  .financial-card:hover .fc-icon { transform: scale(1.1); }
  .financial-card.sales .fc-icon { background: #DBEAFE; color: #2563EB; }
  .financial-card.profit .fc-icon { background: #D1FAE5; color: #059669; }
  [data-theme="dark"] .financial-card.sales .fc-icon { background: rgba(59,130,246,0.2); color: #60A5FA; }
  [data-theme="dark"] .financial-card.profit .fc-icon { background: rgba(52,211,153,0.2); color: #34D399; }
  .financial-card .fc-amount { font-family: var(--font-display); font-size: 2.5rem; font-weight: 700; margin-bottom: 4px; }
  .financial-card.sales .fc-amount { color: #1E40AF; }
  .financial-card.profit .fc-amount { color: #065F46; }
  [data-theme="dark"] .financial-card.sales .fc-amount { color: #93C5FD; }
  [data-theme="dark"] .financial-card.profit .fc-amount { color: #6EE7B7; }
  .financial-card .fc-label { font-size: 0.95rem; font-weight: 600; margin-bottom: 8px; }
  .financial-card.sales .fc-label { color: #2563EB; }
  .financial-card.profit .fc-label { color: #059669; }
  [data-theme="dark"] .financial-card.sales .fc-label { color: #60A5FA; }
  [data-theme="dark"] .financial-card.profit .fc-label { color: #34D399; }
  .financial-card .fc-sub { font-size: 0.78rem; color: var(--text-muted); }
  .financial-card .fc-badge { position: absolute; top: 20px; right: 20px; padding: 6px 14px; border-radius: var(--radius-full); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
  .financial-card.sales .fc-badge { background: #BFDBFE; color: #1E40AF; }
  .financial-card.profit .fc-badge { background: #A7F3D0; color: #065F46; }
  [data-theme="dark"] .financial-card.sales .fc-badge { background: rgba(59,130,246,0.2); color: #93C5FD; }
  [data-theme="dark"] .financial-card.profit .fc-badge { background: rgba(52,211,153,0.2); color: #6EE7B7; }
  
  .info-cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px; }
  .info-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); padding: 24px; box-shadow: var(--shadow-xs); transition: box-shadow 0.3s ease; }
  .info-card:hover { box-shadow: var(--shadow-md); }
  .info-card h3 { font-family: var(--font-display); font-size: 1.05rem; color: var(--text-primary); margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border-color); }
  .info-card-stats { display: flex; align-items: center; gap: 20px; }
  .info-card-stat { text-align: center; flex: 1; }
  .info-card-stat-number { font-family: var(--font-display); font-size: 2rem; font-weight: 700; }
  .info-card-stat-label { font-size: 0.78rem; color: var(--text-muted); margin-top: 4px; }
  .info-card-divider { width: 1px; height: 50px; background: var(--border-color); }
  
  .conversion-bar { width: 100%; height: 6px; background: var(--border-color); border-radius: 3px; margin-top: 10px; overflow: hidden; }
  .conversion-fill { height: 100%; background: linear-gradient(90deg, #4F46E5, #818CF8); border-radius: 3px; transition: width 0.5s ease; }
  .analytics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 36px; }
  .analytics-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); padding: 24px; box-shadow: var(--shadow-xs); transition: box-shadow 0.3s ease; }
  .analytics-card:hover { box-shadow: var(--shadow-md); }
  .analytics-card h3 { font-family: var(--font-display); font-size: 1.05rem; color: var(--text-primary); margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border-color); }
  .bar-chart { display: flex; align-items: flex-end; gap: 12px; height: 160px; padding-top: 10px; }
  .bar-item { flex: 1; text-align: center; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
  .bar { width: 100%; max-width: 50px; background: var(--primary-gradient); border-radius: var(--radius-sm) var(--radius-sm) 0 0; transition: all 0.3s ease; min-height: 4px; }
  .bar:hover { opacity: 0.8; transform: scaleY(1.05); }
  .bar-label { font-size: 0.65rem; color: var(--text-muted); margin-top: 8px; white-space: nowrap; }
  .bar-value { font-size: 0.7rem; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
  
  .recent-orders-table { width: 100%; border-collapse: collapse; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-xs); }
  .recent-orders-table th { text-align: left; padding: 14px 18px; background: var(--bg-card-alt); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); border-bottom: 2px solid var(--border-color); }
  .recent-orders-table td { padding: 14px 18px; font-size: 0.88rem; color: var(--text-body); border-bottom: 1px solid var(--border-color); }
  .recent-orders-table tr:last-child td { border-bottom: none; }
  .recent-orders-table tr:hover td { background: var(--bg-hover); }
  
  .badge-status { display: inline-flex; align-items: center; gap: 5px; padding: 4px 11px; border-radius: var(--radius-full); font-size: 0.7rem; font-weight: 600; text-transform: capitalize; }
  .badge-status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .badge-pending { background: rgba(245,158,11,0.1); color: #D97706; }
  .badge-pending::before { background: #D97706; }
  .badge-processing { background: rgba(245,158,11,0.1); color: #D97706; }
  .badge-processing::before { background: #D97706; }
  .badge-shipped { background: rgba(37,99,235,0.1); color: #2563EB; }
  .badge-shipped::before { background: #2563EB; }
  .badge-delivered { background: rgba(16,185,129,0.1); color: #059669; }
  .badge-delivered::before { background: #059669; }
  .badge-cancelled { background: rgba(239,68,68,0.1); color: #EF4444; }
  .badge-cancelled::before { background: #EF4444; }
  [data-theme="dark"] .badge-pending { background: rgba(251,191,36,0.15); color: #FBBF24; }
  [data-theme="dark"] .badge-processing { background: rgba(251,191,36,0.15); color: #FBBF24; }
  [data-theme="dark"] .badge-shipped { background: rgba(59,130,246,0.15); color: #60A5FA; }
  [data-theme="dark"] .badge-delivered { background: rgba(52,211,153,0.15); color: #34D399; }
  [data-theme="dark"] .badge-cancelled { background: rgba(248,113,113,0.15); color: #F87171; }
  
  .quick-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 36px; }
  .quick-action-card { background: var(--bg-card); border: 2px dashed var(--border-color); border-radius: var(--radius-lg); padding: 28px; text-align: center; transition: all 0.3s ease; text-decoration: none; display: block; }
  .quick-action-card:hover { border-color: var(--primary); background: var(--primary-light); transform: translateY(-3px); box-shadow: var(--shadow-md); border-style: solid; }
  .quick-action-card i { font-size: 2rem; color: var(--primary); margin-bottom: 10px; display: block; transition: transform 0.3s ease; }
  .quick-action-card:hover i { transform: scale(1.15); }
  .quick-action-card span { font-weight: 600; color: var(--text-secondary); font-size: 0.92rem; }
  
  .top-products-list { display: flex; flex-direction: column; gap: 10px; }
  .top-product-item { display: flex; align-items: center; gap: 14px; padding: 10px 0; border-bottom: 1px solid var(--border-color); }
  .top-product-item:last-child { border-bottom: none; }
  .top-product-rank { width: 28px; height: 28px; border-radius: 50%; background: var(--primary-light); color: var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }
  .top-product-info { flex: 1; }
  .top-product-name { font-weight: 600; color: var(--text-primary); font-size: 0.88rem; }
  .top-product-sold { font-size: 0.75rem; color: var(--text-muted); }
  .top-product-revenue { font-weight: 700; color: var(--primary); font-size: 0.88rem; white-space: nowrap; font-family: var(--font-display); }
  
  .status-summary { display: flex; gap: 10px; flex-wrap: wrap; }
  .status-pill { padding: 8px 16px; border-radius: var(--radius-full); font-size: 0.8rem; font-weight: 600; display: flex; align-items: center; gap: 8px; border: 1px solid transparent; }
  .status-pill.pending { background: rgba(245,158,11,0.1); color: #D97706; border-color: rgba(245,158,11,0.2); }
  .status-pill.processing { background: rgba(245,158,11,0.1); color: #D97706; border-color: rgba(245,158,11,0.2); }
  .status-pill.shipped { background: rgba(37,99,235,0.1); color: #2563EB; border-color: rgba(37,99,235,0.2); }
  .status-pill.delivered { background: rgba(16,185,129,0.1); color: #059669; border-color: rgba(16,185,129,0.2); }
  .status-pill.cancelled { background: rgba(239,68,68,0.1); color: #EF4444; border-color: rgba(239,68,68,0.2); }
  
  @media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; display: flex; overflow-x: auto; padding: 12px; gap: 4px; }
    .admin-sidebar-header { display: none; }
    .admin-nav-item { white-space: nowrap; border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; font-size: 0.8rem; margin: 0; border-radius: 0; }
    .admin-nav-item.active { border-left-color: transparent; border-bottom-color: var(--primary); }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .financial-grid { grid-template-columns: 1fr; }
    .info-cards-grid { grid-template-columns: 1fr; }
    .analytics-grid { grid-template-columns: 1fr; }
    .quick-actions { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="container">
  <div class="admin-layout">
    
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Admin Panel</h3>
        <a href="/admin/settings"><i class="fas fa-circle" style="font-size:0.35rem;color:var(--accent);"></i> Logged in as <strong><%= user.firstName %></strong> <i class="fas fa-pen" style="font-size:0.55rem;opacity:0.5;"></i></a>
      </div>
      <a href="/admin/dashboard" class="admin-nav-item active"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/admin/products" class="admin-nav-item"><i class="fas fa-box"></i> Products</a>
      <a href="/admin/orders" class="admin-nav-item"><i class="fas fa-receipt"></i> Orders</a>
      <a href="/admin/coupons" class="admin-nav-item"><i class="fas fa-tags"></i> Coupons</a>
      <a href="/admin/shipping/settings" class="admin-nav-item"><i class="fas fa-truck"></i> Shipping</a>
      <a href="/admin/bank-details" class="admin-nav-item"><i class="fas fa-university"></i> Bank Details</a>
      <a href="/admin/finances" class="admin-nav-item"><i class="fas fa-chart-pie"></i> Finances</a>
      <a href="/admin/settings" class="admin-nav-item"><i class="fas fa-cog"></i> Settings</a>
      <a href="/" class="admin-nav-item" target="_blank"><i class="fas fa-store"></i> View Store</a>
      <a href="/auth/logout" class="admin-nav-item" style="color:var(--error);"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
    </aside>
    
    <div class="admin-content">
      <h1 class="admin-page-title">Dashboard</h1>
      
      <div class="quick-actions">
        <a href="/admin/products/add" class="quick-action-card"><i class="fas fa-plus-circle"></i><span>Add New Product</span></a>
        <a href="/admin/orders" class="quick-action-card"><i class="fas fa-clipboard-list"></i><span>View All Orders</span></a>
        <a href="/admin/coupons/add" class="quick-action-card"><i class="fas fa-tags"></i><span>Create Coupon</span></a>
      </div>
      
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-icon products"><i class="fas fa-box"></i></div><div class="stat-number"><%= totalProducts %></div><div class="stat-label">Total Products</div></div>
        <div class="stat-card"><div class="stat-icon orders"><i class="fas fa-receipt"></i></div><div class="stat-number"><%= totalOrders %></div><div class="stat-label">Total Orders</div></div>
        <div class="stat-card"><div class="stat-icon customers"><i class="fas fa-users"></i></div><div class="stat-number"><%= typeof totalCustomers !== 'undefined' ? totalCustomers : 0 %></div><div class="stat-label">Customers <span style="font-size:0.7rem;color:var(--text-muted);">(<%= typeof totalRegisteredUsers !== 'undefined' ? totalRegisteredUsers : 0 %> registered)</span></div></div>
      </div>
      
      <div class="financial-grid">
        <div class="financial-card sales">
          <div class="fc-badge">Gross Sales</div>
          <div class="fc-icon"><i class="fas fa-shopping-cart"></i></div>
          <div class="fc-amount">LKR <%= totalSales.toFixed(2) %></div>
          <div class="fc-label">Confirmed Sales</div>
          <div class="fc-sub">Total Revenue from the Processed Orders</div>
        </div>
        <div class="financial-card profit">
          <div class="fc-badge">Net Profit</div>
          <div class="fc-icon"><i class="fas fa-chart-line"></i></div>
          <div class="fc-amount">LKR <%= totalRevenue.toFixed(2) %></div>
          <div class="fc-label">Net Profit</div>
          <div class="fc-sub">Pure Profit from the Total Revenue</div>
        </div>
      </div>
      
      <div class="info-cards-grid">
        <div class="info-card">
          <h3><i class="fas fa-shipping-fast" style="color:#2563EB;margin-right:8px;"></i> Delivery Overview</h3>
          <div class="info-card-stats">
            <div class="info-card-stat"><div class="info-card-stat-number" style="color:#2563EB;">LKR <%= typeof totalShippingCollected !== 'undefined' ? totalShippingCollected.toFixed(2) : '0.00' %></div><div class="info-card-stat-label">Total Delivery Charges</div></div>
            <div class="info-card-divider"></div>
            <div class="info-card-stat"><div class="info-card-stat-number" style="color:#1E40AF;"><%= typeof paidShippingOrders !== 'undefined' ? paidShippingOrders : 0 %></div><div class="info-card-stat-label">Orders with Delivery</div></div>
          </div>
        </div>
        <div class="info-card">
          <h3><i class="fas fa-tags" style="color:#D97706;margin-right:8px;"></i> Coupons Overview</h3>
          <div class="info-card-stats">
            <div class="info-card-stat"><div class="info-card-stat-number" style="color:#D97706;">LKR <%= typeof totalCouponsGiven !== 'undefined' ? totalCouponsGiven.toFixed(2) : '0.00' %></div><div class="info-card-stat-label">Total Discounts Given</div></div>
            <div class="info-card-divider"></div>
            <div class="info-card-stat"><div class="info-card-stat-number" style="color:#92400E;"><%= typeof couponOrderCount !== 'undefined' ? couponOrderCount : 0 %></div><div class="info-card-stat-label">Orders with Coupons</div></div>
          </div>
        </div>
      </div>
      
      <div class="analytics-card" style="margin-bottom:28px;">
        <h3>Conversion Rate</h3>
        <div style="display:flex;align-items:center;gap:24px;">
          <div style="text-align:center;"><div style="font-family:var(--font-display);font-size:2.5rem;font-weight:700;color:#4F46E5;"><%= conversionRate %>%</div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;"><%= typeof totalCustomers !== 'undefined' ? totalCustomers : 0 %> customers / <%= typeof totalRegisteredUsers !== 'undefined' ? totalRegisteredUsers : 0 %> registered</div></div>
          <div style="flex:1;"><div class="conversion-bar"><div class="conversion-fill" style="width:<%= conversionRate %>%"></div></div><div style="display:flex;justify-content:space-between;margin-top:6px;font-size:0.7rem;color:var(--text-muted);"><span>0%</span><span>50%</span><span>100%</span></div></div>
        </div>
        <p style="font-size:0.78rem;color:var(--text-muted);margin-top:12px;"><i class="fas fa-info-circle"></i> Percentage of registered users who have made at least one purchase.</p>
      </div>
      
      <div class="analytics-grid">
        <div class="analytics-card">
          <h3>Monthly Sales <span style="font-weight:400;font-size:0.78rem;color:var(--text-muted);">(Last 6 months)</span></h3>
          <% if (typeof monthlySales !== 'undefined' && monthlySales.length > 0) { %>
            <div class="bar-chart">
              <% var maxRevenue = 0; monthlySales.forEach(function(m) { if (m.revenue > maxRevenue) maxRevenue = m.revenue; }); %>
              <% monthlySales.forEach(function(m) { %>
                <div class="bar-item"><div class="bar-value">LKR <%= m.revenue.toFixed(0) %></div><div class="bar" style="height:<%= maxRevenue > 0 ? (m.revenue / maxRevenue * 100) : 0 %>%"></div><div class="bar-label"><%= m._id %></div></div>
              <% }) %>
            </div>
          <% } else { %>
            <div style="text-align:center;padding:40px;color:var(--text-muted);">No sales data yet</div>
          <% } %>
        </div>
        <div class="analytics-card">
          <h3>Top Selling Products</h3>
          <% if (typeof topProducts !== 'undefined' && topProducts.length > 0) { %>
            <div class="top-products-list">
              <% topProducts.forEach(function(tp, index) { %>
                <div class="top-product-item"><div class="top-product-rank"><%= index + 1 %></div><div class="top-product-info"><div class="top-product-name"><%= tp.name %></div><div class="top-product-sold"><%= tp.totalSold %> units sold</div></div><div class="top-product-revenue">LKR <%= tp.revenue.toFixed(2) %></div></div>
              <% }) %>
            </div>
          <% } else { %>
            <div style="text-align:center;padding:40px;color:var(--text-muted);">No sales data yet</div>
          <% } %>
        </div>
      </div>
      
      <% if (typeof ordersByStatus !== 'undefined' && ordersByStatus.length > 0) { %>
        <div class="analytics-card" style="margin-bottom:36px;">
          <h3>Orders by Status</h3>
          <div class="status-summary">
            <% ordersByStatus.forEach(function(s) { %>
              <div class="status-pill <%= s._id %>"><strong><%= s.count %></strong> <%= s._id %></div>
            <% }) %>
          </div>
        </div>
      <% } %>
      
      <h3 style="font-family:var(--font-display);font-size:1.2rem;color:var(--text-primary);margin-bottom:18px;">Recent Orders</h3>
      <% if (recentOrders && recentOrders.length > 0) { %>
        <div style="overflow-x:auto;">
          <table class="recent-orders-table">
            <thead><tr><th>Order #</th><th>Customer</th><th>Date</th><th>Total</th><th>Payment</th><th>Status</th></tr></thead>
            <tbody>
              <% recentOrders.forEach(function(order) { %>
                <tr>
                  <td style="font-weight:600;color:var(--primary);"><%= order.orderNumber %></td>
                  <td><%= order.user ? order.user.firstName + ' ' + order.user.lastName : 'N/A' %></td>
                  <td><%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                  <td style="font-weight:600;color:#2563EB;font-family:var(--font-display);">LKR <%= order.total.toFixed(2) %></td>
                  <td style="font-size:0.75rem;">
                    <% if (order.paymentMethod === 'bank_transfer') { %>
                      Bank Transfer
                      <% if (order.paymentVerified) { %>
                        <span style="color:var(--success);font-weight:600;">✓</span>
                      <% } else { %>
                        <span style="color:#D97706;">Pending</span>
                      <% } %>
                    <% } else { %>
                      COD
                    <% } %>
                  </td>
                  <td><span class="badge-status badge-<%= order.status %>"><%= order.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:48px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-xl);"><i class="fas fa-inbox" style="font-size:3rem;color:var(--text-muted);margin-bottom:12px;display:block;opacity:0.3;"></i><p style="color:var(--text-muted);">No orders yet.</p></div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>