<%- include('partials/header') %>

<style>
  .upload-btn-wrapper {
    position: relative;
    overflow: hidden;
    display: inline-block;
    cursor: pointer;
    width: 100%;
    margin-top: 6px;
  }
  .upload-btn-wrapper input[type="file"] {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  .upload-btn-custom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 18px;
    background: var(--bg-card-alt);
    border: 2px dashed var(--border-color);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    font-family: var(--font-primary);
    transition: all 0.2s ease;
    text-align: center;
    cursor: pointer;
  }
  .upload-btn-custom:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-light);
  }
  .upload-btn-custom.has-file {
    border-color: var(--success);
    color: var(--success);
    background: var(--success-bg);
    border-style: solid;
  }
  #file-name {
    display: block;
    margin-top: 6px;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
  }
</style>

<section class="checkout-section-page">
  <div class="container">
    <h1 style="font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); margin-bottom: 36px; color: var(--text-primary); text-align: center;">Secure Checkout</h1>

    <div class="checkout-layout">
      
      <div class="checkout-form-card">
        <h3 class="checkout-section-title">
          <i class="fas fa-shipping-fast" style="color: var(--primary); margin-right: 8px;"></i>
          Delivery Address
        </h3>
        <div class="form-row">
          <div class="form-group"><label class="form-label">First Name *</label><input type="text" class="form-input" id="firstName" name="firstName" required placeholder="John"></div>
          <div class="form-group"><label class="form-label">Last Name *</label><input type="text" class="form-input" id="lastName" name="lastName" required placeholder="Doe"></div>
        </div>
        <div class="form-group"><label class="form-label">Email Address *</label><input type="email" class="form-input" id="email" name="email" required placeholder="john@example.com"></div>
        <div class="form-group"><label class="form-label">Phone Number *</label><input type="tel" class="form-input" id="phone" name="phone" required placeholder="07XXXXXXXX"></div>
        <div class="form-group"><label class="form-label">Street Address *</label><input type="text" class="form-input" id="address" name="street" required placeholder="123 Main Street, Apt 4B"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">City *</label><input type="text" class="form-input" id="city" name="city" required placeholder="Colombo"></div>
          <div class="form-group"><label class="form-label">District *</label>
            <select class="form-input form-select" id="state" name="state" required>
              <option value="">Select District</option>
              <option value="Colombo">Colombo</option>
              <option value="Gampaha">Gampaha</option>
              <option value="Kalutara">Kalutara</option>
              <option value="Kandy">Kandy</option>
              <option value="Matale">Matale</option>
              <option value="Nuwara Eliya">Nuwara Eliya</option>
              <option value="Galle">Galle</option>
              <option value="Matara">Matara</option>
              <option value="Hambantota">Hambantota</option>
              <option value="Jaffna">Jaffna</option>
              <option value="Kilinochchi">Kilinochchi</option>
              <option value="Mannar">Mannar</option>
              <option value="Vavuniya">Vavuniya</option>
              <option value="Mullaitivu">Mullaitivu</option>
              <option value="Batticaloa">Batticaloa</option>
              <option value="Ampara">Ampara</option>
              <option value="Trincomalee">Trincomalee</option>
              <option value="Kurunegala">Kurunegala</option>
              <option value="Puttalam">Puttalam</option>
              <option value="Anuradhapura">Anuradhapura</option>
              <option value="Polonnaruwa">Polonnaruwa</option>
              <option value="Badulla">Badulla</option>
              <option value="Moneragala">Moneragala</option>
              <option value="Ratnapura">Ratnapura</option>
              <option value="Kegalle">Kegalle</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Postal Code</label>
          <input type="text" class="form-input" id="zip" name="zipCode" placeholder="e.g. 00100">
        </div>
        <input type="hidden" name="country" value="Sri Lanka">

        <h3 class="checkout-section-title" style="margin-top: 28px;">
          <i class="fas fa-credit-card" style="color: var(--primary); margin-right: 8px;"></i>
          Payment Method
        </h3>
        
        <div style="margin-bottom: 16px;">
          <label style="display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: var(--bg-card-alt); border: 2px solid var(--primary); border-radius: var(--radius-lg); cursor: pointer; margin-bottom: 10px; transition: border-color 0.2s;" id="codLabel">
            <input type="radio" name="paymentMethod" value="cod" checked onchange="togglePaymentMethod()" style="width: 18px; height: 18px; accent-color: var(--primary);">
            <div>
              <div style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem;">Cash on Delivery</div>
              <div style="font-size: 0.78rem; color: var(--text-muted);">Pay when you receive your order</div>
            </div>
          </label>
          
          <label style="display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: var(--bg-card-alt); border: 2px solid var(--border-color); border-radius: var(--radius-lg); cursor: pointer; transition: border-color 0.2s;" id="bankLabel">
            <input type="radio" name="paymentMethod" value="bank_transfer" onchange="togglePaymentMethod()" style="width: 18px; height: 18px; accent-color: var(--primary);">
            <div>
              <div style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem;">Bank Transfer</div>
              <div style="font-size: 0.78rem; color: var(--text-muted);">Upload your payment receipt</div>
            </div>
          </label>
        </div>

        <div id="bankDetails" style="display: none; background: var(--bg-card-alt); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 18px 20px; margin-bottom: 18px;">
          <div style="font-weight: 600; color: var(--text-primary); font-size: 0.88rem; margin-bottom: 12px;">
            <i class="fas fa-university" style="color: var(--primary); margin-right: 6px;"></i> Bank Account Details
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 0.85rem;">
            <div><span style="color: var(--text-muted);">Bank:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankName || '—' %></strong></div>
            <div><span style="color: var(--text-muted);">Branch:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankBranch || '—' %></strong></div>
            <div><span style="color: var(--text-muted);">Account Name:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankAccountName || '—' %></strong></div>
            <div><span style="color: var(--text-muted);">Account Number:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankAccountNumber || '—' %></strong></div>
          </div>
          
          <div style="margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border-color);">
            <label class="form-label">Upload Payment Receipt *</label>
            <div class="upload-btn-wrapper">
              <button type="button" class="upload-btn-custom" id="uploadBtn">
                <i class="fas fa-cloud-upload-alt"></i> Choose File
              </button>
              <input type="file" name="paymentReceipt" id="paymentReceipt" accept="image/*,.pdf" onchange="updateFileName()">
            </div>
            <span id="file-name"></span>
            <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 4px;">Accepted: JPG, PNG, PDF. Max size: 5MB</div>
          </div>
        </div>

        <p style="color: var(--text-muted); font-size: 0.82rem; text-align: center; margin: 8px 0 0;">
          <i class="fas fa-lock" style="margin-right: 4px;"></i> Your information is encrypted and secure
        </p>
      </div>

      <div class="order-summary-card">
        <h3 class="order-summary-title">Your Order</h3>
        <div class="order-items-list">
          <% cartItems.forEach(function(item) { %>
            <div class="order-item-mini">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="order-item-mini-image" onerror="this.src='https://picsum.photos/60/60'">
              <div class="order-item-mini-info"><div class="order-item-mini-name"><%= item.name %></div><div class="order-item-mini-qty">Qty: <%= item.quantity %></div></div>
              <div class="order-item-mini-price">LKR <%= (item.price * item.quantity).toFixed(2) %></div>
            </div>
          <% }) %>
        </div>
        <div class="order-totals">
          <div class="order-total-row"><span>Subtotal</span><span>LKR <%= subtotal %></span></div>
          <div class="order-total-row"><span>Delivery</span><span><%= parseFloat(shipping) === 0 ? 'FREE' : 'LKR ' + shipping %></span></div>
          <% if (typeof couponDiscount !== 'undefined' && parseFloat(couponDiscount) > 0) { %>
            <div class="order-total-row" style="color: var(--success);"><span>Coupon (<%= appliedCoupon.code %>)</span><span>-LKR <%= couponDiscount %></span></div>
          <% } %>
          <div class="order-total-row grand-total"><span>Total</span><span>LKR <%= total %></span></div>
        </div>
        
        <button type="button" id="placeOrderBtn" onclick="placeOrder()" style="width: 100%; margin-top: 18px; padding: 14px 28px; background: var(--primary-gradient); color: #FFFFFF; border: none; border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; transition: all 0.2s ease; box-shadow: 0 4px 16px rgba(0,102,255,0.25);">
          <i class="fas fa-check-circle"></i> Place Order
        </button>
        <div id="orderMessage" style="text-align: center; margin-top: 12px; font-size: 0.85rem;"></div>
      </div>
      
    </div>
  </div>
</section>

<script>
function updateFileName() {
  var fileInput = document.getElementById('paymentReceipt');
  var fileName = document.getElementById('file-name');
  var uploadBtn = document.getElementById('uploadBtn');
  if (fileInput.files.length > 0) {
    fileName.textContent = fileInput.files[0].name;
    uploadBtn.classList.add('has-file');
    uploadBtn.innerHTML = '<i class="fas fa-check-circle"></i> File Selected';
  } else {
    fileName.textContent = '';
    uploadBtn.classList.remove('has-file');
    uploadBtn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Choose File';
  }
}

function togglePaymentMethod() {
  var method = document.querySelector('input[name="paymentMethod"]:checked').value;
  var bankDetails = document.getElementById('bankDetails');
  var codLabel = document.getElementById('codLabel');
  var bankLabel = document.getElementById('bankLabel');
  if (method === 'bank_transfer') {
    bankDetails.style.display = 'block';
    bankLabel.style.borderColor = 'var(--primary)';
    codLabel.style.borderColor = 'var(--border-color)';
  } else {
    bankDetails.style.display = 'none';
    codLabel.style.borderColor = 'var(--primary)';
    bankLabel.style.borderColor = 'var(--border-color)';
  }
}

function placeOrder() {
  var firstName = document.getElementById('firstName').value.trim();
  var lastName = document.getElementById('lastName').value.trim();
  var email = document.getElementById('email').value.trim();
  var street = document.getElementById('address').value.trim();
  var city = document.getElementById('city').value.trim();
  var state = document.getElementById('state').value.trim();
  var zip = document.getElementById('zip').value.trim();
  var paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
  
  if (!firstName || !lastName || !email || !street || !city || !state) {
    alert('Please fill in all required address fields.');
    return;
  }
  
  if (paymentMethod === 'bank_transfer') {
    var receiptFile = document.getElementById('paymentReceipt').files[0];
    if (!receiptFile) {
      alert('Please upload your payment receipt.');
      return;
    }
  }
  
  var formData = new FormData();
  formData.append('firstName', firstName);
  formData.append('lastName', lastName);
  formData.append('email', email);
  formData.append('phone', document.getElementById('phone').value.trim());
  formData.append('street', street);
  formData.append('city', city);
  formData.append('state', state);
  formData.append('zipCode', zip);
  formData.append('country', 'Sri Lanka');
  formData.append('paymentMethod', paymentMethod);
  
  if (paymentMethod === 'bank_transfer') {
    formData.append('paymentReceipt', document.getElementById('paymentReceipt').files[0]);
  }
  
  document.getElementById('placeOrderBtn').disabled = true;
  document.getElementById('placeOrderBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
  document.getElementById('orderMessage').innerHTML = '';
  
  fetch('/cart/place-order', {
    method: 'POST',
    body: formData
  })
  .then(function(res) { return res.json(); })
  .then(function(result) {
    if (result.success) {
      window.location.href = '/cart/order-confirmation/' + result.orderId;
    } else {
      document.getElementById('orderMessage').innerHTML = '<span style="color: var(--error);">' + (result.error || 'Something went wrong') + '</span>';
      document.getElementById('placeOrderBtn').disabled = false;
      document.getElementById('placeOrderBtn').innerHTML = '<i class="fas fa-check-circle"></i> Place Order';
    }
  })
  .catch(function() {
    document.getElementById('orderMessage').innerHTML = '<span style="color: var(--error);">Network error. Please try again.</span>';
    document.getElementById('placeOrderBtn').disabled = false;
    document.getElementById('placeOrderBtn').innerHTML = '<i class="fas fa-check-circle"></i> Place Order';
  });
}
</script>

<%- include('partials/footer') %>