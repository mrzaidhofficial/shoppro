<%- include('partials/header') %>

<style>
  .checkout-section-page { padding: 56px 0; background: var(--bg-card); min-height: 100vh; }
  .checkout-layout { display: grid; grid-template-columns: 1fr 420px; gap: 36px; align-items: start; }
  
  .checkout-form-card { 
    background: var(--bg-card); 
    border: 1px solid var(--border-color); 
    border-radius: var(--radius-xl); 
    padding: 36px; 
    box-shadow: var(--shadow-sm); 
  }
  .checkout-section-title { 
    font-family: var(--font-display); 
    font-size: 1.1rem; 
    font-weight: 700; 
    color: var(--text-primary); 
    margin-bottom: 22px; 
    padding-bottom: 14px; 
    border-bottom: 1px solid var(--border-color); 
  }
  
  .form-group { margin-bottom: 18px; }
  .form-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 7px; }
  .form-input, .form-select { 
    width: 100%; 
    padding: 15px 18px; 
    border: 2px solid var(--border-color); 
    border-radius: var(--radius); 
    font-size: 0.92rem; 
    font-family: var(--font-primary); 
    color: var(--text-body); 
    background: var(--bg-input); 
    outline: none; 
    transition: var(--transition-fast); 
  }
  .form-input:focus, .form-select:focus { 
    border-color: var(--primary); 
    background: var(--bg-card); 
    box-shadow: 0 0 0 4px rgba(0,102,255,0.06); 
  }
  .form-select option {
    background: var(--bg-card);
    color: var(--text-body);
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  
  .order-summary-card { 
    background: var(--bg-card); 
    border: 1px solid var(--border-color); 
    border-radius: var(--radius-xl); 
    padding: 30px; 
    position: sticky; 
    top: 100px; 
    box-shadow: var(--shadow-sm); 
  }
  .order-summary-title { 
    font-family: var(--font-display); 
    font-size: 1.1rem; 
    font-weight: 700; 
    margin-bottom: 20px; 
    padding-bottom: 14px; 
    border-bottom: 1px solid var(--border-color); 
    color: var(--text-primary); 
  }
  .order-items-list { max-height: 300px; overflow-y: auto; margin-bottom: 18px; }
  .order-item-mini { display: flex; gap: 14px; padding: 13px 0; border-bottom: 1px solid var(--border-color-light); }
  .order-item-mini:last-child { border-bottom: none; }
  .order-item-mini-image { 
    width: 60px; 
    height: 60px; 
    border-radius: var(--radius); 
    object-fit: cover; 
    flex-shrink: 0; 
    background: var(--bg-card-alt);
  }
  .order-item-mini-info { flex: 1; min-width: 0; }
  .order-item-mini-name { font-size: 0.85rem; font-weight: 500; color: var(--text-primary); }
  .order-item-mini-qty { font-size: 0.75rem; color: var(--text-muted); }
  .order-item-mini-price { font-weight: 600; font-size: 0.88rem; color: var(--text-primary); white-space: nowrap; }
  .order-totals { border-top: 1px solid var(--border-color); padding-top: 16px; }
  .order-total-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 0.88rem; color: var(--text-body); }
  .order-total-row.grand-total { 
    font-size: 1.2rem; 
    font-weight: 700; 
    color: var(--text-primary); 
    border-top: 1px solid var(--border-color); 
    padding-top: 16px; 
    margin-top: 12px; 
  }
  
  /* PayPal Container - Always light background for readability */
  .paypal-container-wrap {
    margin-top: 22px;
    padding: 20px;
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: var(--radius-lg);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .paypal-container-wrap .paypal-heading {
    text-align: center;
    color: #334155;
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #E2E8F0;
  }
  .paypal-container-wrap .paypal-heading i {
    color: #0070BA;
    margin: 0 4px;
  }
  #paypal-button-container {
    max-width: 100%;
    margin: 0 auto;
    background: #FFFFFF;
  }
  
  /* Force PayPal iframe to have white background and visible text */
  #paypal-button-container iframe {
    background: #FFFFFF !important;
  }
  
  .secure-checkout-badge { 
    display: flex; 
    align-items: center; 
    gap: 12px; 
    margin-top: 18px; 
    padding: 16px 20px; 
    background: var(--success-bg); 
    border-radius: var(--radius-lg); 
    font-size: 0.85rem; 
    color: var(--success); 
    font-weight: 500; 
  }
  .secure-checkout-badge i { color: var(--success); font-size: 1.4rem; }
  
  /* Shipping info note */
  .shipping-info-note {
    color: var(--text-muted);
    font-size: 0.82rem;
    text-align: center;
    margin: 0;
    padding: 8px 0;
  }
  .shipping-info-note i {
    margin-right: 4px;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .order-summary-card { position: static; }
    .checkout-form-card { padding: 24px; }
  }
  @media (max-width: 500px) {
    .form-row { grid-template-columns: 1fr; }
    .checkout-form-card { padding: 18px; }
    .order-summary-card { padding: 20px; }
    .paypal-container-wrap { padding: 14px; }
  }
</style>

<section class="checkout-section-page">
  <div class="container">
    <h1 style="font-family: var(--font-display); font-size: 2.2rem; margin-bottom: 36px; color: var(--text-primary); text-align: center;">Secure Checkout</h1>

    <div class="checkout-layout">
      
      <div class="checkout-form-card">
        <h3 class="checkout-section-title">
          <i class="fas fa-shipping-fast" style="color: var(--primary); margin-right: 8px;"></i>
          Shipping Address
        </h3>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">First Name *</label>
            <input type="text" class="form-input" id="firstName" required placeholder="John">
          </div>
          <div class="form-group">
            <label class="form-label">Last Name *</label>
            <input type="text" class="form-input" id="lastName" required placeholder="Doe">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Email Address *</label>
          <input type="email" class="form-input" id="email" required placeholder="john@example.com">
        </div>
        <div class="form-group">
          <label class="form-label">Street Address *</label>
          <input type="text" class="form-input" id="address" required placeholder="123 Main Street, Apt 4B">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">City *</label>
            <input type="text" class="form-input" id="city" required placeholder="New York">
          </div>
          <div class="form-group">
            <label class="form-label">State/Province *</label>
            <input type="text" class="form-input" id="state" required placeholder="NY">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">ZIP/Postal Code *</label>
            <input type="text" class="form-input" id="zip" required placeholder="10001">
          </div>
          <div class="form-group">
            <label class="form-label">Country *</label>
            <select class="form-select" id="country" required>
              <option value="">Select Country</option>
              <option value="US">United States</option>
              <option value="CA">Canada</option>
              <option value="GB">United Kingdom</option>
              <option value="AU">Australia</option>
              <option value="DE">Germany</option>
              <option value="FR">France</option>
              <option value="IT">Italy</option>
              <option value="ES">Spain</option>
              <option value="JP">Japan</option>
              <option value="IN">India</option>
              <option value="LK">Sri Lanka</option>
              <option value="BR">Brazil</option>
              <option value="MX">Mexico</option>
              <option value="NL">Netherlands</option>
              <option value="SE">Sweden</option>
              <option value="NO">Norway</option>
              <option value="DK">Denmark</option>
              <option value="FI">Finland</option>
              <option value="CH">Switzerland</option>
              <option value="AT">Austria</option>
              <option value="BE">Belgium</option>
              <option value="PT">Portugal</option>
              <option value="IE">Ireland</option>
              <option value="NZ">New Zealand</option>
              <option value="SG">Singapore</option>
              <option value="MY">Malaysia</option>
              <option value="PH">Philippines</option>
              <option value="TH">Thailand</option>
              <option value="VN">Vietnam</option>
              <option value="ID">Indonesia</option>
              <option value="KR">South Korea</option>
              <option value="AE">United Arab Emirates</option>
              <option value="SA">Saudi Arabia</option>
              <option value="ZA">South Africa</option>
              <option value="EG">Egypt</option>
              <option value="AR">Argentina</option>
              <option value="CL">Chile</option>
              <option value="CO">Colombia</option>
              <option value="PE">Peru</option>
              <option value="PL">Poland</option>
              <option value="RO">Romania</option>
              <option value="GR">Greece</option>
              <option value="TR">Turkey</option>
              <option value="HK">Hong Kong</option>
              <option value="TW">Taiwan</option>
              <option value="BD">Bangladesh</option>
              <option value="PK">Pakistan</option>
              <option value="NP">Nepal</option>
              <option value="MV">Maldives</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>
        <p class="shipping-info-note">
          <i class="fas fa-lock"></i> Your information is encrypted and secure
        </p>
      </div>

      <div class="order-summary-card">
        <h3 class="order-summary-title">Your Order</h3>
        <div class="order-items-list">
          <% cartItems.forEach(function(item) { %>
            <div class="order-item-mini">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="order-item-mini-image" onerror="this.src='https://picsum.photos/60/60'">
              <div class="order-item-mini-info">
                <div class="order-item-mini-name"><%= item.name %></div>
                <div class="order-item-mini-qty">Qty: <%= item.quantity %></div>
              </div>
              <div class="order-item-mini-price">$<%= (item.price * item.quantity).toFixed(2) %></div>
            </div>
          <% }) %>
        </div>
        <div class="order-totals">
          <div class="order-total-row"><span>Subtotal</span><span>$<%= subtotal %></span></div>
          <div class="order-total-row"><span>Shipping</span><span><%= parseFloat(shipping) === 0 ? 'FREE' : '$' + shipping %></span></div>
          <% if (typeof couponDiscount !== 'undefined' && parseFloat(couponDiscount) > 0) { %>
            <div class="order-total-row" style="color:var(--success);"><span>Coupon (<%= appliedCoupon.code %>)</span><span>-$<%= couponDiscount %></span></div>
          <% } %>
          <div class="order-total-row grand-total"><span>Total</span><span>$<%= total %></span></div>
          <div style="font-size:0.75rem;color:var(--text-muted);text-align:right;margin-top:4px;">Tax/VAT included</div>
        </div>
        
        <!-- PayPal Payment Section -->
        <div class="paypal-container-wrap">
          <div class="paypal-heading">
            Complete your payment securely with <i class="fab fa-cc-paypal"></i> <strong>PayPal</strong>
          </div>
          <% if (typeof paypalConfigured !== 'undefined' && paypalConfigured) { %>
            <div id="paypal-button-container"></div>
          <% } else { %>
            <div style="text-align:center;padding:24px;background:#F8FAFC;border-radius:12px;border:2px dashed #E2E8F0;">
              <p style="color:#64748B;font-size:0.88rem;margin:0;">Payment processing will be available soon.</p>
            </div>
          <% } %>
        </div>
        
        <div class="secure-checkout-badge">
          <i class="fas fa-shield-alt"></i>
          <span>Payments processed securely by PayPal. We never store your card details.</span>
        </div>
      </div>
      
    </div>
  </div>
</section>

<!-- PayPal SDK -->
<script src="https://www.paypal.com/sdk/js?client-id=<%= typeof paypalConfigured !== 'undefined' && paypalConfigured ? process.env.PAYPAL_CLIENT_ID : 'test' %>&currency=USD" data-namespace="paypal_sdk"></script>

<script>
<% if (typeof paypalConfigured !== 'undefined' && paypalConfigured) { %>
paypal_sdk.Buttons({
  style: { 
    shape: 'pill', 
    color: 'gold', 
    layout: 'vertical', 
    label: 'paypal',
    tagline: false
  },
  createOrder: function() {
    var firstName = document.getElementById('firstName').value.trim();
    var lastName = document.getElementById('lastName').value.trim();
    var email = document.getElementById('email').value.trim();
    var address = document.getElementById('address').value.trim();
    var city = document.getElementById('city').value.trim();
    var state = document.getElementById('state').value.trim();
    var zip = document.getElementById('zip').value.trim();
    var country = document.getElementById('country').value;
    
    if (!firstName || !lastName || !email || !address || !city || !state || !zip || !country) {
      alert('Please fill in all shipping address fields before proceeding to payment.');
      return;
    }
    
    return fetch('/cart/paypal/create-order', { 
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' } 
    })
    .then(function(res) { return res.json(); })
    .then(function(data) { 
      if (data.error) { 
        alert(data.error); 
        throw new Error(data.error); 
      } 
      return data.id; 
    });
  },
  onApprove: function(data) {
    var countrySelect = document.getElementById('country');
    var countryText = countrySelect.options[countrySelect.selectedIndex].text;
    
    return fetch('/cart/paypal/capture-payment', {
      method: 'POST', 
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ 
        orderID: data.orderID, 
        shippingAddress: { 
          firstName: document.getElementById('firstName').value,
          lastName: document.getElementById('lastName').value,
          email: document.getElementById('email').value,
          street: document.getElementById('address').value,
          city: document.getElementById('city').value,
          state: document.getElementById('state').value,
          zipCode: document.getElementById('zip').value,
          country: countryText
        } 
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(result) { 
      if (result.success) { 
        window.location.href = '/cart/order-confirmation/' + result.orderId; 
      } else { 
        alert('Payment failed: ' + (result.error || 'Unknown error')); 
      } 
    });
  },
  onError: function(err) { 
    console.error('PayPal error:', err); 
    alert('Payment error. Please try again.'); 
  }
}).render('#paypal-button-container');

// Force PayPal container to maintain white background
setTimeout(function() {
  var paypalContainer = document.getElementById('paypal-button-container');
  if (paypalContainer) {
    paypalContainer.style.backgroundColor = '#FFFFFF';
    paypalContainer.style.color = '#000000';
  }
  // Force all iframes in PayPal container to have white background
  var iframes = document.querySelectorAll('#paypal-button-container iframe');
  iframes.forEach(function(iframe) {
    iframe.style.backgroundColor = '#FFFFFF';
  });
}, 1000);
<% } %>
</script>

<%- include('partials/footer') %>