<%- include('partials/header') %>

<section class="checkout-section-page">
  <div class="container">
    <h1 style="font-family: var(--font-display); font-size: 2.2rem; margin-bottom: 36px; color: var(--gray-900); text-align: center;">Secure Checkout</h1>

    <div class="checkout-layout">
      <div class="checkout-form-card">
        <form id="checkoutForm">
          <div class="checkout-form-section">
            <h3 class="checkout-section-title">Shipping Address</h3>
            <div class="form-row">
              <div class="form-group"><label class="form-label">First Name *</label><input type="text" class="form-input" id="firstName" required placeholder="John"></div>
              <div class="form-group"><label class="form-label">Last Name *</label><input type="text" class="form-input" id="lastName" required placeholder="Doe"></div>
            </div>
            <div class="form-group"><label class="form-label">Email Address *</label><input type="email" class="form-input" id="email" required placeholder="john@example.com"></div>
            <div class="form-group"><label class="form-label">Street Address *</label><input type="text" class="form-input" id="address" required placeholder="123 Main Street, Apt 4B"></div>
            <div class="form-row">
              <div class="form-group"><label class="form-label">City *</label><input type="text" class="form-input" id="city" required placeholder="New York"></div>
              <div class="form-group"><label class="form-label">State/Province *</label><input type="text" class="form-input" id="state" required placeholder="NY"></div>
            </div>
            <div class="form-row">
              <div class="form-group"><label class="form-label">ZIP/Postal Code *</label><input type="text" class="form-input" id="zip" required placeholder="10001"></div>
              <div class="form-group">
                <label class="form-label">Country *</label>
                <select class="form-input form-select" id="country" required>
                  <option value="">Select Country</option>
                  <option value="US">United States</option>
                  <option value="CA">Canada</option>
                  <option value="GB">United Kingdom</option>
                  <option value="AU">Australia</option>
                  <option value="DE">Germany</option>
                  <option value="FR">France</option>
                  <option value="IT">Italy</option>
                  <option value="ES">Spain</option>
                  <option value="JP">Japan</option>
                  <option value="CN">China</option>
                  <option value="IN">India</option>
                  <option value="LK">Sri Lanka</option>
                  <option value="BR">Brazil</option>
                  <option value="MX">Mexico</option>
                  <option value="NL">Netherlands</option>
                  <option value="SE">Sweden</option>
                  <option value="NO">Norway</option>
                  <option value="DK">Denmark</option>
                  <option value="FI">Finland</option>
                  <option value="CH">Switzerland</option>
                  <option value="AT">Austria</option>
                  <option value="BE">Belgium</option>
                  <option value="PT">Portugal</option>
                  <option value="IE">Ireland</option>
                  <option value="NZ">New Zealand</option>
                  <option value="SG">Singapore</option>
                  <option value="MY">Malaysia</option>
                  <option value="PH">Philippines</option>
                  <option value="TH">Thailand</option>
                  <option value="VN">Vietnam</option>
                  <option value="ID">Indonesia</option>
                  <option value="KR">South Korea</option>
                  <option value="AE">United Arab Emirates</option>
                  <option value="SA">Saudi Arabia</option>
                  <option value="QA">Qatar</option>
                  <option value="KW">Kuwait</option>
                  <option value="OM">Oman</option>
                  <option value="BH">Bahrain</option>
                  <option value="ZA">South Africa</option>
                  <option value="NG">Nigeria</option>
                  <option value="KE">Kenya</option>
                  <option value="EG">Egypt</option>
                  <option value="MA">Morocco</option>
                  <option value="AR">Argentina</option>
                  <option value="CL">Chile</option>
                  <option value="CO">Colombia</option>
                  <option value="PE">Peru</option>
                  <option value="PL">Poland</option>
                  <option value="RO">Romania</option>
                  <option value="CZ">Czech Republic</option>
                  <option value="GR">Greece</option>
                  <option value="TR">Turkey</option>
                  <option value="RU">Russia</option>
                  <option value="UA">Ukraine</option>
                  <option value="HK">Hong Kong</option>
                  <option value="TW">Taiwan</option>
                  <option value="BD">Bangladesh</option>
                  <option value="PK">Pakistan</option>
                  <option value="NP">Nepal</option>
                  <option value="MV">Maldives</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>
          </div>

          <div class="checkout-form-section">
            <h3 class="checkout-section-title">Payment Method</h3>
            <div class="payment-methods-list" id="paymentMethods">
              <div class="payment-method-option selected" data-method="visa"><i class="fab fa-cc-visa" style="font-size:2.5rem;"></i><span>Visa</span></div>
              <div class="payment-method-option" data-method="mastercard"><i class="fab fa-cc-mastercard" style="font-size:2.5rem;"></i><span>Mastercard</span></div>
              <div class="payment-method-option" data-method="amex"><i class="fab fa-cc-amex" style="font-size:2.5rem;"></i><span>Amex</span></div>
              <div class="payment-method-option" data-method="discover"><i class="fab fa-cc-discover" style="font-size:2.5rem;"></i><span>Discover</span></div>
              <div class="payment-method-option" data-method="jcb"><i class="fab fa-cc-jcb" style="font-size:2.5rem;"></i><span>JCB</span></div>
              <div class="payment-method-option" data-method="diners-club"><i class="fab fa-cc-diners-club" style="font-size:2.5rem;"></i><span>Diners Club</span></div>
              <div class="payment-method-option" data-method="paypal"><i class="fab fa-cc-paypal" style="font-size:2.5rem;"></i><span>PayPal</span></div>
              <div class="payment-method-option" data-method="apple"><i class="fab fa-cc-apple-pay" style="font-size:2.5rem;"></i><span>Apple Pay</span></div>
              <div class="payment-method-option" data-method="google"><i class="fab fa-google-pay" style="font-size:2.5rem;"></i><span>Google Pay</span></div>
            </div>
            <div id="cardDetails">
              <div class="form-group"><label class="form-label">Card Number *</label><input type="text" class="form-input" id="cardNumber" required placeholder="1234 5678 9012 3456"></div>
              <div class="form-row">
                <div class="form-group"><label class="form-label">Expiry *</label><input type="text" class="form-input" id="expiry" required placeholder="MM/YY"></div>
                <div class="form-group"><label class="form-label">CVV *</label><input type="text" class="form-input" id="cvv" required placeholder="123"></div>
              </div>
            </div>
          </div>

          <div style="text-align: center; margin-top: 10px;">
            <button type="submit" class="checkout-place-order-btn"><i class="fas fa-lock"></i> Place Order — $<%= total %></button>
          </div>
        </form>
      </div>

      <div class="order-summary-card">
        <h3 class="order-summary-title">Your Order</h3>
        <div class="order-items-list">
          <% cartItems.forEach(function(item) { %>
            <div class="order-item-mini">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="order-item-mini-image" onerror="this.src='https://picsum.photos/60/60'">
              <div class="order-item-mini-info"><div class="order-item-mini-name"><%= item.name %></div><div class="order-item-mini-qty">Qty: <%= item.quantity %></div></div>
              <div class="order-item-mini-price">$<%= (item.price * item.quantity).toFixed(2) %></div>
            </div>
          <% }) %>
        </div>
        <div class="order-totals">
          <div class="order-total-row"><span>Subtotal</span><span>$<%= subtotal %></span></div>
          <div class="order-total-row"><span>Shipping</span><span><%= parseFloat(shipping) === 0 ? 'FREE' : '$' + shipping %></span></div>
          <div class="order-total-row"><span>Tax (8%)</span><span>$<%= tax %></span></div>
          <% if (typeof couponDiscount !== 'undefined' && parseFloat(couponDiscount) > 0) { %>
            <div class="order-total-row" style="color:var(--success);"><span>Coupon (<%= appliedCoupon.code %>)</span><span>-$<%= couponDiscount %></span></div>
          <% } %>
          <div class="order-total-row grand-total"><span>Total</span><span>$<%= total %></span></div>
        </div>
        <div class="secure-checkout-badge"><i class="fas fa-shield-alt"></i><span>Secured by 256-bit SSL Encryption</span></div>
      </div>
    </div>
  </div>
</section>

<script>
document.querySelectorAll('.payment-method-option').forEach(function(opt) {
  opt.addEventListener('click', function() {
    document.querySelectorAll('.payment-method-option').forEach(function(o) { o.classList.remove('selected'); });
    this.classList.add('selected');
    var method = this.dataset.method;
    document.getElementById('cardDetails').style.display = (method === 'paypal' || method === 'apple' || method === 'google') ? 'none' : 'block';
  });
});
document.getElementById('cardNumber').addEventListener('input', function(e) {
  var val = this.value.replace(/\s/g, '').replace(/[^0-9]/g, '').substr(0, 16);
  this.value = val.match(/.{1,4}/g) ? val.match(/.{1,4}/g).join(' ') : '';
});
document.getElementById('expiry').addEventListener('input', function(e) {
  var val = this.value.replace(/[^0-9]/g, '').substr(0, 4);
  this.value = val.length > 2 ? val.substr(0,2) + '/' + val.substr(2) : val;
});
document.getElementById('cvv').addEventListener('input', function(e) { this.value = this.value.replace(/[^0-9]/g, '').substr(0, 4); });
document.getElementById('checkoutForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var submitBtn = this.querySelector('.checkout-place-order-btn');
  var originalHTML = submitBtn.innerHTML;
  submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
  submitBtn.disabled = true;
  var selectedMethod = document.querySelector('.payment-method-option.selected').dataset.method;
  var countrySelect = document.getElementById('country');
  var countryName = countrySelect.options[countrySelect.selectedIndex].text;
  var shippingData = { shippingAddress: { firstName: document.getElementById('firstName').value, lastName: document.getElementById('lastName').value, email: document.getElementById('email').value, street: document.getElementById('address').value, city: document.getElementById('city').value, state: document.getElementById('state').value, zipCode: document.getElementById('zip').value, country: countryName }, paymentMethod: selectedMethod };
  fetch('/cart/checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(shippingData) })
  .then(function(res) { return res.json(); })
  .then(function(data) { if (data.success) { window.location.href = '/cart/order-confirmation/' + data.orderId; } else { alert('Error: ' + (data.error || 'Checkout failed')); submitBtn.innerHTML = originalHTML; submitBtn.disabled = false; } })
  .catch(function(err) { console.error('Checkout error:', err); alert('An error occurred. Please try again.'); submitBtn.innerHTML = originalHTML; submitBtn.disabled = false; });
});
</script>

<%- include('partials/footer') %>