<%- include('partials/header') %>

<style>
  .upload-btn-wrapper {
    position: relative;
    overflow: hidden;
    display: inline-block;
    cursor: pointer;
    width: 100%;
    margin-top: 6px;
  }
  .upload-btn-wrapper input[type="file"] {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  .upload-btn-custom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 18px;
    background: var(--bg-card-alt);
    border: 2px dashed var(--border-color);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    font-family: var(--font-primary);
    transition: all 0.2s ease;
    text-align: center;
    cursor: pointer;
  }
  .upload-btn-custom:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-light);
  }
  .upload-btn-custom.has-file {
    border-color: var(--success);
    color: var(--success);
    background: var(--success-bg);
    border-style: solid;
  }
  #file-name {
    display: block;
    margin-top: 6px;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
  }
  .required-star { color: var(--error); font-weight: 700; }
  
  .whatsapp-note {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 8px 12px;
    background: rgba(37, 211, 102, 0.08);
    border: 1px solid rgba(37, 211, 102, 0.2);
    border-radius: var(--radius);
    font-size: 0.75rem;
    color: #059669;
    font-weight: 500;
  }
  [data-theme="dark"] .whatsapp-note {
    background: rgba(52, 211, 153, 0.1);
    border-color: rgba(52, 211, 153, 0.2);
    color: #34D399;
  }
  
  /* Payment Method Cards — spaced out */
  .payment-method-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    background: var(--bg-card-alt);
    border: 2px solid var(--border-color);
    border-radius: var(--radius-lg);
    cursor: pointer;
    margin-bottom: 14px;
    transition: all 0.25s ease;
    position: relative;
  }
  .payment-method-card:last-child {
    margin-bottom: 0;
  }
  .payment-method-card:hover {
    border-color: var(--primary);
    background: var(--bg-card);
    box-shadow: var(--shadow-sm);
  }
  .payment-method-card.selected {
    border-color: var(--primary);
    background: var(--primary-light);
    box-shadow: 0 0 0 4px rgba(0,102,255,0.06);
  }
  .payment-method-card input[type="radio"] {
    width: 20px;
    height: 20px;
    accent-color: var(--primary);
    cursor: pointer;
    flex-shrink: 0;
  }
  .payment-method-icon {
    width: 42px;
    height: 42px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: all 0.25s ease;
  }
  .payment-method-icon.cod { background: rgba(16,185,129,0.1); color: #059669; }
  .payment-method-icon.card { background: rgba(59,130,246,0.1); color: #3B82F6; }
  .payment-method-icon.bank { background: rgba(124,58,237,0.1); color: #7C3AED; }
  [data-theme="dark"] .payment-method-icon.cod { background: rgba(52,211,153,0.15); color: #34D399; }
  [data-theme="dark"] .payment-method-icon.card { background: rgba(59,130,246,0.15); color: #60A5FA; }
  [data-theme="dark"] .payment-method-icon.bank { background: rgba(124,58,237,0.15); color: #A78BFA; }
  
  .payment-method-info { flex: 1; min-width: 0; }
  .payment-method-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.92rem;
    margin-bottom: 2px;
  }
  .payment-method-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
  
  .payment-detail-panel {
    display: none;
    background: var(--bg-card-alt);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    margin-bottom: 16px;
    animation: panelSlideIn 0.3s ease;
  }
  .payment-detail-panel.active { display: block; }
  @keyframes panelSlideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .panel-title {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 0.9rem;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .panel-title i { font-size: 0.95rem; }
  .panel-title i.blue { color: #3B82F6; }
  .panel-title i.purple { color: #7C3AED; }
  [data-theme="dark"] .panel-title i.blue { color: #60A5FA; }
  [data-theme="dark"] .panel-title i.purple { color: #A78BFA; }
  
  .bank-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    font-size: 0.85rem;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-color);
  }
  .bank-detail-grid div span:first-child { color: var(--text-muted); }
  .bank-detail-grid div strong { color: var(--text-primary); }
  
  .card-payment-desc {
    color: var(--text-body);
    font-size: 0.85rem;
    line-height: 1.65;
    margin-bottom: 12px;
  }
  
  .delivery-channels {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 10px;
  }
  .delivery-channel {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.84rem;
    color: var(--text-secondary);
    padding: 8px 12px;
    background: var(--bg-card);
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
    transition: all 0.2s ease;
  }
  .delivery-channel:hover {
    border-color: var(--primary);
    transform: translateX(4px);
  }
  .delivery-channel i {
    width: 22px;
    text-align: center;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .delivery-channel i.fa-envelope { color: #EA580C; }
  .delivery-channel i.fa-comment-sms { color: #2563EB; }
  .delivery-channel i.fa-whatsapp { color: #25D366; }
  
  .security-footer {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid rgba(59,130,246,0.15);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .security-footer i { color: var(--success); }
  
  .form-all-required-note {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(239,68,68,0.05);
    border: 1px solid rgba(239,68,68,0.12);
    border-radius: var(--radius);
    font-size: 0.76rem;
    color: var(--text-muted);
    margin-bottom: 22px;
  }
  .form-all-required-note i { color: var(--error); font-size: 0.7rem; }
  
  @media (max-width: 500px) {
    .payment-method-card { padding: 14px 16px; gap: 10px; }
    .payment-method-icon { width: 36px; height: 36px; font-size: 0.95rem; }
    .payment-method-name { font-size: 0.85rem; }
    .payment-method-desc { font-size: 0.73rem; }
    .payment-detail-panel { padding: 16px; }
    .bank-detail-grid { grid-template-columns: 1fr; }
    .delivery-channel { font-size: 0.78rem; padding: 6px 10px; }
  }
</style>

<section class="checkout-section-page">
  <div class="container">
    <h1 style="font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); margin-bottom: 36px; color: var(--text-primary); text-align: center;">Secure Checkout</h1>

    <div class="checkout-layout">
      
      <div class="checkout-form-card">
        
        <!-- Delivery Address -->
        <h3 class="checkout-section-title">
          <i class="fas fa-shipping-fast" style="color: var(--primary); margin-right: 8px;"></i>
          Delivery Address
        </h3>
        
        <div class="form-all-required-note">
          <i class="fas fa-asterisk"></i>
          <span>All fields are required to place your order</span>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">First Name <span class="required-star">*</span></label>
            <input type="text" class="form-input" id="firstName" name="firstName" required placeholder="John">
          </div>
          <div class="form-group">
            <label class="form-label">Last Name <span class="required-star">*</span></label>
            <input type="text" class="form-input" id="lastName" name="lastName" required placeholder="Doe">
          </div>
        </div>
        
        <div class="form-group">
          <label class="form-label">Email Address <span class="required-star">*</span></label>
          <input type="email" class="form-input" id="email" name="email" required placeholder="john@example.com">
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Phone Number <span class="required-star">*</span></label>
            <input type="tel" class="form-input" id="phone" name="phone" required placeholder="07XXXXXXXX">
          </div>
          <div class="form-group">
            <label class="form-label">WhatsApp Number <span class="required-star">*</span></label>
            <input type="tel" class="form-input" id="whatsapp" name="whatsapp" required placeholder="07XXXXXXXX">
            <div class="whatsapp-note">
              <i class="fab fa-whatsapp"></i>
              <span>Enter even if same as phone number above</span>
            </div>
          </div>
        </div>
        
        <div class="form-group">
          <label class="form-label">Street Address <span class="required-star">*</span></label>
          <input type="text" class="form-input" id="address" name="street" required placeholder="123 Main Street, Apt 4B">
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">City <span class="required-star">*</span></label>
            <input type="text" class="form-input" id="city" name="city" required placeholder="Colombo">
          </div>
          <div class="form-group">
            <label class="form-label">District <span class="required-star">*</span></label>
            <select class="form-input form-select" id="state" name="state" required>
              <option value="">Select District</option>
              <option value="Colombo">Colombo</option>
              <option value="Gampaha">Gampaha</option>
              <option value="Kalutara">Kalutara</option>
              <option value="Kandy">Kandy</option>
              <option value="Matale">Matale</option>
              <option value="Nuwara Eliya">Nuwara Eliya</option>
              <option value="Galle">Galle</option>
              <option value="Matara">Matara</option>
              <option value="Hambantota">Hambantota</option>
              <option value="Jaffna">Jaffna</option>
              <option value="Kilinochchi">Kilinochchi</option>
              <option value="Mannar">Mannar</option>
              <option value="Vavuniya">Vavuniya</option>
              <option value="Mullaitivu">Mullaitivu</option>
              <option value="Batticaloa">Batticaloa</option>
              <option value="Ampara">Ampara</option>
              <option value="Trincomalee">Trincomalee</option>
              <option value="Kurunegala">Kurunegala</option>
              <option value="Puttalam">Puttalam</option>
              <option value="Anuradhapura">Anuradhapura</option>
              <option value="Polonnaruwa">Polonnaruwa</option>
              <option value="Badulla">Badulla</option>
              <option value="Moneragala">Moneragala</option>
              <option value="Ratnapura">Ratnapura</option>
              <option value="Kegalle">Kegalle</option>
            </select>
          </div>
        </div>
        
        <div class="form-group">
          <label class="form-label">Postal Code <span class="required-star">*</span></label>
          <input type="text" class="form-input" id="zip" name="zipCode" required placeholder="e.g. 00100">
        </div>
        <input type="hidden" name="country" value="Sri Lanka">

        <!-- Payment Method -->
        <h3 class="checkout-section-title" style="margin-top: 32px;">
          <i class="fas fa-credit-card" style="color: var(--primary); margin-right: 8px;"></i>
          Payment Method
        </h3>
        
        <!-- Cash on Delivery -->
        <label class="payment-method-card selected" id="codCard">
          <input type="radio" name="paymentMethod" value="cod" checked onchange="togglePaymentMethod()">
          <div class="payment-method-icon cod">
            <i class="fas fa-money-bill-wave"></i>
          </div>
          <div class="payment-method-info">
            <div class="payment-method-name">Cash on Delivery</div>
            <div class="payment-method-desc">Pay when you receive your order at your doorstep</div>
          </div>
        </label>
        
        <!-- Card Payment -->
        <label class="payment-method-card" id="cardCard">
          <input type="radio" name="paymentMethod" value="card_payment" onchange="togglePaymentMethod()">
          <div class="payment-method-icon card">
            <i class="fas fa-credit-card"></i>
          </div>
          <div class="payment-method-info">
            <div class="payment-method-name">Card Payment</div>
            <div class="payment-method-desc">Pay via secure payment link sent to you (Visa / Mastercard)</div>
          </div>
        </label>
        
        <!-- Bank Transfer -->
        <label class="payment-method-card" id="bankCard">
          <input type="radio" name="paymentMethod" value="bank_transfer" onchange="togglePaymentMethod()">
          <div class="payment-method-icon bank">
            <i class="fas fa-university"></i>
          </div>
          <div class="payment-method-info">
            <div class="payment-method-name">Bank Transfer</div>
            <div class="payment-method-desc">Transfer directly to our bank account & upload your receipt</div>
          </div>
        </label>

        <!-- Card Payment Detail Panel -->
        <div class="payment-detail-panel" id="cardPaymentInfo" style="margin-top: 14px;">
          <div class="panel-title">
            <i class="fas fa-credit-card blue"></i>
            Card Payment via HNB Accept
          </div>
          <p class="card-payment-desc">
            After placing your order, we will send a <strong>secure payment link</strong> through multiple channels. 
            You can pay using your Visa or Mastercard. <strong>No payment receipt upload is needed</strong> — just place your order and pay via the link we send you.
          </p>
          <div style="font-weight: 600; color: var(--text-primary); font-size: 0.82rem; margin-bottom: 8px;">
            <i class="fas fa-paper-plane" style="color: var(--primary); margin-right: 6px;"></i> Payment link will be sent to:
          </div>
          <div class="delivery-channels">
            <div class="delivery-channel">
              <i class="fas fa-envelope"></i>
              <span><strong>Email</strong> — to your email address</span>
            </div>
            <div class="delivery-channel">
              <i class="fas fa-comment-sms"></i>
              <span><strong>SMS</strong> — as a text message to your phone number</span>
            </div>
            <div class="delivery-channel">
              <i class="fab fa-whatsapp"></i>
              <span><strong>WhatsApp</strong> — to your WhatsApp number</span>
            </div>
          </div>
          <div class="security-footer">
            <i class="fas fa-shield-alt"></i>
            <span>Secured by HNB Accept — Sri Lanka's trusted payment gateway</span>
          </div>
        </div>

        <!-- Bank Transfer Detail Panel -->
        <div class="payment-detail-panel" id="bankDetails" style="margin-top: 14px;">
          <div class="panel-title">
            <i class="fas fa-university purple"></i>
            Bank Account Details
          </div>
          <div class="bank-detail-grid">
            <div><span style="color: var(--text-muted);">Bank:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankName || '—' %></strong></div>
            <div><span style="color: var(--text-muted);">Branch:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankBranch || '—' %></strong></div>
            <div><span style="color: var(--text-muted);">Account Name:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankAccountName || '—' %></strong></div>
            <div><span style="color: var(--text-muted);">Account Number:</span> <strong style="color: var(--text-primary);"><%= bankDetails.bankAccountNumber || '—' %></strong></div>
          </div>
          
          <div>
            <label class="form-label">Upload Payment Receipt <span class="required-star">*</span></label>
            <div class="upload-btn-wrapper">
              <button type="button" class="upload-btn-custom" id="uploadBtn">
                <i class="fas fa-cloud-upload-alt"></i> Choose File
              </button>
              <input type="file" name="paymentReceipt" id="paymentReceipt" accept="image/*,.pdf" onchange="updateFileName()">
            </div>
            <span id="file-name"></span>
            <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 4px;">Accepted: JPG, PNG, PDF. Max size: 5MB</div>
          </div>
        </div>

        <!-- Security Note -->
        <p style="color: var(--text-muted); font-size: 0.82rem; text-align: center; margin: 18px 0 0;">
          <i class="fas fa-lock" style="margin-right: 4px;"></i> Your information is encrypted and secure
        </p>
      </div>

      <!-- Order Summary -->
      <div class="order-summary-card">
        <h3 class="order-summary-title">Your Order</h3>
        <div class="order-items-list">
          <% cartItems.forEach(function(item) { %>
            <div class="order-item-mini">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="order-item-mini-image" onerror="this.src='https://picsum.photos/60/60'">
              <div class="order-item-mini-info">
                <div class="order-item-mini-name"><%= item.name %></div>
                <div class="order-item-mini-qty">Qty: <%= item.quantity %></div>
              </div>
              <div class="order-item-mini-price">LKR <%= (item.price * item.quantity).toFixed(2) %></div>
            </div>
          <% }) %>
        </div>
        <div class="order-totals">
          <div class="order-total-row"><span>Subtotal</span><span>LKR <%= subtotal %></span></div>
          <div class="order-total-row"><span>Delivery</span><span><%= parseFloat(shipping) === 0 ? 'FREE' : 'LKR ' + shipping %></span></div>
          <% if (typeof settings !== 'undefined' && settings.estimatedDelivery) { %>
            <div style="font-size:0.72rem;color:var(--text-muted);text-align:right;margin-top:-4px;margin-bottom:2px;">
              <i class="fas fa-truck"></i> Est. Delivery: <%= settings.estimatedDelivery %>
            </div>
          <% } %>
          <% if (typeof couponDiscount !== 'undefined' && parseFloat(couponDiscount) > 0) { %>
            <div class="order-total-row" style="color: var(--success);"><span>Coupon (<%= appliedCoupon.code %>)</span><span>-LKR <%= couponDiscount %></span></div>
          <% } %>
          <div class="order-total-row grand-total"><span>Total</span><span>LKR <%= total %></span></div>
        </div>
        
        <button type="button" id="placeOrderBtn" onclick="placeOrder()" style="width: 100%; margin-top: 18px; padding: 14px 28px; background: var(--primary-gradient); color: #FFFFFF; border: none; border-radius: var(--radius-full); font-size: 0.95rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; transition: all 0.2s ease; box-shadow: 0 4px 16px rgba(0,102,255,0.25);">
          <i class="fas fa-check-circle"></i> Place Order
        </button>
        <div id="orderMessage" style="text-align: center; margin-top: 12px; font-size: 0.85rem;"></div>
      </div>
      
    </div>
  </div>
</section>

<script>
function updateFileName() {
  var fileInput = document.getElementById('paymentReceipt');
  var fileName = document.getElementById('file-name');
  var uploadBtn = document.getElementById('uploadBtn');
  if (fileInput.files.length > 0) {
    fileName.textContent = fileInput.files[0].name;
    uploadBtn.classList.add('has-file');
    uploadBtn.innerHTML = '<i class="fas fa-check-circle"></i> File Selected';
  } else {
    fileName.textContent = '';
    uploadBtn.classList.remove('has-file');
    uploadBtn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Choose File';
  }
}

function togglePaymentMethod() {
  var method = document.querySelector('input[name="paymentMethod"]:checked').value;
  var bankDetails = document.getElementById('bankDetails');
  var cardInfo = document.getElementById('cardPaymentInfo');
  var codCard = document.getElementById('codCard');
  var cardCard = document.getElementById('cardCard');
  var bankCard = document.getElementById('bankCard');
  
  // Hide all panels and deselect all cards
  bankDetails.classList.remove('active');
  cardInfo.classList.remove('active');
  codCard.classList.remove('selected');
  cardCard.classList.remove('selected');
  bankCard.classList.remove('selected');
  
  // Show relevant panel and highlight selected card
  if (method === 'bank_transfer') {
    bankDetails.classList.add('active');
    bankCard.classList.add('selected');
  } else if (method === 'card_payment') {
    cardInfo.classList.add('active');
    cardCard.classList.add('selected');
  } else {
    codCard.classList.add('selected');
  }
}

function placeOrder() {
  var firstName = document.getElementById('firstName').value.trim();
  var lastName = document.getElementById('lastName').value.trim();
  var email = document.getElementById('email').value.trim();
  var phone = document.getElementById('phone').value.trim();
  var whatsapp = document.getElementById('whatsapp').value.trim();
  var street = document.getElementById('address').value.trim();
  var city = document.getElementById('city').value.trim();
  var state = document.getElementById('state').value.trim();
  var zip = document.getElementById('zip').value.trim();
  var paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
  
  // Validate all required fields with individual messages
  if (!firstName) { alert('Please enter your First Name.'); document.getElementById('firstName').focus(); return; }
  if (!lastName) { alert('Please enter your Last Name.'); document.getElementById('lastName').focus(); return; }
  if (!email) { alert('Please enter your Email Address.'); document.getElementById('email').focus(); return; }
  if (!phone) { alert('Please enter your Phone Number.'); document.getElementById('phone').focus(); return; }
  if (!whatsapp) { alert('Please enter your WhatsApp Number (even if it is the same as your phone number).'); document.getElementById('whatsapp').focus(); return; }
  if (!street) { alert('Please enter your Street Address.'); document.getElementById('address').focus(); return; }
  if (!city) { alert('Please enter your City.'); document.getElementById('city').focus(); return; }
  if (!state) { alert('Please select your District.'); document.getElementById('state').focus(); return; }
  if (!zip) { alert('Please enter your Postal Code.'); document.getElementById('zip').focus(); return; }
  
  // Only require receipt upload for bank transfer
  if (paymentMethod === 'bank_transfer') {
    var receiptFile = document.getElementById('paymentReceipt').files[0];
    if (!receiptFile) {
      alert('Please upload your payment receipt for Bank Transfer.');
      return;
    }
  }
  
  var formData = new FormData();
  formData.append('firstName', firstName);
  formData.append('lastName', lastName);
  formData.append('email', email);
  formData.append('phone', phone);
  formData.append('whatsapp', whatsapp);
  formData.append('street', street);
  formData.append('city', city);
  formData.append('state', state);
  formData.append('zipCode', zip);
  formData.append('country', 'Sri Lanka');
  formData.append('paymentMethod', paymentMethod);
  
  // Only append receipt for bank transfer
  if (paymentMethod === 'bank_transfer') {
    formData.append('paymentReceipt', document.getElementById('paymentReceipt').files[0]);
  }
  
  document.getElementById('placeOrderBtn').disabled = true;
  document.getElementById('placeOrderBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
  document.getElementById('orderMessage').innerHTML = '';
  
  fetch('/cart/place-order', {
    method: 'POST',
    body: formData
  })
  .then(function(res) { return res.json(); })
  .then(function(result) {
    if (result.success) {
      window.location.href = '/cart/order-confirmation/' + result.orderId;
    } else {
      document.getElementById('orderMessage').innerHTML = '<span style="color: var(--error);">' + (result.error || 'Something went wrong') + '</span>';
      document.getElementById('placeOrderBtn').disabled = false;
      document.getElementById('placeOrderBtn').innerHTML = '<i class="fas fa-check-circle"></i> Place Order';
    }
  })
  .catch(function() {
    document.getElementById('orderMessage').innerHTML = '<span style="color: var(--error);">Network error. Please try again.</span>';
    document.getElementById('placeOrderBtn').disabled = false;
    document.getElementById('placeOrderBtn').innerHTML = '<i class="fas fa-check-circle"></i> Place Order';
  });
}
</script>

