<%- include('partials/header') %>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
    padding: 70px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  [data-theme="dark"] .page-hero { background: linear-gradient(135deg, #020617 0%, #0F172A 100%); }
  .page-hero::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: rgba(0,102,255,0.05);
    border-radius: 50%;
  }
  .page-hero-icon {
    width: 70px;
    height: 70px;
    border-radius: 20px;
    background: rgba(0,229,160,0.15);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: var(--accent);
    margin-bottom: 18px;
    position: relative;
    z-index: 1;
  }
  .page-hero-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: #FFFFFF;
    position: relative;
    z-index: 1;
  }
  
  .page-content {
    padding: 56px 0;
    background: var(--bg-body);
  }
  .content-wrapper {
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  
  .contact-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 32px;
    box-shadow: var(--shadow-sm);
    text-align: center;
    transition: all 0.3s ease;
  }
  .contact-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--primary); }
  .contact-card.full { grid-column: 1 / -1; }
  .contact-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    margin-bottom: 14px;
  }
  .contact-icon.blue { background: rgba(0,102,255,0.1); color: #3B82F6; }
  .contact-icon.green { background: rgba(16,185,129,0.1); color: #059669; }
  .contact-icon.purple { background: rgba(124,58,237,0.1); color: #7C3AED; }
  .contact-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .contact-card p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .contact-card a {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .contact-card a:hover { text-decoration: underline; }
  
  .contact-form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 36px;
    box-shadow: var(--shadow-sm);
  }
  .contact-form-card h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 22px;
  }
  .form-group { margin-bottom: 16px; }
  .form-label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 5px; }
  .form-input, .form-textarea {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid var(--border-color);
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-family: var(--font-primary);
    color: var(--text-body);
    background: var(--bg-input);
    outline: none;
    transition: all 0.2s ease;
  }
  .form-textarea { resize: vertical; min-height: 120px; }
  .form-input:focus, .form-textarea:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(0,102,255,0.06); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    background: var(--primary-gradient);
    color: #FFFFFF;
    border: none;
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 16px rgba(0,102,255,0.25);
  }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,102,255,0.35); }
  
  @media (max-width: 600px) {
    .content-wrapper { grid-template-columns: 1fr; }
    .contact-card.full { grid-column: 1; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<div class="page-hero">
  <div class="page-hero-icon"><i class="fas fa-headset"></i></div>
  <h1 class="page-hero-title">Contact Us</h1>
</div>

<div class="page-content">
  <div class="container">
    <div class="content-wrapper">
      
      <div class="contact-card">
        <div class="contact-icon blue"><i class="fas fa-envelope"></i></div>
        <h3>Email Us</h3>
        <p>Send us an email anytime</p>
        <a href="mailto:shopnest.management@gmail.com">shopnest.management@gmail.com</a>
      </div>
      
      <div class="contact-card">
        <div class="contact-icon green"><i class="fas fa-clock"></i></div>
        <h3>Response Time</h3>
        <p>We typically respond within</p>
        <strong style="color:var(--text-primary);font-size:1.1rem;">24-48 Hours</strong>
      </div>
      
      <div class="contact-card">
        <div class="contact-icon purple"><i class="fas fa-search-location"></i></div>
        <h3>Track Order</h3>
        <p>Already placed an order?</p>
        <a href="/track">Track your order here →</a>
      </div>
      
      <div class="contact-card">
        <div class="contact-icon blue"><i class="fas fa-question-circle"></i></div>
        <h3>FAQ</h3>
        <p>Find quick answers</p>
        <a href="/faq">Visit our FAQ page →</a>
      </div>
      
      <div class="contact-form-card full">
        <h2>Send us a Message</h2>
        <form onsubmit="event.preventDefault(); alert('Thank you! Your message has been sent. We will get back to you within 24-48 hours.'); this.reset();">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Your Name</label>
              <input type="text" class="form-input" placeholder="John Doe" required>
            </div>
            <div class="form-group">
              <label class="form-label">Email Address</label>
              <input type="email" class="form-input" placeholder="john@example.com" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Subject</label>
            <input type="text" class="form-input" placeholder="How can we help?" required>
          </div>
          <div class="form-group">
            <label class="form-label">Message</label>
            <textarea class="form-textarea" placeholder="Tell us more about your inquiry..." required></textarea>
          </div>
          <button type="submit" class="btn-submit"><i class="fas fa-paper-plane"></i> Send Message</button>
        </form>
      </div>
      
    </div>
  </div>
</div>

<%- include('partials/footer') %>