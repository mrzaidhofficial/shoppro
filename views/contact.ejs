<%- include('partials/header') %>

<style>
  .contact-page {
    background: var(--bg-body);
    position: relative;
    overflow: hidden;
    min-height: 80vh;
  }
  
  .contact-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .bg-blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.04;
  }
  .bg-blob.b1 { width: 500px; height: 500px; background: var(--primary); top: -150px; left: -200px; animation: blobFloat 20s ease-in-out infinite; }
  .bg-blob.b2 { width: 350px; height: 350px; background: var(--accent); bottom: -100px; right: -120px; animation: blobFloat 18s ease-in-out infinite reverse; }
  @keyframes blobFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.1); }
    66% { transform: translate(-25px, 20px) scale(0.95); }
  }
  
  .contact-container {
    max-width: 820px;
    margin: 0 auto;
    padding: 60px 20px;
    position: relative;
    z-index: 1;
  }
  
  .contact-hero {
    text-align: center;
    margin-bottom: 40px;
  }
  .contact-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(0,229,160,0.1);
    border: 1px solid rgba(0,229,160,0.2);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 14px;
    letter-spacing: 0.5px;
  }
  .contact-hero-badge .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: dotPulse 2s ease-in-out infinite;
  }
  @keyframes dotPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .contact-hero-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
    letter-spacing: -0.5px;
  }
  .contact-hero-title span {
    background: var(--primary-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .contact-hero-subtitle {
    font-size: 0.92rem;
    color: var(--text-muted);
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .cards-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }
  
  .info-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 24px;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 16px;
    position: relative;
    overflow: hidden;
  }
  .info-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 3px 3px 0 0;
  }
  .info-card.email-card::before { background: linear-gradient(135deg, #7C3AED, #A78BFA); }
  .info-card.time-card::before { background: linear-gradient(135deg, #059669, #34D399); }
  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  
  .info-icon-circle {
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .info-card:hover .info-icon-circle { transform: scale(1.08); }
  .info-icon-circle.purple { background: rgba(124,58,237,0.1); color: #7C3AED; }
  .info-icon-circle.green { background: rgba(5,150,105,0.1); color: #059669; }
  [data-theme="dark"] .info-icon-circle.purple { background: rgba(124,58,237,0.15); color: #A78BFA; }
  [data-theme="dark"] .info-icon-circle.green { background: rgba(52,211,153,0.15); color: #34D399; }
  
  .info-content { flex: 1; min-width: 0; }
  .info-label {
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 4px;
  }
  .info-value {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
    word-break: break-all;
  }
  .info-highlight {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .info-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.82rem;
    text-decoration: none;
    margin-top: 2px;
    transition: gap 0.2s;
  }
  .info-link:hover { gap: 8px; }
  .info-link i { font-size: 0.7rem; }
  
  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 32px;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .form-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--primary-gradient);
    border-radius: 3px 3px 0 0;
  }
  .form-card:hover { box-shadow: var(--shadow-lg); }
  
  .form-header { margin-bottom: 22px; }
  .form-title {
    font-family: var(--font-display);
    font-size: 1.25rem; font-weight: 700;
    color: var(--text-primary); margin-bottom: 3px;
  }
  .form-subtitle { font-size: 0.82rem; color: var(--text-muted); }
  
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .form-grid .full { grid-column: 1 / -1; }
  
  .form-group { }
  .form-label {
    display: block; font-size: 0.78rem;
    font-weight: 600; color: var(--text-secondary);
    margin-bottom: 5px;
  }
  .form-input, .form-textarea {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid var(--border-color);
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-family: var(--font-primary);
    color: var(--text-body);
    background: var(--bg-input);
    outline: none;
    transition: all 0.2s ease;
  }
  .form-textarea { resize: vertical; min-height: 130px; }
  .form-input::placeholder, .form-textarea::placeholder { color: var(--text-muted); }
  .form-input:focus, .form-textarea:focus {
    border-color: var(--primary);
    background: var(--bg-card);
    box-shadow: 0 0 0 4px rgba(0,102,255,0.06);
  }
  
  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 14px;
  }
  .form-note {
    font-size: 0.78rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    background: var(--bg-card-alt);
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
  }
  .form-note i { color: var(--success); }
  
  .btn-send {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--primary-gradient);
    color: #FFFFFF;
    border: none;
    border-radius: var(--radius-full);
    font-size: 0.92rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 4px 16px rgba(0,102,255,0.25);
  }
  .btn-send:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,102,255,0.35);
  }
  
  @media (max-width: 600px) {
    .cards-row { grid-template-columns: 1fr; }
    .form-grid { grid-template-columns: 1fr; }
    .form-grid .full { grid-column: 1; }
    .form-card { padding: 22px 16px; }
    .contact-hero-title { font-size: 1.7rem; }
    .info-card { padding: 20px; }
    .form-footer { flex-direction: column; align-items: stretch; text-align: center; }
    .form-note { justify-content: center; }
    .btn-send { justify-content: center; }
  }
</style>

<div class="contact-page">
  
  <div class="contact-bg">
    <div class="bg-blob b1"></div>
    <div class="bg-blob b2"></div>
  </div>
  
  <div class="contact-container">
    
    <div class="contact-hero">
      <div class="contact-hero-badge">
        <span class="dot"></span> Get in Touch
      </div>
      <h1 class="contact-hero-title">We'd Love to <span>Hear From You</span></h1>
      <p class="contact-hero-subtitle">Have a question or need assistance? We're here to help.</p>
    </div>
    
    <div class="cards-row">
      <div class="info-card email-card">
        <div class="info-icon-circle purple"><i class="fas fa-envelope"></i></div>
        <div class="info-content">
          <div class="info-label">Email Address</div>
          <div class="info-value">shopnest.management@gmail.com</div>
          <a href="mailto:shopnest.management@gmail.com" class="info-link">Send Email <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      
      <div class="info-card time-card">
        <div class="info-icon-circle green"><i class="fas fa-clock"></i></div>
        <div class="info-content">
          <div class="info-label">Response Time</div>
          <div class="info-highlight">24-48 Hours</div>
          <div style="font-size:0.78rem;color:var(--text-muted);">We respond to all inquiries promptly</div>
        </div>
      </div>
    </div>
    
    <div class="form-card">
      <div class="form-header">
        <h2 class="form-title">Send a Message</h2>
        <p class="form-subtitle">Fill out the form and we'll get back to you soon</p>
      </div>
      
      <form onsubmit="event.preventDefault(); alert('Thank you! Your message has been sent. We will get back to you within 24-48 hours.'); this.reset();">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Your Name</label>
            <input type="text" class="form-input" placeholder="John Doe" required>
          </div>
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-input" placeholder="john@example.com" required>
          </div>
          <div class="form-group full">
            <label class="form-label">Subject</label>
            <input type="text" class="form-input" placeholder="What's this about?" required>
          </div>
          <div class="form-group full">
            <label class="form-label">Message</label>
            <textarea class="form-textarea" placeholder="Tell us more about your inquiry..." required></textarea>
          </div>
        </div>
        
        <div class="form-footer">
          <div class="form-note">
            <i class="fas fa-shield-alt"></i> Your information is secure and encrypted
          </div>
          <button type="submit" class="btn-send">
            <i class="fas fa-paper-plane"></i> Send Message
          </button>
        </div>
      </form>
    </div>
    
  </div>
</div>

<%- include('partials/footer') %>