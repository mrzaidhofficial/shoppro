<%- include('partials/header') %>

<style>
  .profile-section { padding: 48px 0; min-height: 60vh; background: var(--bg-body); }
  .profile-layout { display: grid; grid-template-columns: 300px 1fr; gap: 28px; align-items: start; }
  
  .profile-card { 
    background: var(--bg-card); 
    border-radius: var(--radius-xl); 
    overflow: hidden; 
    box-shadow: var(--shadow-md); 
    border: 1px solid var(--border-color); 
    position: sticky; 
    top: 100px;
    transition: box-shadow 0.3s ease;
  }
  .profile-card:hover { box-shadow: var(--shadow-lg); }
  .profile-cover { 
    height: 90px; 
    background: linear-gradient(135deg, var(--primary) 0%, #06B6D4 100%); 
    position: relative;
    overflow: hidden;
  }
  .profile-cover::after {
    content: '';
    position: absolute;
    top: -30px;
    right: -30px;
    width: 120px;
    height: 120px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
  }
  .profile-cover::before {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 40%;
    width: 80px;
    height: 80px;
    background: rgba(255,255,255,0.06);
    border-radius: 50%;
  }
  .profile-avatar-wrap { text-align: center; margin-top: -40px; margin-bottom: 14px; position: relative; z-index: 1; }
  .profile-avatar { 
    width: 80px; height: 80px; border-radius: 50%; 
    background: var(--primary-gradient); color: white; 
    display: inline-flex; align-items: center; justify-content: center; 
    font-size: 1.8rem; font-weight: 700; font-family: var(--font-display); 
    border: 4px solid var(--bg-card); box-shadow: var(--shadow-md);
    transition: transform 0.3s ease;
  }
  .profile-card:hover .profile-avatar { transform: scale(1.05); }
  .profile-card-body { padding: 0 24px 24px; text-align: center; }
  .profile-name { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 3px; letter-spacing: -0.3px; }
  .profile-email { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 12px; word-break: break-all; }
  .profile-role { 
    display: inline-block; padding: 4px 14px; border-radius: var(--radius-full); 
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 18px; 
  }
  .profile-role.customer { background: var(--primary-light); color: var(--primary); }
  .profile-role.admin { background: var(--accent-light); color: #059669; }
  [data-theme="dark"] .profile-role.admin { color: #34D399; }
  
  .profile-menu { 
    border-top: 1px solid var(--border-color); padding: 14px 0 0; 
    display: flex; flex-direction: column; gap: 4px; 
  }
  .profile-menu a { 
    display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: var(--radius); 
    font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); 
    text-decoration: none; transition: all 0.2s ease; 
  }
  .profile-menu a:hover { background: var(--bg-hover); color: var(--primary); transform: translateX(3px); }
  .profile-menu a i { width: 18px; text-align: center; font-size: 0.88rem; }
  .profile-menu a.admin-link { color: #059669; }
  [data-theme="dark"] .profile-menu a.admin-link { color: #34D399; }
  .profile-menu a.admin-link:hover { background: rgba(5,150,105,0.1); }
  .profile-menu a.track-link { color: #2563EB; }
  [data-theme="dark"] .profile-menu a.track-link { color: #60A5FA; }
  .profile-menu a.track-link:hover { background: rgba(37,99,235,0.1); }
  .profile-menu a.logout { color: var(--error); }
  .profile-menu a.logout:hover { background: var(--error-bg); }
  
  .content-card { 
    background: var(--bg-card); border: 1px solid var(--border-color); 
    border-radius: var(--radius-xl); padding: 28px; box-shadow: var(--shadow-xs); 
    transition: box-shadow 0.3s ease;
  }
  .content-card:hover { box-shadow: var(--shadow-sm); }
  .content-header { 
    display: flex; justify-content: space-between; align-items: center; 
    margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border-color); 
    flex-wrap: wrap; gap: 10px;
  }
  .content-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--text-primary); letter-spacing: -0.4px; }
  .content-count { 
    font-size: 0.8rem; color: var(--text-muted); background: var(--bg-card-alt); 
    padding: 5px 14px; border-radius: var(--radius-full); font-weight: 600;
    border: 1px solid var(--border-color);
  }
  
  .order-list { display: flex; flex-direction: column; gap: 12px; }
  .order-item { 
    background: var(--bg-card-alt); border: 1px solid var(--border-color); 
    border-radius: var(--radius-lg); padding: 18px 20px; 
    text-decoration: none; color: inherit; display: block; 
    transition: all 0.25s ease; 
  }
  .order-item:hover { 
    border-color: var(--primary); background: var(--bg-card); 
    box-shadow: var(--shadow-md); transform: translateY(-2px); 
  }
  .order-item-top { 
    display: flex; justify-content: space-between; align-items: center; 
    flex-wrap: wrap; gap: 10px; margin-bottom: 10px; 
  }
  .order-number { 
    font-weight: 700; color: var(--primary); font-size: 0.9rem; 
    font-family: var(--font-display); letter-spacing: -0.3px;
  }
  .order-date { font-size: 0.78rem; color: var(--text-muted); }
  .order-item-middle {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 10px; margin-bottom: 8px;
  }
  .order-items-text { font-size: 0.83rem; color: var(--text-body); }
  .order-total { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); }
  
  .order-item-bottom {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 8px; padding-top: 10px; border-top: 1px solid var(--border-color);
  }
  .tracking-info {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.8rem; color: var(--text-secondary);
  }
  .tracking-info strong { color: var(--primary); font-family: var(--font-display); }
  .copy-btn {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; font-size: 0.7rem; font-weight: 600;
    background: var(--primary-light); color: var(--primary);
    border: 1px solid var(--primary); border-radius: var(--radius-full);
    cursor: pointer; font-family: var(--font-primary); transition: all 0.2s ease;
  }
  .copy-btn:hover { background: var(--primary); color: #FFFFFF; }
  .copy-btn.copied { background: var(--success); color: #FFFFFF; border-color: var(--success); }
  
  .status-badge { 
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; border-radius: var(--radius-full); 
    font-size: 0.68rem; font-weight: 600; text-transform: capitalize; letter-spacing: 0.3px;
  }
  .status-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .status-pending { background: rgba(245,158,11,0.1); color: #D97706; }
  .status-pending::before { background: #D97706; }
  .status-processing { background: rgba(245,158,11,0.1); color: #D97706; }
  .status-processing::before { background: #D97706; }
  .status-shipped { background: rgba(37,99,235,0.1); color: #2563EB; }
  .status-shipped::before { background: #2563EB; }
  .status-delivered { background: rgba(16,185,129,0.1); color: #059669; }
  .status-delivered::before { background: #059669; }
  .status-cancelled { background: rgba(239,68,68,0.1); color: #EF4444; }
  .status-cancelled::before { background: #EF4444; }
  [data-theme="dark"] .status-pending { background: rgba(251,191,36,0.15); color: #FBBF24; }
  [data-theme="dark"] .status-processing { background: rgba(251,191,36,0.15); color: #FBBF24; }
  [data-theme="dark"] .status-shipped { background: rgba(59,130,246,0.15); color: #60A5FA; }
  [data-theme="dark"] .status-delivered { background: rgba(52,211,153,0.15); color: #34D399; }
  [data-theme="dark"] .status-cancelled { background: rgba(248,113,113,0.15); color: #F87171; }
  
  .payment-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 0.72rem; font-weight: 500;
  }
  .payment-badge.verified { color: var(--success); }
  .payment-badge.pending { color: #D97706; }
  
  .empty-state { text-align: center; padding: 48px 20px; }
  .empty-state-icon { font-size: 3.5rem; color: var(--text-muted); margin-bottom: 16px; display: block; opacity: 0.3; }
  .empty-state h3 { font-family: var(--font-display); font-size: 1.2rem; color: var(--text-primary); margin-bottom: 8px; }
  .empty-state p { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px; }
  .btn-primary-sm { 
    display: inline-flex; align-items: center; gap: 8px; padding: 11px 24px; 
    background: var(--primary-gradient); color: white; border: none; 
    border-radius: var(--radius-full); font-size: 0.85rem; font-weight: 600; 
    font-family: var(--font-primary); cursor: pointer; text-decoration: none; 
    transition: all 0.25s ease; box-shadow: 0 4px 14px rgba(0,102,255,0.2);
  }
  .btn-primary-sm:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,102,255,0.3); }
  
  @media (max-width: 768px) {
    .profile-layout { grid-template-columns: 1fr; gap: 16px; }
    .profile-card { position: static; }
    .content-card { padding: 16px; }
    .profile-cover { height: 60px; }
    .profile-avatar { width: 60px; height: 60px; font-size: 1.4rem; }
    .profile-avatar-wrap { margin-top: -30px; margin-bottom: 10px; }
    .profile-name { font-size: 1.1rem; }
    .profile-card-body { padding: 0 16px 16px; }
    .order-item-top { flex-direction: column; align-items: flex-start; gap: 6px; }
    .order-item-bottom { flex-direction: column; gap: 8px; align-items: flex-start; }
    .order-item-middle { flex-direction: column; gap: 4px; align-items: flex-start; }
    .content-header { flex-direction: column; gap: 8px; align-items: flex-start; }
    .profile-menu a { padding: 8px 10px; font-size: 0.8rem; }
  }
</style>

<div class="profile-section">
  <div class="container">
    <div class="profile-layout">
      
      <aside class="profile-card">
        <div class="profile-cover"></div>
        <div class="profile-avatar-wrap">
          <div class="profile-avatar"><%= user.firstName.charAt(0).toUpperCase() %></div>
        </div>
        <div class="profile-card-body">
          <div class="profile-name"><%= user.firstName %> <%= user.lastName %></div>
          <div class="profile-email"><%= user.email %></div>
          <span class="profile-role <%= user.role %>"><%= user.role %></span>
          
          <div class="profile-menu">
            <a href="/products"><i class="fas fa-shopping-bag"></i> Browse Products</a>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
              <a href="/admin/dashboard" class="admin-link"><i class="fas fa-gauge"></i> Admin Panel</a>
            <% } %>
            <a href="/cart/wishlist"><i class="fas fa-heart"></i> My Wishlist</a>
            <a href="/cart"><i class="fas fa-shopping-cart"></i> View Cart</a>
            <a href="/track" class="track-link"><i class="fas fa-search-location"></i> Track Order</a>
            <a href="/auth/logout" class="logout"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
          </div>
        </div>
      </aside>
      
      <div class="profile-content">
        <div class="content-card">
          <div class="content-header">
            <h2 class="content-title">Order History</h2>
            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
              <span class="content-count"><%= orders.length %> order<%= orders.length !== 1 ? 's' : '' %></span>
            <% } %>
          </div>
          
          <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
            <div class="order-list">
              <% orders.forEach(function(order) { %>
                <div class="order-item">
                  <div class="order-item-top">
                    <span class="order-number">#<%= order.orderNumber %></span>
                    <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
                    <span class="order-date"><%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                  </div>
                  <div class="order-item-middle">
                    <span class="order-items-text">
                      <%= order.items ? order.items.length : 0 %> item(s)
                      <% if (order.items && order.items.length > 0) { %>
                        — <%= order.items.slice(0, 2).map(function(i) { return i.name; }).join(', ') %><%= order.items.length > 2 ? '...' : '' %>
                      <% } %>
                    </span>
                    <span class="order-total">LKR <%= order.total.toFixed(2) %></span>
                  </div>
                  <div class="order-item-bottom">
                    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                      <div style="display:flex;align-items:center;gap:8px;">
                        <span style="font-size:0.75rem;color:var(--text-muted);">Order ID:</span>
                        <span style="font-size:0.78rem;font-weight:500;color:var(--text-secondary);"><%= order.orderNumber %></span>
                        <button class="copy-btn" onclick="copyToClipboard('<%= order.orderNumber %>', this)"><i class="fas fa-copy"></i> Copy</button>
                      </div>
                      <% if (order.trackingNumber) { %>
                        <div style="display:flex;align-items:center;gap:8px;">
                          <span style="font-size:0.75rem;color:var(--text-muted);">Tracking No:</span>
                          <span style="font-size:0.78rem;font-weight:500;color:var(--primary);"><%= order.trackingNumber %></span>
                          <button class="copy-btn" onclick="copyToClipboard('<%= order.trackingNumber %>', this)"><i class="fas fa-copy"></i> Copy</button>
                        </div>
                      <% } %>
                      <% if (order.paymentMethod === 'bank_transfer') { %>
                        <span class="payment-badge <%= order.paymentVerified ? 'verified' : 'pending' %>">
                          <i class="fas <%= order.paymentVerified ? 'fa-check-circle' : 'fa-clock' %>"></i>
                          Bank Transfer: <%= order.paymentVerified ? 'Verified' : 'Pending' %>
                        </span>
                      <% } else { %>
                        <span class="payment-badge" style="color:var(--text-secondary);">
                          <i class="fas fa-money-bill-wave"></i> COD
                        </span>
                      <% } %>
                    </div>
                    <a href="/cart/order-confirmation/<%= order._id %>" style="font-size:0.78rem;color:var(--primary);font-weight:600;text-decoration:none;">View Details →</a>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <span class="empty-state-icon"><i class="fas fa-box-open"></i></span>
              <h3>No orders yet</h3>
              <p>Start shopping to see your order history here.</p>
              <a href="/products" class="btn-primary-sm"><i class="fas fa-shopping-bag"></i> Browse Products</a>
            </div>
          <% } %>
        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
function copyToClipboard(text, btn) {
  navigator.clipboard.writeText(text).then(function() {
    btn.classList.add('copied');
    btn.innerHTML = '<i class="fas fa-check"></i> Copied';
    setTimeout(function() {
      btn.classList.remove('copied');
      btn.innerHTML = '<i class="fas fa-copy"></i> Copy';
    }, 2000);
  }).catch(function() {
    alert('Failed to copy. Please copy manually: ' + text);
  });
}
</script>

<%- include('partials/footer') %>