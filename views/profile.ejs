<%- include('partials/header') %>

<style>
  .profile-section { padding: 48px 0; min-height: 60vh; background: var(--gray-50); }
  .profile-layout { display: grid; grid-template-columns: 300px 1fr; gap: 28px; align-items: start; }
  
  .profile-card { background: var(--white); border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-sm); border: var(--border); position: sticky; top: 100px; }
  .profile-cover { height: 80px; background: var(--primary-gradient); }
  .profile-avatar-wrap { text-align: center; margin-top: -35px; margin-bottom: 16px; }
  .profile-avatar { width: 70px; height: 70px; border-radius: 50%; background: var(--primary-gradient); color: white; display: inline-flex; align-items: center; justify-content: center; font-size: 1.6rem; font-weight: 700; font-family: var(--font-display); border: 4px solid white; box-shadow: var(--shadow-md); }
  .profile-card-body { padding: 0 24px 24px; text-align: center; }
  .profile-name { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--gray-900); margin-bottom: 2px; }
  .profile-email { font-size: 0.82rem; color: var(--gray-500); margin-bottom: 12px; }
  .profile-role { display: inline-block; padding: 4px 14px; border-radius: var(--radius-full); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 16px; }
  .profile-role.customer { background: var(--primary-light); color: var(--primary); }
  .profile-role.admin { background: var(--accent-light); color: var(--accent-dark); }
  
  .profile-menu { border-top: var(--border); padding: 16px 0 0; display: flex; flex-direction: column; gap: 6px; }
  .profile-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 16px; border-radius: var(--radius); font-size: 0.85rem; font-weight: 500; color: var(--gray-600); text-decoration: none; transition: all 0.15s ease; }
  .profile-menu a:hover { background: var(--gray-50); color: var(--primary); }
  .profile-menu a i { width: 18px; text-align: center; font-size: 0.9rem; }
  .profile-menu a.logout { color: var(--error); }
  .profile-menu a.logout:hover { background: var(--error-bg); }
  
  .profile-content { }
  .content-card { background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 28px; box-shadow: var(--shadow-xs); }
  .content-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: var(--border); }
  .content-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--gray-900); }
  .content-count { font-size: 0.82rem; color: var(--gray-500); background: var(--gray-100); padding: 4px 12px; border-radius: var(--radius-full); }
  
  .order-list { display: flex; flex-direction: column; gap: 12px; }
  .order-item { background: var(--gray-50); border: 1px solid var(--gray-100); border-radius: var(--radius-lg); padding: 18px 20px; text-decoration: none; color: inherit; display: block; transition: all 0.2s ease; }
  .order-item:hover { border-color: var(--primary); background: var(--white); box-shadow: var(--shadow-sm); }
  .order-item-top { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 10px; }
  .order-number { font-weight: 700; color: var(--primary); font-size: 0.9rem; font-family: var(--font-display); }
  .order-date { font-size: 0.78rem; color: var(--gray-500); }
  .order-item-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
  .order-items-text { font-size: 0.82rem; color: var(--gray-600); }
  .order-total { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--gray-900); }
  
  .status-badge { display: inline-block; padding: 3px 10px; border-radius: var(--radius-full); font-size: 0.68rem; font-weight: 600; text-transform: capitalize; }
  .status-processing { background: #FEF3C7; color: #D97706; }
  .status-shipped { background: #DBEAFE; color: #2563EB; }
  .status-delivered { background: var(--success-bg); color: var(--success); }
  .status-cancelled { background: var(--error-bg); color: var(--error); }
  
  .empty-state { text-align: center; padding: 48px 20px; }
  .empty-state-icon { font-size: 3.5rem; color: var(--gray-200); margin-bottom: 16px; display: block; }
  .empty-state h3 { font-family: var(--font-display); font-size: 1.2rem; color: var(--gray-700); margin-bottom: 8px; }
  .empty-state p { color: var(--gray-500); font-size: 0.9rem; margin-bottom: 20px; }
  .btn-primary-sm { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; background: var(--primary-gradient); color: white; border: none; border-radius: var(--radius-full); font-size: 0.85rem; font-weight: 600; font-family: var(--font-primary); cursor: pointer; text-decoration: none; transition: all 0.2s ease; }
  .btn-primary-sm:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,102,255,0.3); }
  
  @media (max-width: 768px) {
    .profile-layout { grid-template-columns: 1fr; }
    .profile-card { position: static; }
    .content-card { padding: 20px; }
  }
</style>

<div class="profile-section">
  <div class="container">
    <div class="profile-layout">
      
      <!-- Sidebar Profile Card -->
      <aside class="profile-card">
        <div class="profile-cover"></div>
        <div class="profile-avatar-wrap">
          <div class="profile-avatar"><%= user.firstName.charAt(0).toUpperCase() %></div>
        </div>
        <div class="profile-card-body">
          <div class="profile-name"><%= user.firstName %> <%= user.lastName %></div>
          <div class="profile-email"><%= user.email %></div>
          <span class="profile-role <%= user.role %>"><%= user.role %></span>
          
          <div class="profile-menu">
            <a href="/products"><i class="fas fa-shopping-bag"></i> Browse Products</a>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
              <a href="/admin/dashboard"><i class="fas fa-gauge"></i> Admin Panel</a>
            <% } %>
            <a href="/cart/wishlist"><i class="fas fa-heart"></i> My Wishlist</a>
            <a href="/cart"><i class="fas fa-shopping-cart"></i> View Cart</a>
            <a href="/auth/logout" class="logout"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
          </div>
        </div>
      </aside>
      
      <!-- Main Content -->
      <div class="profile-content">
        <div class="content-card">
          <div class="content-header">
            <h2 class="content-title">Order History</h2>
            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
              <span class="content-count"><%= orders.length %> order<%= orders.length !== 1 ? 's' : '' %></span>
            <% } %>
          </div>
          
          <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
            <div class="order-list">
              <% orders.forEach(function(order) { %>
                <a href="/cart/order-confirmation/<%= order._id %>" class="order-item">
                  <div class="order-item-top">
                    <span class="order-number">#<%= order.orderNumber %></span>
                    <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
                    <span class="order-date"><%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                  </div>
                  <div class="order-item-bottom">
                    <span class="order-items-text">
                      <%= order.items ? order.items.length : 0 %> item(s)
                      <% if (order.items && order.items.length > 0) { %>
                        — <%= order.items.slice(0, 2).map(function(i) { return i.name; }).join(', ') %><%= order.items.length > 2 ? '...' : '' %>
                      <% } %>
                    </span>
                    <span class="order-total">$<%= order.total.toFixed(2) %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <span class="empty-state-icon"><i class="fas fa-box-open"></i></span>
              <h3>No orders yet</h3>
              <p>Start shopping to see your order history here.</p>
              <a href="/products" class="btn-primary-sm"><i class="fas fa-shopping-bag"></i> Browse Products</a>
            </div>
          <% } %>
        </div>
      </div>
      
    </div>
  </div>
</div>

<%- include('partials/footer') %>