<%- include('partials/header') %>

<section class="product-detail-section">
  <div class="container">
    <nav class="breadcrumb-nav">
      <a href="/">Home</a><span class="separator">/</span>
      <a href="/products">Products</a><span class="separator">/</span>
      <span><%= product.name %></span>
    </nav>

    <div class="product-detail-layout">
      <div>
        <div class="product-gallery-main">
          <img src="<%= product.images && product.images[0] ? product.images[0] : 'https://picsum.photos/600/600' %>" alt="<%= product.name %>" onerror="this.src='https://picsum.photos/600/600'">
        </div>
        <% if (product.images && product.images.length > 1) { %>
          <div style="display:flex;gap:10px;margin-top:12px;overflow-x:auto;">
            <% product.images.forEach(function(img, index) { if (index > 0) { %>
              <img src="<%= img %>" alt="<%= product.name %>" style="width:80px;height:80px;border-radius:10px;object-fit:cover;cursor:pointer;border:2px solid transparent;" onerror="this.style.display='none'" onclick="document.querySelector('.product-gallery-main img').src='<%= img %>'">
            <% }}); %>
          </div>
        <% } %>
      </div>
      <div>
        <span class="product-info-category"><%= product.category %></span>
        <h1 class="product-info-title"><%= product.name %></h1>
        
        <!-- Dynamic Star Rating -->
        <div class="product-info-rating" style="display:flex;align-items:center;gap:8px;margin-bottom:18px;">
          <div style="display:flex;gap:2px;">
            <% for (var i = 1; i <= 5; i++) { %>
              <% if (i <= Math.floor(product.averageRating)) { %>
                <span class="star filled"><i class="fas fa-star"></i></span>
              <% } else if (i - 0.5 <= product.averageRating) { %>
                <span class="star filled"><i class="fas fa-star-half-alt"></i></span>
              <% } else { %>
                <span class="star"><i class="fas fa-star"></i></span>
              <% } %>
            <% } %>
          </div>
          <span style="font-size:0.85rem;color:var(--gray-500);">
            <%= product.averageRating %> (<%= product.numReviews || product.ratings.length %> reviews)
          </span>
        </div>
        
        <div class="product-info-price">$<%= product.price.toFixed(2) %></div>
        
        <!-- Short Description -->
        <% if (product.shortDescription) { %>
          <p class="product-info-short-desc" style="color:var(--gray-600);font-size:1rem;line-height:1.6;margin-bottom:16px;font-weight:500;"><%= product.shortDescription %></p>
        <% } %>
        
        <!-- Full Description -->
        <p class="product-info-description"><%= product.description %></p>

        <!-- Stock Badge -->
        <% if (product.stock === 0) { %>
          <div style="background:var(--error-bg);color:var(--error);padding:10px 18px;border-radius:var(--radius-full);display:inline-block;font-weight:600;font-size:0.85rem;margin-bottom:18px;">
            <i class="fas fa-times-circle"></i> Out of Stock
          </div>
        <% } else if (product.stock <= 5) { %>
          <div style="background:#FEF3C7;color:#D97706;padding:10px 18px;border-radius:var(--radius-full);display:inline-block;font-weight:600;font-size:0.85rem;margin-bottom:18px;">
            <i class="fas fa-exclamation-triangle"></i> Only <%= product.stock %> left in stock!
          </div>
        <% } else if (product.stock <= 15) { %>
          <div style="background:var(--primary-light);color:var(--primary);padding:10px 18px;border-radius:var(--radius-full);display:inline-block;font-weight:600;font-size:0.85rem;margin-bottom:18px;">
            <i class="fas fa-box"></i> <%= product.stock %> units available
          </div>
        <% } else { %>
          <div style="background:var(--success-bg);color:var(--success);padding:10px 18px;border-radius:var(--radius-full);display:inline-block;font-weight:600;font-size:0.85rem;margin-bottom:18px;">
            <i class="fas fa-check-circle"></i> In Stock
          </div>
        <% } %>

        <!-- Wishlist Button -->
        <div style="margin-bottom:18px;">
          <% if (typeof user !== 'undefined' && user) { %>
            <form action="/cart/wishlist/add/<%= product._id %>" method="POST" style="display:inline;">
              <button type="submit" style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:transparent;border:2px solid var(--gray-200);border-radius:var(--radius-full);font-size:0.85rem;font-weight:600;color:var(--gray-600);cursor:pointer;font-family:var(--font-primary);transition:var(--transition);">
                <i class="fas fa-heart"></i> Add to Wishlist
              </button>
            </form>
          <% } else { %>
            <a href="/auth/signin" style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:transparent;border:2px solid var(--gray-200);border-radius:var(--radius-full);font-size:0.85rem;font-weight:600;color:var(--gray-600);text-decoration:none;transition:var(--transition);">
              <i class="fas fa-heart"></i> Sign in to Wishlist
            </a>
          <% } %>
        </div>

        <div class="product-specs">
          <table class="product-specs-table">
            <% if (product.specifications && product.specifications.size > 0) { %>
              <% for (const [key, value] of product.specifications) { %>
                <tr><td><%= key %></td><td><%= value %></td></tr>
              <% } %>
            <% } else { %>
              <tr><td>Category</td><td><%= product.category %></td></tr>
              <tr><td>Stock</td><td><%= product.stock %> units</td></tr>
              <tr><td>Quality</td><td>Premium</td></tr>
              <tr><td>Warranty</td><td>1 Year</td></tr>
            <% } %>
          </table>
        </div>

        <% if (product.stock > 0) { %>
          <form action="/cart/add/<%= product._id %>" method="POST">
            <div class="quantity-selector">
              <button type="button" class="qty-btn" onclick="var i=document.getElementById('qtyInput');var v=parseInt(i.value)||1;if(v>1)i.value=v-1;">−</button>
              <input type="number" name="quantity" id="qtyInput" value="1" min="1" max="<%= product.stock %>" class="qty-input" readonly>
              <button type="button" class="qty-btn" onclick="var i=document.getElementById('qtyInput');var v=parseInt(i.value)||0;var m=<%= product.stock %>;if(v<m)i.value=v+1;">+</button>
            </div>
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-cart-shopping"></i> Add to Cart</button>
          </form>
        <% } else { %>
          <button class="btn btn-secondary btn-lg" disabled style="width:100%;">Out of Stock</button>
        <% } %>
      </div>
    </div>

    <!-- Reviews Section -->
    <div style="margin-top:60px;border-top:var(--border);padding-top:40px;">
      <h2 style="font-family:var(--font-display);font-size:1.6rem;color:var(--gray-900);margin-bottom:24px;">Customer Reviews</h2>
      
      <% if (typeof user !== 'undefined' && user) { %>
        <div style="background:var(--gray-50);border:var(--border);border-radius:var(--radius-xl);padding:28px;margin-bottom:28px;">
          <h4 style="font-weight:600;color:var(--gray-900);margin-bottom:16px;">Write a Review</h4>
          <form action="/products/<%= product._id %>/review" method="POST">
            <div style="margin-bottom:14px;">
              <label style="font-weight:600;font-size:0.85rem;color:var(--gray-700);display:block;margin-bottom:6px;">Your Rating *</label>
              <div style="display:flex;gap:6px;" id="starRating">
                <% for (var i = 1; i <= 5; i++) { %>
                  <span class="review-star" data-rating="<%= i %>" style="font-size:1.5rem;color:var(--gray-300);cursor:pointer;transition:var(--transition-fast);"><i class="fas fa-star"></i></span>
                <% } %>
              </div>
              <input type="hidden" name="rating" id="ratingInput" value="5" required>
            </div>
            <div class="form-group">
              <label class="form-label">Your Review (optional)</label>
              <textarea name="review" class="form-input" style="resize:vertical;min-height:100px;" placeholder="Share your experience with this product..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="background:var(--primary-gradient);color:white;border:none;padding:12px 28px;border-radius:var(--radius-full);font-weight:600;cursor:pointer;font-family:var(--font-primary);">Submit Review</button>
          </form>
        </div>
      <% } else { %>
        <div style="background:var(--gray-50);border:var(--border);border-radius:var(--radius-xl);padding:24px;text-align:center;margin-bottom:28px;">
          <p style="color:var(--gray-500);margin-bottom:10px;">Please sign in to leave a review.</p>
          <a href="/auth/signin" class="btn btn-primary" style="background:var(--primary-gradient);color:white;border:none;padding:10px 24px;border-radius:var(--radius-full);font-weight:600;text-decoration:none;display:inline-block;">Sign In</a>
        </div>
      <% } %>
      
      <% if (product.ratings && product.ratings.length > 0) { %>
        <div style="display:flex;flex-direction:column;gap:20px;">
          <% product.ratings.slice().reverse().forEach(function(review) { %>
            <div style="background:var(--white);border:var(--border);border-radius:var(--radius-lg);padding:22px 26px;box-shadow:var(--shadow-xs);">
              <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:10px;">
                <div style="display:flex;align-items:center;gap:10px;">
                  <div style="width:36px;height:36px;border-radius:50%;background:var(--primary-gradient);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;">
                    <%= review.user ? review.user.firstName.charAt(0).toUpperCase() : 'U' %>
                  </div>
                  <strong style="color:var(--gray-900);font-size:0.9rem;"><%= review.user ? review.user.firstName + ' ' + review.user.lastName : 'Anonymous' %></strong>
                </div>
                <span style="font-size:0.8rem;color:var(--gray-400);"><%= review.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
              </div>
              <div style="display:flex;gap:2px;margin-bottom:8px;">
                <% for (var i = 1; i <= 5; i++) { %>
                  <span class="star <%= i <= review.rating ? 'filled' : '' %>"><i class="fas fa-star"></i></span>
                <% } %>
              </div>
              <% if (review.review) { %>
                <p style="color:var(--gray-600);font-size:0.9rem;line-height:1.6;"><%= review.review %></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:40px;background:var(--white);border:var(--border);border-radius:var(--radius-xl);">
          <i class="fas fa-comment-dots" style="font-size:2.5rem;color:var(--gray-300);margin-bottom:12px;display:block;"></i>
          <p style="color:var(--gray-500);">No reviews yet. Be the first to review this product!</p>
        </div>
      <% } %>
    </div>

    <!-- Related Products -->
    <% if (typeof relatedProducts !== 'undefined' && relatedProducts.length > 0) { %>
      <div style="margin-top:60px;border-top:var(--border);padding-top:40px;">
        <h2 style="font-family:var(--font-display);font-size:1.6rem;color:var(--gray-900);margin-bottom:24px;">Related Products</h2>
        <div class="product-grid">
          <% relatedProducts.forEach(function(relProduct) { %>
            <div class="product-card">
              <div class="product-card-image">
                <a href="/products/<%= relProduct._id %>">
                  <img src="<%= relProduct.images && relProduct.images[0] ? relProduct.images[0] : 'https://picsum.photos/400/400' %>" alt="<%= relProduct.name %>" loading="lazy" onerror="this.src='https://picsum.photos/400/400'">
                </a>
                <div class="quick-view-overlay">
                  <button class="quick-view-btn" data-id="<%= relProduct._id %>">Quick View</button>
                </div>
              </div>
              <div class="product-card-body">
                <span class="product-card-category"><%= relProduct.category %></span>
                <h3 class="product-card-title"><a href="/products/<%= relProduct._id %>"><%= relProduct.name %></a></h3>
                <div class="product-card-rating">
                  <% for (var i = 1; i <= 5; i++) { %>
                    <span class="star <%= i <= Math.floor(relProduct.averageRating) ? 'filled' : '' %>"><i class="fas fa-star"></i></span>
                  <% } %>
                </div>
                <div class="product-card-price">$<%= relProduct.price.toFixed(2) %></div>
              </div>
              <div class="product-card-footer">
                <a href="/products/<%= relProduct._id %>" class="btn btn-outline btn-sm">Details</a>
                <form action="/cart/add/<%= relProduct._id %>" method="POST" style="flex:1;"><input type="hidden" name="quantity" value="1"><button type="submit" class="btn btn-primary btn-sm btn-block">Add to Cart</button></form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Recently Viewed -->
    <% if (typeof recentlyViewed !== 'undefined' && recentlyViewed.length > 0) { %>
      <div style="margin-top:60px;border-top:var(--border);padding-top:40px;">
        <h2 style="font-family:var(--font-display);font-size:1.6rem;color:var(--gray-900);margin-bottom:24px;">Recently Viewed</h2>
        <div class="product-grid">
          <% recentlyViewed.forEach(function(rvProduct) { %>
            <div class="product-card">
              <div class="product-card-image">
                <a href="/products/<%= rvProduct._id %>">
                  <img src="<%= rvProduct.images && rvProduct.images[0] ? rvProduct.images[0] : 'https://picsum.photos/400/400' %>" alt="<%= rvProduct.name %>" loading="lazy" onerror="this.src='https://picsum.photos/400/400'">
                </a>
                <div class="quick-view-overlay"><button class="quick-view-btn" data-id="<%= rvProduct._id %>">Quick View</button></div>
              </div>
              <div class="product-card-body">
                <span class="product-card-category"><%= rvProduct.category %></span>
                <h3 class="product-card-title"><a href="/products/<%= rvProduct._id %>"><%= rvProduct.name %></a></h3>
                <div class="product-card-rating">
                  <% for (var i = 1; i <= 5; i++) { %><span class="star <%= i <= Math.floor(rvProduct.averageRating) ? 'filled' : '' %>"><i class="fas fa-star"></i></span><% } %>
                </div>
                <div class="product-card-price">$<%= rvProduct.price.toFixed(2) %></div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</section>

<script>
document.querySelectorAll('.review-star').forEach(function(star) {
  star.addEventListener('click', function() {
    var rating = parseInt(this.dataset.rating);
    document.getElementById('ratingInput').value = rating;
    document.querySelectorAll('.review-star').forEach(function(s, index) { s.style.color = index < rating ? '#F59E0B' : 'var(--gray-300)'; });
  });
  star.addEventListener('mouseenter', function() {
    var rating = parseInt(this.dataset.rating);
    document.querySelectorAll('.review-star').forEach(function(s, index) { s.style.color = index < rating ? '#F59E0B' : 'var(--gray-300)'; });
  });
  star.addEventListener('mouseleave', function() {
    var currentRating = parseInt(document.getElementById('ratingInput').value);
    document.querySelectorAll('.review-star').forEach(function(s, index) { s.style.color = index < currentRating ? '#F59E0B' : 'var(--gray-300)'; });
  });
});
document.querySelectorAll('.review-star').forEach(function(s, index) { s.style.color = index < 5 ? '#F59E0B' : 'var(--gray-300)'; });
</script>

<%- include('partials/footer') %>