<%- include('partials/header') %>

<div style="padding: 80px 0; background: var(--bg-body); min-height: 60vh;">
  <div class="container">
    <div style="max-width: 700px; margin: 0 auto; text-align: center;">
      
      <div style="width: 80px; height: 80px; background: var(--success-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; animation: popIn 0.5s ease;">
        <i class="fas fa-check-circle" style="font-size: 3rem; color: var(--success);"></i>
      </div>
      
      <h1 style="font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); color: var(--text-primary); margin-bottom: 8px;">Order Confirmed!</h1>
      <p style="color: var(--text-muted); font-size: 1.05rem; margin-bottom: 8px;">Thank you for your purchase!</p>
      <p style="color: var(--primary); font-weight: 600; font-size: 1.1rem; margin-bottom: 16px;">Order #<%= order.orderNumber %></p>
      
      <div style="background: #FEF3C7; border: 1px solid #F59E0B; border-radius: var(--radius-lg); padding: 14px 20px; margin-bottom: 20px; display: inline-block; text-align: left; max-width: 100%;">
        <p style="color: #92400E; font-size: 0.88rem; margin: 0;">
          <i class="fas fa-info-circle" style="margin-right: 6px;"></i>
          <strong>Important:</strong> A confirmation email has been sent to your inbox. Please check your <strong>spam/junk folder</strong> and mark our emails as <strong>"Not Spam"</strong> to ensure you receive future order updates.
        </p>
      </div>

      <% if (order.paymentMethod === 'card_payment') { %>
        <div style="background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(6,182,212,0.08)); border: 1px solid rgba(59,130,246,0.25); border-radius: var(--radius-lg); padding: 20px 24px; margin-bottom: 20px; text-align: left; max-width: 100%;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
            <div style="width: 40px; height: 40px; border-radius: var(--radius); background: rgba(59,130,246,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <i class="fas fa-credit-card" style="color: #3B82F6; font-size: 1rem;"></i>
            </div>
            <div>
              <% if (order.paymentVerified) { %>
                <div style="font-weight: 700; color: #059669; font-size: 0.9rem;">Card Payment — Verified ✓</div>
                <div style="font-size: 0.78rem; color: #059669;">Your payment has been verified</div>
              <% } else if (order.paymentLinkSent) { %>
                <div style="font-weight: 700; color: #7C3AED; font-size: 0.9rem;">Card Payment — Awaiting Verification</div>
                <div style="font-size: 0.78rem; color: var(--text-muted);">Payment link has been sent. Waiting for your payment.</div>
              <% } else { %>
                <div style="font-weight: 700; color: #EA580C; font-size: 0.9rem;">Card Payment — Awaiting Payment Link</div>
                <div style="font-size: 0.78rem; color: var(--text-muted);">We will send you a secure payment link shortly</div>
              <% } %>
            </div>
          </div>
          
          <% if (!order.paymentVerified && !order.paymentLinkSent) { %>
            <p style="color: var(--text-body); font-size: 0.85rem; line-height: 1.6; margin-bottom: 12px;">
              A secure payment link will be sent to you through the following channels:
            </p>
          <% } else if (!order.paymentVerified && order.paymentLinkSent) { %>
            <p style="color: var(--text-body); font-size: 0.85rem; line-height: 1.6; margin-bottom: 12px;">
              A secure payment link has been sent to you through the following channels:
            </p>
          <% } %>
          
          <% if (!order.paymentVerified) { %>
            <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px;">
              <div style="display: flex; align-items: center; gap: 8px; font-size: 0.84rem; color: var(--text-secondary);">
                <i class="fas fa-envelope" style="color: #EA580C; width: 20px; text-align: center;"></i>
                <span><strong>Email</strong> — to your email address</span>
              </div>
              <div style="display: flex; align-items: center; gap: 8px; font-size: 0.84rem; color: var(--text-secondary);">
                <i class="fas fa-comment-sms" style="color: #2563EB; width: 20px; text-align: center;"></i>
                <span><strong>SMS</strong> — as a text message to your phone</span>
              </div>
              <div style="display: flex; align-items: center; gap: 8px; font-size: 0.84rem; color: var(--text-secondary);">
                <i class="fab fa-whatsapp" style="color: #25D366; width: 20px; text-align: center;"></i>
                <span><strong>WhatsApp</strong> — to your WhatsApp number</span>
              </div>
            </div>
          <% } %>
          <div style="background: rgba(59,130,246,0.06); border-radius: var(--radius); padding: 10px 14px; font-size: 0.76rem; color: #3B82F6; font-weight: 500;">
            <i class="fas fa-shield-alt" style="margin-right: 4px;"></i>
            Secured by HNB Accept. Pay using your Visa or Mastercard.
          </div>
        </div>
      <% } %>

      <% if (order.paymentMethod === 'bank_transfer') { %>
        <div style="background: var(--bg-card-alt); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 14px 20px; margin-bottom: 20px; display: inline-block; text-align: left; max-width: 100%;">
          <p style="font-size: 0.88rem; margin: 0; color: var(--text-primary);">
            <i class="fas fa-receipt" style="margin-right: 6px; color: var(--primary);"></i>
            <strong>Payment Status:</strong> 
            <% if (order.paymentVerified) { %>
              <span style="color: var(--success); font-weight: 600;">Verified ✓</span>
            <% } else { %>
              <span style="color: #D97706; font-weight: 600;">Pending Verification</span>
            <% } %>
          </p>
          <% if (!order.paymentVerified) { %>
            <p style="color: #92400E; font-size: 0.82rem; margin: 8px 0 0;">
              <i class="fas fa-clock" style="margin-right: 4px;"></i>
              Your payment receipt has been uploaded. Your order will be processed once we verify your payment. This usually takes 1-2 business hours.
            </p>
          <% } %>
        </div>
      <% } %>

      <% if (order.paymentMethod === 'cod') { %>
        <div style="background: var(--bg-card-alt); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 14px 20px; margin-bottom: 20px; display: inline-block; text-align: left; max-width: 100%;">
          <p style="font-size: 0.88rem; margin: 0; color: var(--text-primary);">
            <i class="fas fa-money-bill-wave" style="margin-right: 6px; color: var(--primary);"></i>
            <strong>Payment Method:</strong> Cash on Delivery
          </p>
          <p style="color: var(--text-muted); font-size: 0.82rem; margin: 8px 0 0;">
            <i class="fas fa-box" style="margin-right: 4px;"></i>
            Please have the exact amount ready when your order arrives.
          </p>
        </div>
      <% } %>
      
      <div style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); padding: clamp(16px, 4vw, 30px); text-align: left; box-shadow: var(--shadow-sm); margin-bottom: 32px;">
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Order Date</span>
            <span style="font-weight: 600; color: var(--text-primary);"><%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          </div>
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Payment Method</span>
            <span style="font-weight: 600; color: var(--text-primary); text-transform: capitalize;">
              <% if (order.paymentMethod === 'cod') { %>Cash on Delivery
              <% } else if (order.paymentMethod === 'card_payment') { %>Card Payment
              <% } else { %>Bank Transfer<% } %>
            </span>
          </div>
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Total Amount</span>
            <span style="font-weight: 700; color: var(--primary); font-size: 1.2rem;">LKR <%= order.total.toFixed(2) %></span>
          </div>
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Status</span>
            <span style="display: inline-block; background: var(--primary-light); color: var(--primary); padding: 3px 12px; border-radius: var(--radius-full); font-size: 0.82rem; font-weight: 600; text-transform: capitalize;"><%= order.status %></span>
          </div>
        </div>
        
        <div style="border-top: 1px solid var(--border-color); padding-top: 20px;">
          <h3 style="font-family: var(--font-display); font-size: 1.05rem; color: var(--text-primary); margin-bottom: 14px;">Items Ordered</h3>
          <% order.items.forEach(function(item) { %>
            <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border-color-light); gap: 10px; flex-wrap: wrap;">
              <div style="flex: 1; min-width: 150px;">
                <span style="font-weight: 500; color: var(--text-primary);"><%= item.name %></span>
                <span style="color: var(--text-muted); font-size: 0.85rem; margin-left: 10px;">x<%= item.quantity %></span>
              </div>
              <span style="font-weight: 600; color: var(--text-primary);">LKR <%= item.subtotal.toFixed(2) %></span>
            </div>
          <% }) %>
        </div>
        
        <div style="border-top: 1px solid var(--border-color); padding-top: 16px; margin-top: 16px;">
          <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--text-body); font-size: 0.9rem;"><span>Subtotal</span><span>LKR <%= order.subtotal.toFixed(2) %></span></div>
          <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--text-body); font-size: 0.9rem;"><span>Shipping</span><span><%= order.shippingCost === 0 ? 'FREE' : 'LKR ' + order.shippingCost.toFixed(2) %></span></div>
          <% if (order.couponDiscount && order.couponDiscount > 0) { %>
            <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--success); font-size: 0.9rem;"><span>Discount (<%= order.couponCode %>)</span><span>-LKR <%= order.couponDiscount.toFixed(2) %></span></div>
          <% } %>
          <div style="display: flex; justify-content: space-between; padding: 8px 0; font-weight: 700; color: var(--text-primary); font-size: 1.05rem; border-top: 1px solid var(--border-color); margin-top: 8px;"><span>Total</span><span>LKR <%= order.total.toFixed(2) %></span></div>
          <div style="font-size:0.75rem;color:var(--text-muted);text-align:right;margin-top:4px;">Tax/VAT included</div>
        </div>
        
        <% if (order.shippingAddress && order.shippingAddress.street) { %>
          <div style="border-top: 1px solid var(--border-color); padding-top: 16px; margin-top: 16px;">
            <h4 style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 6px;">Shipping Address</h4>
            <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.5;">
              <%= order.shippingAddress.street %><br>
              <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.zipCode %><br>
              <%= order.shippingAddress.country %>
            </p>
          </div>
        <% } %>
      </div>
      
      <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
        <% if (order.paymentMethod === 'cod' || order.paymentVerified) { %>
          <a href="/cart/invoice/<%= order._id %>" class="hero-btn-outline" style="font-size: 0.95rem; border-color: var(--primary); color: var(--primary); background: transparent; text-decoration: none;">
            <i class="fas fa-download"></i> Download Invoice
          </a>
        <% } %>
        <a href="/products" class="hero-btn-primary" style="font-size: 0.95rem; text-decoration: none;">
          <i class="fas fa-shopping-bag"></i> Continue Shopping
        </a>
        <a href="/" class="hero-btn-outline" style="font-size: 0.95rem; border-color: var(--border-color); color: var(--text-muted); background: transparent; text-decoration: none;">
          <i class="fas fa-home"></i> Go Home
        </a>
      </div>
      
    </div>
  </div>
</div>

<style>
@keyframes popIn {
  0% { transform: scale(0); opacity: 0; }
  70% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}
@media (max-width: 480px) {
  .order-items-list { max-height: 250px; }
  .order-item-mini { flex-wrap: wrap; }
  .order-item-mini-image { width: 50px; height: 50px; }
}
</style>

<%- include('partials/footer') %>