<%- include('partials/header') %>

<div style="padding: 80px 0; background: var(--gray-50); min-height: 60vh;">
  <div class="container">
    <div style="max-width: 700px; margin: 0 auto; text-align: center;">
      
      <!-- Success Icon -->
      <div style="width: 80px; height: 80px; background: var(--success-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; animation: popIn 0.5s ease;">
        <i class="fas fa-check-circle" style="font-size: 3rem; color: var(--success);"></i>
      </div>
      
      <h1 style="font-family: var(--font-display); font-size: 2.2rem; color: var(--gray-900); margin-bottom: 8px;">Order Confirmed!</h1>
      <p style="color: var(--gray-500); font-size: 1.05rem; margin-bottom: 8px;">Thank you for your purchase!</p>
      <p style="color: var(--primary); font-weight: 600; font-size: 1.1rem; margin-bottom: 36px;">Order #<%= order.orderNumber %></p>
      
      <!-- Order Details Card -->
      <div style="background: var(--white); border: var(--border); border-radius: var(--radius-xl); padding: 30px; text-align: left; box-shadow: var(--shadow-sm); margin-bottom: 32px;">
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Order Date</span>
            <span style="font-weight: 600; color: var(--gray-900);"><%= order.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          </div>
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Payment Method</span>
            <span style="font-weight: 600; color: var(--gray-900); text-transform: capitalize;"><%= order.paymentInfo.method.replace('_', ' ') %></span>
          </div>
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Total Amount</span>
            <span style="font-weight: 700; color: var(--primary); font-size: 1.2rem;">$<%= order.total.toFixed(2) %></span>
          </div>
          <div>
            <span style="display: block; font-size: 0.78rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Status</span>
            <span style="display: inline-block; background: var(--primary-light); color: var(--primary); padding: 3px 12px; border-radius: var(--radius-full); font-size: 0.82rem; font-weight: 600; text-transform: capitalize;"><%= order.status %></span>
          </div>
        </div>
        
        <div style="border-top: var(--border); padding-top: 20px;">
          <h3 style="font-family: var(--font-display); font-size: 1.05rem; color: var(--gray-900); margin-bottom: 14px;">Items Ordered</h3>
          <% order.items.forEach(function(item) { %>
            <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--gray-100);">
              <div>
                <span style="font-weight: 500; color: var(--gray-800);"><%= item.name %></span>
                <span style="color: var(--gray-500); font-size: 0.85rem; margin-left: 10px;">x<%= item.quantity %></span>
              </div>
              <span style="font-weight: 600; color: var(--gray-900);">$<%= item.subtotal.toFixed(2) %></span>
            </div>
          <% }) %>
        </div>
        
        <div style="border-top: var(--border); padding-top: 16px; margin-top: 16px;">
          <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--gray-600); font-size: 0.9rem;"><span>Subtotal</span><span>$<%= order.subtotal.toFixed(2) %></span></div>
          <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--gray-600); font-size: 0.9rem;"><span>Shipping</span><span><%= order.shippingCost === 0 ? 'FREE' : '$' + order.shippingCost.toFixed(2) %></span></div>
          <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--gray-600); font-size: 0.9rem;"><span>Tax</span><span>$<%= order.tax.toFixed(2) %></span></div>
          <% if (order.couponDiscount && order.couponDiscount > 0) { %>
            <div style="display: flex; justify-content: space-between; padding: 6px 0; color: var(--success); font-size: 0.9rem;"><span>Discount (<%= order.couponCode %>)</span><span>-$<%= order.couponDiscount.toFixed(2) %></span></div>
          <% } %>
          <div style="display: flex; justify-content: space-between; padding: 8px 0; font-weight: 700; color: var(--gray-900); font-size: 1.05rem; border-top: var(--border); margin-top: 8px;"><span>Total</span><span>$<%= order.total.toFixed(2) %></span></div>
        </div>
        
        <% if (order.shippingAddress && order.shippingAddress.street) { %>
          <div style="border-top: var(--border); padding-top: 16px; margin-top: 16px;">
            <h4 style="font-size: 0.85rem; color: var(--gray-700); margin-bottom: 6px;">Shipping Address</h4>
            <p style="color: var(--gray-500); font-size: 0.9rem; line-height: 1.5;">
              <%= order.shippingAddress.street %><br>
              <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.zipCode %><br>
              <%= order.shippingAddress.country %>
            </p>
          </div>
        <% } %>
      </div>
      
      <!-- Buttons -->
      <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
        <a href="/cart/invoice/<%= order._id %>" class="hero-btn-outline" style="font-size: 0.95rem; border-color: var(--primary); color: var(--primary); background: transparent;">
          <i class="fas fa-download"></i> Download Invoice
        </a>
        <a href="/products" class="hero-btn-primary" style="font-size: 0.95rem;">
          <i class="fas fa-shopping-bag"></i> Continue Shopping
        </a>
        <a href="/" class="hero-btn-outline" style="font-size: 0.95rem; border-color: var(--gray-300); color: var(--gray-600); background: transparent;">
          <i class="fas fa-home"></i> Go Home
        </a>
      </div>
      
    </div>
  </div>
</div>

<style>
@keyframes popIn {
  0% { transform: scale(0); opacity: 0; }
  70% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}
</style>

<%- include('partials/footer') %>