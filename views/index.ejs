  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter-section">
  <div class="newsletter-bg-shapes">
    <div class="newsletter-shape ns-1"></div>
    <div class="newsletter-shape ns-2"></div>
    <div class="newsletter-shape ns-3"></div>
  </div>
  <div class="container">
    <div class="newsletter-content">
      <div class="newsletter-icon-wrapper">
        <i class="fas fa-paper-plane"></i>
      </div>
      <h2 class="newsletter-title">Get 15% Off Your First Order</h2>
      <p class="newsletter-desc">Subscribe to our newsletter and receive exclusive deals, new arrivals alerts, and a welcome discount code straight to your inbox.</p>
      <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Thank you for subscribing! Check your email for your 15% discount code.');">
        <input type="email" class="newsletter-input" placeholder="Enter your email address" required>
        <button type="submit" class="newsletter-btn">
          <i class="fas fa-arrow-right"></i> Subscribe
        </button>
      </form>
      <p class="newsletter-trust">No spam, unsubscribe anytime. Your email is safe with us.</p>
      <div class="newsletter-stats">
        <div class="nl-stat"><span class="nl-stat-number">25K+</span><span class="nl-stat-label">Subscribers</span></div>
        <div class="nl-stat-divider"></div>
        <div class="nl-stat"><span class="nl-stat-number">4.9</span><span class="nl-stat-label">User Rating</span></div>
        <div class="nl-stat-divider"></div>
        <div class="nl-stat"><span class="nl-stat-number">1M+</span><span class="nl-stat-label">Products Sold</span></div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>